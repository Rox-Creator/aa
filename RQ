local function flintlockResolvePart(obj)
    local part = nil
    pcall(function() part = obj:FindFirstChild("Handle") end)
    if part then return part end
    pcall(function() part = obj:FindFirstChild("Part") end)
    if part then return part end
    -- Fall back to first child that has a Position (i.e. a BasePart)
    pcall(function()
        for _, child in pairs(obj:GetChildren()) do
            local ok, _ = pcall(function() return child.Position end)
            if ok and child.Position then part = child; return end
        end
    end)
    if part then return part end
    -- Object itself may be a BasePart
    local okSelf = false
    pcall(function() if obj.Position then okSelf = true end end)
    if okSelf then return obj end
    return nil
end

