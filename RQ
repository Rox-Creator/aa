-- Load saved config BEFORE building the menu so the first paint reflects on-disk state
pcall(loadConfig)

-- NOTE: we intentionally do NOT auto-load the RS snapshot here.
-- The decode pass for a large saved snapshot is single-threaded and
-- noticeably stalls startup. Users now load it explicitly via the
-- "Load Saved" button in the RS Diff panel.

-- ============================================================
-- REQUIEM UI  —  smooth immediate-mode Drawing engine (my own)
-- ============================================================
-- Built the way INS-ui gets its smoothness: a per-frame render loop redraws
-- everything from a pooled object set, and every animated value is eased with
-- frame-rate-independent exponential smoothing  v += (target-v)*(1-exp(-k*dt))
-- (the lib's `bX`). Hover, sliding toggles/tab-underlines, eased scrolling and
-- the window open fade+rise all run on this. Wrapped in an IIFE for a fresh
-- 200-local register budget; only reaches the script's data fns as upvalues.
;(function()
local floor, expf, minf, maxf = math.floor, math.exp, math.min, math.max
local C3 = Color3.fromRGB
local T = {
    bg=C3(15,15,19), bg2=C3(12,12,16), head=C3(19,19,24), panel=C3(26,25,30),
    field=C3(36,34,40), soft=C3(50,48,56), text=C3(228,228,234), muted=C3(122,120,130),
    dim=C3(80,78,88), red=C3(222,68,74), green=C3(82,212,122), yellow=C3(240,202,72), blue=C3(100,176,255),
}
local RC = {
    Mythical=C3(220,60,60), Legendary=C3(245,200,60), Epic=C3(170,80,230), Rare=C3(70,140,240),
    Uncommon=C3(80,200,100), Common=C3(220,220,225), Unique=C3(255,130,200),
}

local R = { dt=1/60, fade=1, yoff=0, opacity=1, mx=0, my=0, down=false, justP=false }
local function smooth(cur, target, k)
    if cur == nil then return target end
    local dt = R.dt; if dt <= 0 then dt = 1/60 end
    return cur + (target - cur) * (1 - expf(-(k or 15) * dt))
end
local anim = {}
local function av(key, target, k) anim[key] = smooth(anim[key], target, k); return anim[key] end
local function mixc(a, b, t)
    return C3(floor((a.R*255+(b.R*255-a.R*255)*t)+0.5), floor((a.G*255+(b.G*255-a.G*255)*t)+0.5), floor((a.B*255+(b.B*255-a.B*255)*t)+0.5))
end
local function tw(s, size) return #tostring(s or "")*(size or 13)*0.5 end
local function trim(s, n) s=tostring(s or ""); if #s<=n then return s end return s:sub(1,maxf(1,n-2)).."." end

local pool = { Square={}, Text={}, Line={}, Circle={} }
local idx = { Square=0, Text=0, Line=0, Circle=0 }
local function claim(kind)
    idx[kind] = idx[kind]+1
    local p = pool[kind]; local o = p[idx[kind]]
    if not o then local ok; ok,o = pcall(Drawing.new, kind); if not ok or not o then return nil end; p[idx[kind]]=o end
    o.Visible = true; return o
end
local function beginFrame() idx.Square=0; idx.Text=0; idx.Line=0; idx.Circle=0 end
local function endFrame() for kind,p in pairs(pool) do for i=idx[kind]+1,#p do pcall(function() p[i].Visible=false end) end end end

-- R.clipTop/R.clipBot define a vertical scissor band (absolute screen Y). Rects
-- clamp to it; text/line/circle hide when their centre falls outside. Used to
-- keep scrolling list/grid content from spilling over the panel header.
local function rect(x,y,w,h,color,z,alpha,corner,filled,thick)
    local ay=y+R.yoff
    if R.clipTop then
        if ay+h<=R.clipTop or ay>=R.clipBot then return end
        local ny=maxf(ay,R.clipTop); h=minf(ay+h,R.clipBot)-ny; ay=ny; if h<=0 then return end
    end
    local o=claim("Square"); if not o then return end
    o.Position=Vector2.new(x,ay); o.Size=Vector2.new(maxf(0,w),maxf(0,h)); o.Color=color or T.panel
    o.Filled=filled~=false; o.Corner=corner or 0; if thick then o.Thickness=thick end
    o.Transparency=(alpha or 1)*R.fade*R.opacity; o.ZIndex=z or 60; return o
end
local function txt(s,x,y,size,color,z,center,font)
    local ay=y+R.yoff
    if R.clipTop then local mc=ay+(size or 13)*0.5; if mc<R.clipTop or mc>R.clipBot then return end end
    local o=claim("Text"); if not o then return end
    o.Position=Vector2.new(x,ay); o.Text=tostring(s==nil and "" or s); o.Size=size or 13
    o.Color=color or T.text; o.Center=center==true; o.Outline=false; o.Font=font or Drawing.Fonts.System
    o.Transparency=R.fade*R.opacity; o.ZIndex=z or 61; return o
end
local function ln(x1,y1,x2,y2,color,z,thick,alpha)
    if R.clipTop then local mc=(y1+y2)*0.5+R.yoff; if mc<R.clipTop or mc>R.clipBot then return end end
    local o=claim("Line"); if not o then return end
    o.From=Vector2.new(x1,y1+R.yoff); o.To=Vector2.new(x2,y2+R.yoff); o.Color=color or T.soft
    o.Thickness=thick or 1; o.Transparency=(alpha or 1)*R.fade*R.opacity; o.ZIndex=z or 61; return o
end
local function circ(cx,cy,rad,color,z,alpha,filled)
    if R.clipTop then local ac=cy+R.yoff; if ac+rad<R.clipTop or ac-rad>R.clipBot then return end end
    local o=claim("Circle"); if not o then return end
    o.Position=Vector2.new(cx,cy+R.yoff); o.Radius=maxf(0,rad); o.Color=color or T.text
    o.Filled=filled~=false; o.NumSides=24; o.Transparency=(alpha or 1)*R.fade*R.opacity; o.ZIndex=z or 61; return o
end
local function shadow(x,y,w,h,z) rect(x+9,y+13,w,h,C3(0,0,0),z,0.10,10); rect(x+4,y+6,w,h,C3(0,0,0),z+1,0.08,10) end

local clicks, drags, scrolls, resizes = {}, {}, {}, {}
local function inside(x,y,w,h) return R.mx>=x and R.mx<=x+w and R.my>=y+R.yoff and R.my<=y+R.yoff+h end
local function hot(id,x,y,w,h,onClick)
    local over=inside(x,y,w,h)
    if onClick then clicks[#clicks+1]={x=x,y=y+R.yoff,w=w,h=h,onClick=onClick} end
    return av("h:"..id, over and 1 or 0, 16), over
end

local function window(key,x,y,w,h,title,subtitle,onClose)
    local z=60
    shadow(x,y,w,h,z-4)
    rect(x,y,w,h,T.bg,z,0.95,8)
    rect(x,y,w,h,C3(255,255,255),z+1,0.12,8,false,1)
    rect(x,y,w,34,T.head,z+1,0.93,8)
    rect(x,y+26,w,8,T.head,z+1,0.93,0)
    ln(x+12,y+34,x+w-12,y+34,T.red,z+2,1,0.5)
    rect(x+12,y+9,15,15,C3(40,24,28),z+3,0.9,4)
    ln(x+16,y+13,x+23,y+13,T.red,z+4,1.5,1); ln(x+16,y+17,x+23,y+17,T.red,z+4,1.5,1); ln(x+16,y+21,x+23,y+21,T.red,z+4,1.5,1)
    txt(title,x+34,y+8,16,T.red,z+4,false,Drawing.Fonts.SystemBold)
    if subtitle and subtitle~="" then txt(subtitle,x+34+tw(title,16)+12,y+11,12,T.muted,z+4) end
    -- (no X button — popups are closed from the menu toggle; the resize grip stays)
    drags[#drags+1]={x=x,y=y+R.yoff,w=w-20,h=34,key=key}
    -- resize grip (bottom-right), like the original menu
    local rhv=hot(key..":rs",x+w-20,y+h-20,18,18)
    ln(x+w-16,y+h-7,x+w-7,y+h-16,mixc(T.muted,T.text,rhv*0.5),z+6,1.5,0.7)
    ln(x+w-12,y+h-7,x+w-7,y+h-12,mixc(T.muted,T.text,rhv*0.5),z+6,1.5,0.7)
    resizes[#resizes+1]={x=x+w-20,y=y+h-20+R.yoff,w=20,h=20,key=key}
    return x+14,y+44,w-28
end

local function card(x,y,w,h,z,active,accent,hov)
    accent=accent or T.red
    shadow(x,y,w,h,z-1)
    rect(x,y,w,h,mixc(active and C3(40,27,31) or T.panel, T.soft, (hov or 0)*0.35),z,active and 0.9 or 0.78,6)
    rect(x,y,w,h,active and accent or mixc(T.soft,accent,(hov or 0)*0.6),z+1,active and 0.7 or (0.28+(hov or 0)*0.4),6,false,1)
end

local function button(id,x,y,w,h,label,onClick,primary,accent,z)
    accent=accent or T.red; z=z or 62
    local hv=hot(id,x,y,w,h,onClick)
    if primary then
        rect(x,y,w,h,mixc(accent,C3(255,255,255),hv*0.12),z,0.94,5)
        txt(label,x+w/2,y+(h-14)/1.35,13,C3(18,18,22),z+2,true,Drawing.Fonts.SystemBold)
    else
        rect(x,y,w,h,mixc(C3(32,30,36),C3(48,46,54),hv*0.5),z,0.82,5)
        rect(x,y,w,h,accent,z+1,0.4+hv*0.4,5,false,1)
        txt(label,x+w/2,y+(h-13)/1.35,13,mixc(accent,T.text,hv*0.2),z+2,true,Drawing.Fonts.SystemBold)
    end
end

local function toggle(id,x,y,label,value,onClick)
    local z=62
    txt(label,x,y+2,13,T.text,z+1)
    local tx,tw2,th=x+150,38,18
    local a=av("t:"..id, value and 1 or 0, 18)
    hot(id,tx,y,tw2,th,onClick)
    rect(tx,y,tw2,th,mixc(C3(50,48,55),T.red,a),z,0.86,9)
    circ(tx+10+(tw2-20)*a, y+th/2, 7, C3(236,236,240), z+2, 1)
end

local function checkbox(id,x,y,label,checked,onClick)
    local z=62; local a=av("c:"..id, checked and 1 or 0, 18)
    hot(id,x-2,y-2,20+tw(label,13)+10,20,onClick)
    rect(x,y,16,16,T.field,z,0.9,3)
    rect(x,y,16,16,mixc(T.soft,T.red,a),z+1,0.5+a*0.45,3,false,1)
    if a>0.1 then ln(x+4,y+8,x+7,y+12,T.red,z+2,2,a); ln(x+7,y+12,x+13,y+4,T.red,z+2,2,a) end
    txt(label,x+24,y-1,13,T.text,z+2)
end

local function tabs(key,x,y,w,names,selected,onSelect,colorFor)
    local z=62; local tw2=floor(w/#names); local selIdx=1
    for i,n in ipairs(names) do
        if selected==n then selIdx=i end
        local active=selected==n
        local col=(colorFor and colorFor(n)) or T.red
        local hv=hot(key..":"..n,x+(i-1)*tw2,y,tw2,28,function() onSelect(n) end)
        txt(n,x+(i-1)*tw2+tw2/2,y+8,13,mixc(active and col or T.muted, T.text, (active and 0 or hv*0.4)),z+2,true,active and Drawing.Fonts.SystemBold or Drawing.Fonts.System)
    end
    ln(x+4,y+28,x+w-4,y+28,T.soft,z+1,1,0.35)
    -- ease the RELATIVE offset (not absolute x) so dragging the window doesn't slide it
    local uoff = av(key..":u", (selIdx-1)*tw2, 22)
    local ucol=(colorFor and colorFor(selected)) or T.red
    ln(x+uoff+8,y+26,x+uoff+tw2-8,y+26,ucol,z+3,2,0.95)
end

local function scrollbar(key,offKey,x,y,h,maxScroll,viewH,contentH)
    local z=64
    GUI[offKey]=maxf(0,minf(GUI[offKey] or 0,maxScroll))
    local disp=av("s:"..key, GUI[offKey], 16)
    if maxScroll>0 then
        rect(x,y,5,h,T.bg2,z,0.5,3)
        local thumbH=maxf(28,h*(viewH/maxf(1,contentH)))
        local ty=y+(h-thumbH)*(disp/maxScroll)
        local hv=hot("sb:"..key,x-3,ty,11,thumbH)
        rect(x,ty,5,thumbH,mixc(T.soft,T.text,hv*0.3),z+1,0.85,3)
        scrolls[#scrolls+1]={x=x-3,y=ty+R.yoff,w=11,h=thumbH,key=offKey,track=h-thumbH,maxScroll=maxScroll}
    end
    return disp
end

local function healthbar(x,y,w,hp,maxHp,z)
    z=z or 63
    local m=tonumber(maxHp) or 0; if m<=0 then m=maxf(100,tonumber(hp) or 0) end
    local r=maxf(0,minf(1,(tonumber(hp) or 0)/m))
    local col= r>0.5 and T.green or (r>0.25 and T.yellow or T.red)
    rect(x,y,w,6,C3(30,30,36),z,0.85,3)
    if r>0 then rect(x,y,maxf(3,w*r),6,col,z+1,0.95,3) end
end

local plTimer = 0
local enCache, enSig, enTimer = nil, nil, 0  -- cache the (sorted) enchant list; rebuild only on filter change / every 0.4s
local function drawPlayers()
    if not GUI.PlayerListOpen then anim.plopen=0; return end
    local op=av("plopen",1,14); R.fade=op; R.yoff=(1-op)*12
    plTimer=plTimer+R.dt
    if plTimer>1.5 then plTimer=0; pcall(function() GUI.PLCachedPlayers=ReadPlayerData() end) end
    local x,y,w,h=GUI.PlayerListX,GUI.PlayerListY,GUI.PlayerListW,GUI.PlayerListH
    local src=GUI.PLCachedPlayers or {}
    local tab,search=GUI.PlayerListTab or "Players",string.lower(GUI.PLSearchText or "")
    local list={}
    for _,p in ipairs(src) do
        local ok
        if tab=="Dead" then ok=p.Dead==true elseif tab=="Staff" then ok=(not p.Dead) and (p.StaffState or 0)>0 else ok=(not p.Dead) and (p.StaffState or 0)<=0 end
        if ok and search~="" then ok=string.find(string.lower(tostring(p.Name).." "..tostring(p.DisplayName or "")),search,1,true)~=nil end
        if ok then list[#list+1]=p end
    end
    if GUI.PLSortMode=="Rank" then table.sort(list,function(a,b) return (a.Rank or 0)>(b.Rank or 0) end)
    elseif GUI.PLSortMode=="Health" then table.sort(list,function(a,b) return (a.Health or 0)<(b.Health or 0) end)
    else table.sort(list,function(a,b) return tostring(a.Name)<tostring(b.Name) end) end

    local cx,cy,cw=window("pl",x,y,w,h,"Player List","("..#list..")",function() GUI.PlayerListOpen=false end)
    local listW=floor(cw*0.52); local detX=x+14+listW+16; local detW=w-28-listW-16
    tabs("pltab",x+14,cy,listW,{"Players","Staff","Dead"},tab,function(n) GUI.PlayerListTab=n; GUI.PLScrollOffset=0; GUI.PlayerListSelected=nil end,nil)
    -- search bar (full width) with the sort buttons on their own row below it
    local searchY=cy+42
    button("plsearch",x+14,searchY,listW,26,(GUI.PLSearchText~="" and GUI.PLSearchText or "Search players...")..(GUI.PLSearchFocused and "|" or ""),function() GUI.PLSearchFocused=not GUI.PLSearchFocused end,false,GUI.PLSearchFocused and T.red or T.soft)
    local sortY=searchY+32; local sbw=floor((listW-16)/3)
    for i,s in ipairs({"None","Rank","Health"}) do button("plsort"..s,x+14+(i-1)*(sbw+8),sortY,sbw,26,s,function() GUI.PLSortMode=s; GUI.PLScrollOffset=0 end, GUI.PLSortMode==s, T.red) end
    local listY=sortY+36; local listH=(y+h-14)-listY; local rowH=42
    local maxS=maxf(0,#list*rowH-listH)
    local off=scrollbar("pl","PLScrollOffset",x+14+listW-6,listY,listH,maxS,listH,#list*rowH)
    R.clipTop=listY-1; R.clipBot=y+h-12
    for i,p in ipairs(list) do
        local rY=listY+(i-1)*rowH-off
        if rY+rowH>listY-2 and rY<y+h-12 then
            local sel=GUI.PlayerListSelected==p.Name
            local hv=hot("plrow"..i,x+14,rY,listW-12,rowH-6,function() GUI.PlayerListSelected=p.Name end)
            card(x+14,rY,listW-12,rowH-6,63,sel,T.red,hv)
            txt(trim(p.DisplayName or p.Name,20),x+26,rY+7,13,sel and T.red or T.text,66,false,Drawing.Fonts.SystemBold)
            healthbar(x+26,rY+26,listW-150,p.Health,p.MaxHealth,65)
            local mh=(p.MaxHealth and p.MaxHealth>0) and p.MaxHealth or maxf(100,p.Health or 0)
            local hs=p.Dead and "DEAD" or (floor(p.Health or 0).."/"..floor(mh))
            txt(hs,x+14+listW-20-tw(hs,12),rY+14,12,p.Dead and T.red or T.muted,66,false,p.Dead and Drawing.Fonts.SystemBold or Drawing.Fonts.System)
        end
    end
    R.clipTop=nil; R.clipBot=nil
    -- details pane
    local dH=h-(cy-y)-14
    card(detX,cy,detW,dH,61,false)
    local p; for _,q in ipairs(src) do if q.Name==GUI.PlayerListSelected then p=q break end end
    if p then
        local mh=(p.MaxHealth and p.MaxHealth>0) and p.MaxHealth or maxf(100,p.Health or 0)
        local alive=not p.Dead; local chipC=alive and T.green or T.red
        txt(trim(p.DisplayName or p.Name,16),detX+16,cy+14,18,T.text,64,false,Drawing.Fonts.SystemBold)
        txt("@"..trim(p.Name,18),detX+16,cy+37,12,T.muted,64)
        rect(detX+detW-72,cy+16,56,20,mixc(T.panel,chipC,0.22),64,0.9,6)
        rect(detX+detW-72,cy+16,56,20,chipC,65,0.55,6,false,1)
        txt(alive and "ALIVE" or "DEAD",detX+detW-44,cy+21,11,chipC,66,true,Drawing.Fonts.SystemBold)
        txt("HEALTH",detX+16,cy+60,11,T.muted,64,false,Drawing.Fonts.SystemBold)
        local hnum=floor(p.Health or 0).."  /  "..floor(mh)
        txt(hnum,detX+detW-16-tw(hnum,13),cy+59,13,chipC,64)
        healthbar(detX+16,cy+78,detW-32,p.Health,p.MaxHealth,64)
        ln(detX+16,cy+98,detX+detW-16,cy+98,T.soft,64,1,0.3)
        local info={
            {"Branch",(BRANCH_NAMES and BRANCH_NAMES[p.Branch]) or "None",T.blue},
            {"Rank",(GetRankName and GetRankName(p.Rank,p.Branch)) or tostring(p.Rank or "-"),T.text},
            {"Staff",(STAFF_NAMES and STAFF_NAMES[p.StaffState]) or "Player",(p.StaffState or 0)>0 and T.yellow or T.muted},
            {"Username",tostring(p.Name),T.muted},
        }
        for i,rw in ipairs(info) do
            local rY=cy+112+(i-1)*30
            rect(detX+16,rY,detW-32,24,T.panel,63,0.55,5)
            txt(rw[1],detX+26,rY+5,12,T.muted,64)
            local v=trim(rw[2],20)
            txt(v,detX+detW-26-tw(v,13),rY+5,13,rw[3] or T.text,64,false,Drawing.Fonts.SystemBold)
        end
        button("plmon",detX+16,cy+dH-44,detW-32,30,"Monitor Health",function() pcall(function() ToggleMonitorBar(p.Name) end) end,true,T.red)
    else
        txt("Select a player",detX+detW/2,cy+dH/2-12,15,T.muted,64,true,Drawing.Fonts.SystemBold)
        txt("from the list to see details",detX+detW/2,cy+dH/2+10,12,T.dim,64,true)
    end
    R.fade=1; R.yoff=0
end

local function drawEnchants()
    if not GUI.EnchantsOpen then anim.enopen=0; return end
    local op=av("enopen",1,14); R.fade=op; R.yoff=(1-op)*12
    local x,y,w,h=GUI.EnchantsX,GUI.EnchantsY,GUI.EnchantsW,GUI.EnchantsH
    if not GUI.EnchantsAllData and not GUI.EnchantsFetching then
        GUI.EnchantsFetching=true
        task.spawn(function() pcall(FetchEnchantData); pcall(FetchOwnedEnchants); GUI.EnchantsFetching=false end)
    end
    enTimer=enTimer+R.dt
    local sig=tostring(GUI.EnchantsRarityFilter)..tostring(GUI.EnchantsShowUnowned)..(GUI.EnchantsAllData and "1" or "0")
    if (not enCache) or sig~=enSig or enTimer>0.4 then enTimer=0; enSig=sig; enCache=(GUI.EnchantsAllData and buildFilteredEnchantList()) or {} end
    local list=enCache
    local owned=0; for _,it in ipairs(list) do if it.owned then owned=owned+1 end end
    local cx,cy,cw=window("en",x,y,w,h,"Enchants",(GUI.EnchantsAllData and (owned.." / "..#list) or (GUI.EnchantsFetching and "fetching..." or "")),function() GUI.EnchantsOpen=false; GUI.EnchantsModal=nil end)
    local rar={"All"}; for _,r in ipairs(ENCHANT_RARITIES) do rar[#rar+1]=r end
    tabs("entab",x+14,cy,cw,rar,GUI.EnchantsRarityFilter,function(n) GUI.EnchantsRarityFilter=n; GUI.EnchantsScrollOffset=0 end,function(n) return n=="All" and T.red or RC[n] or T.text end)
    checkbox("enmiss",x+14,cy+38,"Show Missing Only",GUI.EnchantsShowUnowned,function() GUI.EnchantsShowUnowned=not GUI.EnchantsShowUnowned; GUI.EnchantsScrollOffset=0 end)
    button("enref",x+w-128,cy+34,110,24,"Refresh",function() task.spawn(function() pcall(FetchOwnedEnchants) end) end,false,T.red)
    local gridY=cy+72; local gridH=(y+h-14)-gridY; local pad=12; local cols=4
    local cardW=floor((cw-(cols-1)*pad)/cols); local cardH=96; local rows=math.ceil(#list/cols)
    local maxS=maxf(0,rows*(cardH+pad)-gridH)
    local off=scrollbar("en","EnchantsScrollOffset",x+w-14,gridY,gridH,maxS,gridH,rows*(cardH+pad))
    R.clipTop=gridY-1; R.clipBot=y+h-12
    for i,it in ipairs(list) do
        local r=floor((i-1)/cols); local c=(i-1)%cols
        local cY=gridY+r*(cardH+pad)-off
        if cY+cardH>gridY-2 and cY<y+h-12 then
            local cX=x+14+c*(cardW+pad); local col=RC[it.rarity] or T.text
            local hv=hot("encard"..i,cX,cY,cardW,cardH,function() GUI.EnchantsModal=it end)
