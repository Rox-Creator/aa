-- File-local rarity table + helpers, used by both the fetch and the lazy
-- card-click description loader.
local ENCHANT_RARITY_NAMES = {
    Mythical = true, Mythic = true, Legendary = true, Epic = true,
    Rare = true, Uncommon = true, Common = true, Unique = true,
}

local function enchantRarityFromAncestors(inst)
    local node = nil
    pcall(function() node = inst.Parent end)
    for _ = 1, 6 do
        if not node then break end
        local nm = nil
        pcall(function() nm = node.Name end)
        if nm and ENCHANT_RARITY_NAMES[nm] then
            if nm == "Mythic" then return "Mythical" end
            return nm
        end
        local nextNode = nil
        pcall(function() nextNode = node.Parent end)
        node = nextNode
    end
    return nil
end

local function enchantDescriptionFromSource(src)
    if not src or src == "" then return nil end
    -- Try a bunch of common field names, in priority order. Long-bracket
    -- strings ([[...]]) come first within each field so multi-line
    -- descriptions win over short quoted strings elsewhere in the file.
    local fields = {
        "Description", "description",
        "Desc", "desc",
        "Effect", "effect",
        "Tooltip", "tooltip",
        "Info", "info",
        "Body", "body",
        "Text", "text",
    }
    for _, f in ipairs(fields) do
        local d = src:match(f .. "%s*=%s*%[%[(.-)%]%]")
            or src:match('%["' .. f .. '"%]%s*=%s*%[%[(.-)%]%]')
            or src:match("%['" .. f .. "'%]%s*=%s*%[%[(.-)%]%]")
            or src:match(f .. '%s*=%s*"([^"]*)"')
            or src:match(f .. "%s*=%s*'([^']*)'")
            or src:match('%["' .. f .. '"%]%s*=%s*"([^"]*)"')
            or src:match("%['" .. f .. "'%]%s*=%s*'([^']*)'")
        if d and #d > 0 then return d end
    end
    -- Last-resort fallback: pick the longest plausible string in the source.
    -- Most enchant modules have at most one long human-readable string, so
    -- this catches modules with non-standard field names.
    local best = nil
    for s in src:gmatch("%[%[(.-)%]%]") do
        if #s >= 30 and #s <= 600 and (not best or #s > #best) then best = s end
    end
    if not best then
        for s in src:gmatch('"([^"]+)"') do
            if #s >= 30 and #s <= 600 and not s:find("\\") and not s:find("/") then
                if not best or #s > #best then best = s end
            end
        end
    end
    return best
end

local function enchantRarityFromSource(src)
    if not src or src == "" then return nil end
    local r = src:match('[Rr]arity%s*=%s*"([^"]+)"')
        or src:match("[Rr]arity%s*=%s*'([^']+)'")
        or src:match('%["[Rr]arity"%]%s*=%s*"([^"]+)"')
    if r and ENCHANT_RARITY_NAMES[r] then
        if r == "Mythic" then return "Mythical" end
        return r
    end
    return nil
end

-- Walks ReplicatedStorage.Client.Progression.Enchantments.Enchantments and
-- builds { [name] = { rarity, description = nil, module = ModuleScript } }.
-- Rarity comes from the ancestor folder name; descriptions are fetched lazily
-- on card click (decompile() in a tight loop hangs the VM and looked like a
-- crash on first open). Yields every few items to keep the VM responsive.
FetchEnchantData = function()
    local data = {}

    local ok, err = pcall(function()
        local rs = game:GetService("ReplicatedStorage")
        local node = rs:FindFirstChild("Client")
        if node then node = node:FindFirstChild("Progression") end
        if node then node = node:FindFirstChild("Enchantments") end
        if node then node = node:FindFirstChild("Enchantments") end
        if not node then
            GUI.EnchantsFetchStatus = "Folder not found"
            return
        end

        -- Depth-limited walk (safer than GetDescendants on large trees)
        local modules = {}
        local function walk(inst, depth)
            if depth > 5 then return end
            local kids = nil
            pcall(function() kids = inst:GetChildren() end)
            if not kids then return end
            for _, c in pairs(kids) do
                local cls = nil
                pcall(function() cls = c.ClassName end)
                if cls == "ModuleScript" then
                    table.insert(modules, c)
                else
                    walk(c, depth + 1)
                end
            end
        end
        walk(node, 0)

        local total = #modules
        local kept = 0
        for i, mod in ipairs(modules) do
            -- One bad module (or one bad decompile) shouldn't kill the loop.
            -- We try ancestor first (free) and fall back to decompile only
            -- when needed. Description comes from the same decompiled source
            -- if we ran one, otherwise stays nil and is loaded on card click.
            pcall(function()
                local rarity = enchantRarityFromAncestors(mod)
                local description = nil
                if not rarity then
                    local src = nil
                    pcall(function() src = decompile(mod) end)
                    rarity = enchantRarityFromSource(src)
                    description = enchantDescriptionFromSource(src)
                end
                if rarity then
                    data[mod.Name] = {
                        rarity = rarity,
                        description = description,  -- may be nil → lazy load on click
                        module = mod,
                    }
                    kept = kept + 1
                end
            end)
            -- Yield every iteration when we might be decompiling, less often
            -- when ancestor walk is enough. Cheaper than freezing the VM.
            if i % 4 == 0 then
                GUI.EnchantsFetchStatus = "Loading " .. i .. " / " .. total
                task.wait()
            end
        end
        GUI.EnchantsFetchStatus = kept .. " enchants loaded"
    end)
    if not ok then
        GUI.EnchantsFetchStatus = "Error: " .. tostring(err)
    end
    GUI.EnchantsAllData = data
end

-- Reads owned enchants from LocalPlayer.PlayerGui.Enchantments.Enchantments
-- (each Frame child is one owned enchant; Frame.Name == enchant module name)
FetchOwnedEnchants = function()
    local owned = {}
    pcall(function()
        local pgui = LocalPlayer:FindFirstChild("PlayerGui")
        if not pgui then return end
        local container = pgui:FindFirstChild("Enchantments")
        if not container then return end
        local list = container:FindFirstChild("Enchantments")
        if not list then return end
        for _, frame in pairs(list:GetChildren()) do
            local nm = nil
            pcall(function() nm = frame.Name end)
            if nm and nm ~= "" then owned[nm] = true end
        end
    end)
    GUI.EnchantsOwned = owned
end

local function buildFilteredEnchantList()
    local all = GUI.EnchantsAllData or {}
    local owned = GUI.EnchantsOwned or {}
    local filter = GUI.EnchantsRarityFilter
    local showUnowned = GUI.EnchantsShowUnowned

    local list = {}
    for name, info in pairs(all) do
        local rarity = info.rarity
        local pass = true
        if filter ~= "All" and rarity ~= filter then pass = false end
        if pass and showUnowned then
            -- Only show rarities the player can actually obtain
            if owned[name] or ENCHANT_RARITY_UNOBTAINABLE[rarity] then pass = false end
        end
        if pass then
            table.insert(list, {
                name = name,
                rarity = rarity,
                description = info.description,  -- nil until lazily decompiled
                module = info.module,
                owned = owned[name] == true,
            })
        end
    end
    -- Sort: by rarity rank desc, then name asc
    local rarityRank = {}
    for i, r in ipairs(ENCHANT_RARITIES) do rarityRank[r] = i end
    table.sort(list, function(a, b)
        local ra = rarityRank[a.rarity] or 0
        local rb = rarityRank[b.rarity] or 0
        if ra ~= rb then return ra > rb end
        return a.name < b.name
    end)
    return list
end

-- Word-wrap a single string into N-char-ish lines (Drawing has no auto-wrap)
local function wrapEnchantText(text, maxLen)
    local lines = {}
    if not text or text == "" then return { "" } end
    local current = ""
    for word in string.gmatch(text, "%S+") do
        if #current == 0 then
            current = word
        elseif #current + 1 + #word <= maxLen then
            current = current .. " " .. word
        else
            table.insert(lines, current)
            current = word
        end
    end
    if #current > 0 then table.insert(lines, current) end
    return lines
end

