                        break
                    end
                end
            end
            if hoverRect then
                GUI._enchHoverEl.Position = Vector2.new(hoverRect.x - 1, hoverRect.y - 1)
                GUI._enchHoverEl.Size = Vector2.new(hoverRect.w + 2, hoverRect.h + 2)
                GUI._enchHoverEl.Color = hoverRect.rcol or Colors.AccentRed
                GUI._enchHoverEl.Visible = true
            else
                GUI._enchHoverEl.Visible = false
            end

            GUI._enchWasMouseDown = mouseDown
        else
            -- Panel closed: make sure the hover indicator is hidden
            if GUI._enchHoverEl then GUI._enchHoverEl.Visible = false end
        end

        -- RS Diff panel drag + scroll + click (independent of main GUI).
        -- Same structure as Enchants but simpler — no modal, no card
        -- hitboxes, just header drag, button clicks, and a scrollbar.
        if GUI.RSDiffOpen and #GUI.RSDiffElements > 0 then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local justP = mouseDown and not (GUI._rsWasMouseDown or false)
            local headerH = 34
            local onHeader = IsInside(mx, my, GUI.RSDiffX, GUI.RSDiffY, GUI.RSDiffW, headerH)

            if GUI.RSDiffDragging then
