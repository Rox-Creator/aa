local function animalUpdate()
    if not ANIMAL.Enabled then
        for _, data in pairs(ANIMAL.Objects) do
            for _, ln in ipairs(data.wireLines) do ln.Visible = false end
            data.nameTag.Visible = false
        end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end

    for id, data in pairs(ANIMAL.Objects) do
        local model = data.model

        local function hideAll()
            for _, ln in ipairs(data.wireLines) do ln.Visible = false end
            data.nameTag.Visible = false
        end

        if not model or not model.Parent then
            hideAll()
        else
            local curPos = nil
            pcall(function() curPos = data.refPart.Position end)
            if curPos and data.lastPos then
                local mx = curPos.X - data.lastPos.X
                local my = curPos.Y - data.lastPos.Y
                local mz = curPos.Z - data.lastPos.Z
                if mx*mx + my*my + mz*mz > 0.01 then
                    data.lastPos = curPos
                    data.lastMoveTime = tick()
                    data.isDead = false
                else
                    if tick() - data.lastMoveTime > 7 then
                        data.isDead = true
                    end
                end
            elseif curPos then
                data.lastPos = curPos
                data.lastMoveTime = tick()
            end

            if data.isDead then
                hideAll()
            else
                local mnX, mnY, mnZ, mxX, mxY, mxZ = getAnimalAABB(data.partList)
                if not mnX then
                    hideAll()
                else
                    local cx = (mnX + mxX) / 2
                    local cy = (mnY + mxY) / 2
                    local cz = (mnZ + mxZ) / 2
                    local dx = playerPos.X - cx
                    local dy = playerPos.Y - cy
                    local dz = playerPos.Z - cz
                    local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

                    if dist > ANIMAL.MaxDistance then
                        hideAll()
                    else
                        local sMinX, sMinY = math.huge, math.huge
                        local sMaxX, sMaxY = -math.huge, -math.huge
                        local anyOn = false
                        local cornersV = {
                            Vector3.new(mnX, mnY, mnZ),
                            Vector3.new(mxX, mnY, mnZ),
                            Vector3.new(mxX, mnY, mxZ),
                            Vector3.new(mnX, mnY, mxZ),
                            Vector3.new(mnX, mxY, mnZ),
                            Vector3.new(mxX, mxY, mnZ),
                            Vector3.new(mxX, mxY, mxZ),
                            Vector3.new(mnX, mxY, mxZ),
                        }
                        for i = 1, 8 do
                            local screenPos, onScreen = WorldToScreen(cornersV[i])
                            if screenPos and onScreen then
                                anyOn = true
                                if screenPos.X < sMinX then sMinX = screenPos.X end
                                if screenPos.Y < sMinY then sMinY = screenPos.Y end
                                if screenPos.X > sMaxX then sMaxX = screenPos.X end
                                if screenPos.Y > sMaxY then sMaxY = screenPos.Y end
                            end
                        end

                        if not anyOn then
                            hideAll()
                        else
                            local tl = Vector2.new(sMinX, sMinY)
                            local tr = Vector2.new(sMaxX, sMinY)
                            local br = Vector2.new(sMaxX, sMaxY)
                            local bl = Vector2.new(sMinX, sMaxY)
                            data.wireLines[1].From = tl; data.wireLines[1].To = tr; data.wireLines[1].Visible = true
                            data.wireLines[2].From = tr; data.wireLines[2].To = br; data.wireLines[2].Visible = true
                            data.wireLines[3].From = br; data.wireLines[3].To = bl; data.wireLines[3].Visible = true
                            data.wireLines[4].From = bl; data.wireLines[4].To = tl; data.wireLines[4].Visible = true

                            local midX = (sMinX + sMaxX) / 2
                            data.nameTag.Position = Vector2.new(midX, sMinY - 18)
                            data.nameTag.Text = data.animalType
                            data.nameTag.Visible = true
                        end
                    end
                end
            end
        end
    end
end

local function animalCleanup()
    for id, data in pairs(ANIMAL.Objects) do
        local model = data.model
        if not model or not model.Parent then
            for _, ln in ipairs(data.wireLines) do ln:Remove() end
            data.nameTag:Remove()
            ANIMAL.Objects[id] = nil
        end
    end
end

