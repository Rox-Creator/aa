-- DAMAGE INDICATOR ENGINE
-- ============================================================

local function DmgIndicatorLoop()
    local playerCache = nil
    local playerCacheTimer = 999
    local healthSrcCache = {}  -- [playerName] = { child = instance|false, expires = tick }
    while GUI.Running do
        if not GUI.DmgIndicatorEnabled then
            -- Idle: clean up and wait
            if #GUI.DmgIndicatorFloaters > 0 then
                for _, f in ipairs(GUI.DmgIndicatorFloaters) do
                    for _, el in ipairs(f.elements) do
                        pcall(function() el:Remove() end)
                    end
                end
                GUI.DmgIndicatorFloaters = {}
            end
            GUI.DmgIndicatorPrevHP = {}
            playerCache = nil
            playerCacheTimer = 999
            healthSrcCache = {}
            wait(0.5)
        else
            local ok, err = pcall(function()
                -- Get my position (same pattern as ESP code)
                local playerPos = getPlayerPos()
                if not playerPos then return end
                local radius = GUI.DmgIndicatorRadius

                -- Refresh player list every ~1s instead of every 30ms tick
                playerCacheTimer = playerCacheTimer + 1
                if not playerCache or playerCacheTimer >= 33 then
                    playerCache = Players:GetPlayers()
                    playerCacheTimer = 0
                    -- Drop stale Health child refs for players no longer present
                    local alive = {}
                    for _, p in pairs(playerCache) do
                        pcall(function() alive[p.Name] = true end)
                    end
                    for n, _ in pairs(healthSrcCache) do
                        if not alive[n] then healthSrcCache[n] = nil end
                    end
                end

                local now = tick()
                for _, player in pairs(playerCache) do
                    pcall(function()
                        if player == LocalPlayer or player.Name == LocalPlayer.Name then return end
                        local name = player.Name

                        -- Read health from attributes (nil = 100, same as playerlist)
                        local hp = 100
                        pcall(function()
                            local h = player:GetAttribute("Health")
                            if h then hp = tonumber(h) or 100 end
                        end)

                        -- Resolve "Health" child once per second per player; reuse the ref every tick
                        local hsc = healthSrcCache[name]
                        if not hsc or now > hsc.expires then
                            local found = false
                            pcall(function()
                                for _, child in pairs(player:GetChildren()) do
                                    if child.Name == "Health" then found = child; break end
                                end
                            end)
                            hsc = { child = found, expires = now + 1 }
                            healthSrcCache[name] = hsc
                        end
                        if hsc.child then
                            pcall(function()
                                local v = hsc.child.Value
                                if v then hp = tonumber(v) or hp end
                            end)
                        end

                        local prevHP = GUI.DmgIndicatorPrevHP[name]
                        GUI.DmgIndicatorPrevHP[name] = hp

                        -- Detect health drop
                        if prevHP and hp < prevHP then
                            local dmg = math.floor(prevHP - hp)
                            if dmg <= 0 then return end

                            -- Distance check using character HRP (same pattern as ESP)
                            local char = nil
                            pcall(function() char = player.Character end)
                            if not char then return end
                            local hrp = char:FindFirstChild("HumanoidRootPart")
                            if not hrp then return end

                            local pos = hrp.Position
                            local dx = playerPos.X - pos.X
                            local dy = playerPos.Y - pos.Y
                            local dz = playerPos.Z - pos.Z
                            local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

                            if dist > radius then return end


                            -- Get screen position
                            local screenPos, onScreen = WorldToScreen(pos + Vector3.new(0, 3, 0))
                            if not screenPos or not onScreen then return end

                            local isKill = hp <= 0

                            -- Stack offset: count active floaters to push new ones up
                            local stackOffset = #GUI.DmgIndicatorFloaters * 80

                            -- Clamp to screen bounds (leave margin for text)
                            local cx = math.max(120, math.min(screenPos.X, 2560 - 120))
                            local baseY = math.max(30, math.min(screenPos.Y - 50 - stackOffset, 1440 - 100))
                            local nameY = baseY
                            local lineY = baseY + 26
                            local dmgY = baseY + 40
                            local killY = baseY + 62

                            -- Player name (slides from right)
                            local nameText = Drawing.new("Text")
                            nameText.Position = Vector2.new(cx + 200, nameY)
                            nameText.Text = name
                            nameText.Color = Color3.fromRGB(255, 255, 255)
                            nameText.Size = 23
                            nameText.Font = Drawing.Fonts.SystemBold
                            nameText.Center = true
                            nameText.Outline = true
                            nameText.Visible = true
                            nameText.ZIndex = 58

                            -- Separator line
                            local sepLine = Drawing.new("Line")
                            sepLine.From = Vector2.new(cx - 80, lineY)
                            sepLine.To = Vector2.new(cx + 80, lineY)
                            sepLine.Color = Color3.fromRGB(220, 75, 75)
                            sepLine.Thickness = 1
                            sepLine.Visible = true
                            sepLine.ZIndex = 58

                            -- "X Damage Dealt" on one line (number red, text white)
                            local dmgText = Drawing.new("Text")
                            dmgText.Position = Vector2.new(cx - 200, dmgY)
                            dmgText.Text = tostring(dmg) .. " Damage Dealt"
                            dmgText.Color = Color3.fromRGB(220, 75, 75)
                            dmgText.Size = 18
                            dmgText.Font = Drawing.Fonts.System
                            dmgText.Center = true
                            dmgText.Outline = true
                            dmgText.Visible = true
                            dmgText.ZIndex = 58

                            -- Kill text
                            local killText = nil
                            if isKill then
                                killText = Drawing.new("Text")
                                killText.Position = Vector2.new(cx, killY)
                                killText.Text = "KILLED"
                                killText.Color = Color3.fromRGB(255, 60, 60)
                                killText.Size = 18
                                killText.Font = Drawing.Fonts.SystemBold
                                killText.Center = true
                                killText.Outline = true
                                killText.Visible = true
                                killText.ZIndex = 58
                            end

                            local floater = {
                                created = tick(),
                                cx = cx,
                                nameY = nameY,
                                dmgY = dmgY,
                                nameText = nameText,
                                sepLine = sepLine,
                                dmgText = dmgText,
                                killText = killText,
                                elements = {nameText, sepLine, dmgText},
                            }
                            if killText then table.insert(floater.elements, killText) end

                            table.insert(GUI.DmgIndicatorFloaters, floater)
                        end
                    end)
                end

                -- Animate and clean up floaters
                local now = tick()
                local alive = {}
                for _, f in ipairs(GUI.DmgIndicatorFloaters) do
                    local age = now - f.created
                    if age < 2.5 then
                        -- Slide animation (first 0.3s)
                        local slideT = math.min(1, age / 0.3)
                        local ease = 1 - (1 - slideT) * (1 - slideT) * (1 - slideT)

                        -- Name slides from right to center
                        local nameX = f.cx + 200 * (1 - ease)
                        pcall(function()
                            f.nameText.Position = Vector2.new(nameX, f.nameY)
                        end)

                        -- Damage slides from left to center
                        local dmgX = f.cx - 200 * (1 - ease)
                        pcall(function()
                            f.dmgText.Position = Vector2.new(dmgX, f.dmgY)
                        end)

                        -- Fade out last 0.6s
                        if age > 1.9 then
                            local alpha = (age - 1.9) / 0.6
                            for _, el in ipairs(f.elements) do
                                pcall(function() el.Transparency = alpha end)
                            end
                        end

                        table.insert(alive, f)
                    else
                        for _, el in ipairs(f.elements) do
                            pcall(function() el:Remove() end)
                        end
                    end
                end
                GUI.DmgIndicatorFloaters = alive
            end)
            wait(0.03)
        end
    end
end

