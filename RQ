    }
end

local function espScan()
    for _, obj in pairs(Workspace:GetChildren()) do
        espRegisterObj(obj)
    end
end

local function espUpdate()
    if not anyOreEnabled() then
        for _, data in pairs(ESP.Objects) do
            data.label.Visible = false
        end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end

    for id, data in pairs(ESP.Objects) do
        local mineral = data.mineral
        if not mineral or not mineral.Parent then
            data.label.Visible = false
        else
            local enabled = false
            for _, ore in ipairs(ORE_LIST) do
                if ore.Name == data.oreName then
                    enabled = ore.Enabled
                    break
                end
            end

            if not enabled then
                data.label.Visible = false
            else
                local pos = mineral.Position
                if not pos then
                    data.label.Visible = false
                else
                    local dx = playerPos.X - pos.X
                    local dy = playerPos.Y - pos.Y
                    local dz = playerPos.Z - pos.Z
                    local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

                    if dist > ESP.MaxDistance then
                        data.label.Visible = false
                    else
                        local screenPos, onScreen = WorldToScreen(pos)
                        if onScreen and screenPos then
                            local fd = math.floor(dist)
                            if data.lastDist ~= fd then
                                data.label.Text = data.oreName .. " [" .. fd .. "m]"
                                data.lastDist = fd
                            end
                            data.label.Position = Vector2.new(screenPos.X, screenPos.Y)
                            data.label.Visible = true
                        else
                            data.label.Visible = false
                        end
                    end
                end
            end
        end
    end
end

local function espCleanup()
    for id, data in pairs(ESP.Objects) do
        local mineral = data.mineral
        if not mineral or not mineral.Parent then
            data.label:Remove()
            ESP.Objects[id] = nil
        end
    end
