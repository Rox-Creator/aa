local function CloseDropdown()
    for _, el in ipairs(GUI.DropdownElements) do
        pcall(function() el:Remove() end)
    end
    GUI.DropdownElements = {}
    GUI.DropdownClickables = {}
    GUI.DropdownOpen = false
end

local function ClearSubTabs()
    for _, el in ipairs(GUI.SubTabElements) do
        pcall(function() el:Remove() end)
    end
    GUI.SubTabElements = {}
    GUI.SubTabClickables = {}
end

local function ClearContent()
    CloseDropdown()
    -- Invalidate any in-flight content animations so their delayed task.spawn
    -- callbacks don't poke at Drawing objects we've already :Remove()'d.
    newAnimToken()
    -- pcall each Remove individually — if one fails the loop keeps going
    -- so we don't leak the rest of the elements (that was causing stale
    -- card underlines to stack up across rebuilds).
    for _, el in ipairs(GUI.ContentElements) do
        pcall(function() el:Remove() end)
    end
    GUI.ContentElements = {}
    GUI.Clickables = {}
    GUI.SliderDragging = nil
end


