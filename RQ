    -- Each pin edits client-side config constants exactly like the proven standalone
    -- requiem_*.lua scripts: getgc(key) -> keep only the real numeric entry (an accept
    -- range filters out the hash-sized decoys) -> applygc(entries, key, value). The
    -- pre-change value is captured the first time a key is touched, so "Reset Default"
    -- restores YOUR original value (not a hard-coded guess). Self-contained: all state
    -- and helpers live inside this tab's scope.
    tabBuild(function()
        local tab = window:Tab("Character", "sword")

        -- key -> { lo, hi = accept range (excludes hash decoys, spans every slider value), fb = default }
        local CFG = {
            ERADICATE_CHAIN_MAX_KILLS   = { lo = 2, hi = 50,    fb = 3    },
            ERADICATE_CHAIN_LOCKOUT_SEC = { lo = 1, hi = 200,   fb = 120  },
            GearGrappleRangeMultiplier  = { lo = 0, hi = 1000,  fb = 1    },
            GearAdditionalGrappleRange  = { lo = 0, hi = 20000, fb = 0    },
            GearMaxVelocityMultiplier   = { lo = 0, hi = 100,   fb = 1.11 },
            GearVelocityIncreaseRate    = { lo = 0, hi = 100,   fb = 1.75 },
            GearVelocityDecayRate       = { lo = 0, hi = 100,   fb = 1.1  },
        }
        local savedDefault = {}   -- your value BEFORE the first change (for Reset Default)

        local function notif(t, m, d) pcall(notify, t, m, d or 3) end

        -- getgc(key) -> keep only the real numeric config entry(ies)
        local function collect(key)
            local cfg = CFG[key]; if not cfg then return {}, nil end
            local ok, entries = pcall(function() return getgc(key) end)
            if not ok or type(entries) ~= "table" then return {}, nil end
            local safe = {}
            for _, e in pairs(entries) do
                if type(e) == "table" and e.key == key and e.type == "number" then
                    local v = tonumber(e.value)
                    if v and v >= cfg.lo and v <= cfg.hi then safe[#safe + 1] = e end
                end
            end
            return safe, (safe[1] and tonumber(safe[1].value)) or nil
        end

        -- write `value` to `key`; capture the pre-change value the first time we touch it
        local function apply(key, value)
            if type(getgc) ~= "function" or type(applygc) ~= "function" then return false end
            local safe, cur = collect(key)
            if #safe == 0 then return false end
            if savedDefault[key] == nil then savedDefault[key] = cur end
            return (pcall(function() applygc(safe, key, value) end))
        end

        local function reset(key)
            if savedDefault[key] ~= nil then return apply(key, savedDefault[key]) end
            local _, cur = collect(key)               -- never changed: current IS your default
            savedDefault[key] = cur or CFG[key].fb
            return true
        end

        local function applyMany(title, keys, vals)
            local okAll = true
            for i, k in ipairs(keys) do if not apply(k, vals[i]) then okAll = false end end
            if okAll then notif(title, "Applied", 3) else notif(title, "Failed - join a round first", 4) end
        end
        local function resetMany(title, keys)
            for _, k in ipairs(keys) do reset(k) end
            notif(title, "Restored your defaults", 3)
        end

        -- ---------- Eradicate (Sentinel chain capstone) ----------
        local secEr = tab:Section("Eradicate", "Left", "Chain kills / lockout")
        local erKills, erLock = CFG.ERADICATE_CHAIN_MAX_KILLS.fb, CFG.ERADICATE_CHAIN_LOCKOUT_SEC.fb
        secEr:Slider("Chain Max Kills", erKills, 1, 2, 50, "", function(v) erKills = math.floor(tonumber(v) or erKills) end)
        secEr:Slider("Chain Lockout", erLock, 1, 1, 200, "s", function(v) erLock = math.floor(tonumber(v) or erLock) end)
        secEr:Button("Apply Eradicate", function()
            applyMany("Eradicate", { "ERADICATE_CHAIN_MAX_KILLS", "ERADICATE_CHAIN_LOCKOUT_SEC" }, { erKills, erLock })
        end)
        secEr:Button("Reset Default", function()
            resetMany("Eradicate", { "ERADICATE_CHAIN_MAX_KILLS", "ERADICATE_CHAIN_LOCKOUT_SEC" })
        end)

        -- ---------- Grapple (ODM hook range) ----------
        local secGr = tab:Section("Grapple", "Left", "ODM hook range")
        local grMult, grAdd = CFG.GearGrappleRangeMultiplier.fb, CFG.GearAdditionalGrappleRange.fb
        secGr:Slider("Range Multiplier", grMult, 0.5, 1, 25, "x", function(v) grMult = tonumber(v) or grMult end)
        secGr:Slider("Additional Range", grAdd, 50, 0, 5000, "", function(v) grAdd = math.floor(tonumber(v) or grAdd) end)
        secGr:Label(function()
            return string.format("Est. hook range  ~%d studs  (stock 400)", math.floor((grAdd + 400) * grMult + 0.5))
        end)
        secGr:Button("Apply Grapple", function()
            applyMany("Grapple", { "GearGrappleRangeMultiplier", "GearAdditionalGrappleRange" }, { grMult, grAdd })
        end)
        secGr:Button("Reset Default", function()
            resetMany("Grapple", { "GearGrappleRangeMultiplier", "GearAdditionalGrappleRange" })
        end)

        -- ---------- Velocity (ODM speed build-up) ----------
        local secVe = tab:Section("Velocity", "Right", "ODM speed build-up")
        local veMax, veInc, veDec = CFG.GearMaxVelocityMultiplier.fb, CFG.GearVelocityIncreaseRate.fb, CFG.GearVelocityDecayRate.fb
        secVe:Slider("Max Velocity", veMax, 0.01, 0.5, 3, "x", function(v) veMax = tonumber(v) or veMax end)
        secVe:Slider("Increase Rate", veInc, 0.05, 0.5, 5, "x", function(v) veInc = tonumber(v) or veInc end)
        secVe:Slider("Decay Rate", veDec, 0.05, 0, 3, "x", function(v) veDec = tonumber(v) or veDec end)
        secVe:Button("Apply Velocity", function()
            applyMany("Velocity", { "GearMaxVelocityMultiplier", "GearVelocityIncreaseRate", "GearVelocityDecayRate" }, { veMax, veInc, veDec })
        end)
        secVe:Button("Reset Default", function()
            resetMany("Velocity", { "GearMaxVelocityMultiplier", "GearVelocityIncreaseRate", "GearVelocityDecayRate" })
        end)

        -- ---------- Velocity indicator (live) ----------
        -- Live speed from HumanoidRootPart position-delta (robust; Matcha doesn't reliably
        -- expose AssemblyLinearVelocity). Shows your projected top-speed gain vs default.
        local VEL = { speed = 0, peak = 0, lastPos = nil, lastT = 0 }
        task.spawn(function()
            while GUI.Running do
                pcall(function()
                    local ch = LocalPlayer and LocalPlayer.Character
                    local hrp = ch and (ch:FindFirstChild("HumanoidRootPart") or ch:FindFirstChild("Torso") or ch.PrimaryPart)
                    if hrp then
                        local p, now = hrp.Position, os.clock()
                        if VEL.lastPos then
                            local dt = now - VEL.lastT
                            if dt > 0.0001 then
                                local s = (p - VEL.lastPos).Magnitude / dt
                                if s < 8000 then   -- ignore teleport spikes
                                    VEL.speed = VEL.speed + (s - VEL.speed) * 0.4
                                    if VEL.speed > VEL.peak then VEL.peak = VEL.speed end
                                end
                            end
                        end
                        VEL.lastPos, VEL.lastT = p, now
                    else
                        VEL.lastPos = nil
                    end
                end)
                task.wait(0.1)
            end
        end)

        local secInd = tab:Section("Velocity Indicator", "Right", "How much more speed you'll gain")
        secInd:Label(function()
            local base = savedDefault.GearMaxVelocityMultiplier or CFG.GearMaxVelocityMultiplier.fb
            local gain = (base > 0) and ((veMax / base - 1) * 100) or 0
            return string.format("Top-speed cap  x%.2f   (%+d%% vs default x%.2f)", veMax, math.floor(gain + 0.5), base)
        end)
        secInd:Label(function()
            return string.format("Live speed  %d studs/s      Peak  %d", math.floor(VEL.speed + 0.5), math.floor(VEL.peak + 0.5))
        end)
        secInd:Button("Reset Peak", function() VEL.peak = 0 end)
    end)

    -- ===== Tab: Logs =====
    tabBuild(function()
        local tab = window:Tab("Logs", "skull")
        local sec = tab:Section("Death Log Webhook", "Left", "Discord death feed")
        sec:Toggle("Enable Death Log", DEATHLOG.Enabled, function(v)
            DEATHLOG.Enabled = v
            if v then
                -- Re-seed so deaths already on the ground don't spam the webhook.
                DEATHLOG.Seeded = false; DEATHLOG.NextPollAt = 0; DEATHLOG.Pending = {}
            else
                DEATHLOG.Pending = {}
            end
        end)
        sec:Button("Fetch Current Ragdolls", function()
            local sentNow = deathFetchAllNow()
            notify("Death Log", "Fetched " .. tostring(sentNow) .. " ragdoll(s) to webhook", 3)
        end)
        pcall(function()
            sec:Label(function()
                if not DEATHLOG.Enabled then return "Status:  Inactive" end
                if DEATHLOG.Seeded then return "Status:  Active   (sent " .. tostring(DEATHLOG.SentCount) .. ")" end
                return "Status:  Seeding existing ragdolls..."
            end)
        end)
    end)

    -- ===== Settings tab (built-in) =====
    tabBuild(function()
        local setTab = window:AddSettingsTab("cog")

        local secCfg = setTab:Section("Config", "Left", "Save / load / reset")
        secCfg:Button("Save Config", function()
            pcall(saveConfig); notify("Config", "Saved to " .. CONFIG_PATH, 2)
        end)
        secCfg:Button("Load Config", function()
            pcall(loadConfig); notify("Config", "Loaded — reload script to refresh the menu", 4)
        end)
        secCfg:Button("Reset Config", function()
            pcall(resetConfigToDefaults); notify("Config", "Reset — reload script to refresh the menu", 4)
        end):SetRisk()

        -- Appearance: Requiem owns the accent + opacity (the lib doesn't expose its
        -- live theme), and the driver above pushes them to BOTH the menu and the popups.
        local secLook = setTab:Section("Appearance", "Left", "Applies to menu + popups")
        secLook:Toggle("Rainbow", RUITHEME.rainbow, function(v) RUITHEME.rainbow = v end)
        secLook:Slider("Rainbow Speed", math.floor((RUITHEME.rainbowSpeed or 0.35) * 100), 1, 5, 150, "", function(v) RUITHEME.rainbowSpeed = (tonumber(v) or 35) / 100 end)
        pcall(function() secLook:Colorpicker("Accent", RUITHEME.baseAccent, function(c) RUITHEME.baseAccent = c; RUITHEME.baseAccentB = c end) end)
        secLook:Slider("Opacity", math.floor((RUITHEME.opacity or 1) * 100), 1, 30, 100, "%", function(v) RUITHEME.opacity = (tonumber(v) or 100) / 100 end)

        local secAbout = setTab:Section("About", "Right", "Requiem")
        pcall(function() secAbout:Label(function() return "Menu key:   F3" end) end)
        pcall(function() secAbout:Label(function() return "Unload:   " .. GetKeyName(GUI.CloseKey) end) end)
        pcall(function() secAbout:Label(function() return "Player ESP:   " .. GetKeyName(GUI.PlayerEspKey) end) end)
        pcall(function() secAbout:Label(function() return "Player List:   " .. GetKeyName(GUI.PlayerListKey) end) end)
    end)

    notify("Requiem", "Loaded  -  F3 menu  -  " .. GetKeyName(GUI.CloseKey) .. " unload", 4)
    print("[Requiem] loaded with INS-ui front-end")
end)()

