-- Read a player's health and max-health by name. Returns (hp, maxHp).
-- Defaults: hp=100, maxHp=100. Tries attributes/NumberValues first, then Humanoid.
local function ReadPlayerHealth(playerName)
    local hp = 100
    local maxHp = 100
    local sawMax = false
    pcall(function()
        local p = game:GetService("Players"):FindFirstChild(playerName)
        if p then
            pcall(function()
                local h = p:GetAttribute("Health")
                if h then hp = tonumber(h) or hp end
                local m = p:GetAttribute("Maximum health")
                if not m then m = p:GetAttribute("MaxHealth") end
                if not m then m = p:GetAttribute("MaximumHealth") end
                if m then maxHp = tonumber(m) or maxHp; sawMax = true end
            end)
            pcall(function()
                for _, child in pairs(p:GetChildren()) do
                    if child.Name == "Health" then
                        hp = tonumber(child.Value) or hp
                    elseif child.Name == "MaxHealth" or child.Name == "Maximum health" or child.Name == "MaximumHealth" then
                        maxHp = tonumber(child.Value) or maxHp
                        sawMax = true
                    end
                end
            end)
            if not sawMax then
                pcall(function()
                    local char = p.Character
                    if char then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then
                            local m = tonumber(hum.MaxHealth)
                            if m and m > 0 then maxHp = m; sawMax = true end
                            -- Humanoid.Health is authoritative when present
                            local h = tonumber(hum.Health)
                            if h then hp = h end
                        end
                    end
                end)
            end
        end
    end)
    -- If we never found a max, assume max is at least the current hp (so a
    -- buffed player at 145 still reads as 100% instead of being stuck).
    if not sawMax then maxHp = math.max(100, hp) end
    if maxHp <= 0 then maxHp = 100 end
    if hp < 0 then hp = 0 end
    if hp > maxHp then hp = maxHp end
    return hp, maxHp
end

-- Generic health bar drawing (reused for self and monitors)
local function DrawHealthBarWidget(px, py, pw, ph, playerName, hp, maxHp, zb, elemTable)
    maxHp = (maxHp and maxHp > 0) and maxHp or 100
    local hpFrac = math.max(0, math.min(1, hp / maxHp))
    local pctNum = math.floor(hpFrac * 100 + 0.5)
    local hpColor = GetHealthColor(pctNum)
    local C3c = Color3.fromRGB
    local function add(o) o.Visible = true; table.insert(elemTable, o); return o end
    local function sq(x, y, w, h, col, z, a, cn, fl, th)
        local s = Drawing.new("Square"); s.Position = Vector2.new(x, y); s.Size = Vector2.new(w, h)
        s.Color = col; s.Filled = fl ~= false; s.Corner = cn or 0; if th then s.Thickness = th end
        s.Transparency = a or 1; s.ZIndex = z; return add(s)
    end
    local function tx(str, x, y, sz, col, z, font)
        local t = Drawing.new("Text"); t.Position = Vector2.new(x, y); t.Text = tostring(str)
        t.Size = sz; t.Color = col; t.Font = font or Drawing.Fonts.System; t.Center = false
        t.Outline = false; t.ZIndex = z; return add(t)
    end
    -- drop shadow, rounded body, hairline edge
    sq(px + 4, py + 6, pw, ph, C3c(0, 0, 0), zb - 1, 0.16, 8)
    sq(px, py, pw, ph, C3c(15, 15, 19), zb, 0.93, 8)
    sq(px, py, pw, ph, C3c(255, 255, 255), zb + 1, 0.10, 8, false, 1)
    -- health-coloured accent strip on the left edge
    sq(px, py + 7, 3, ph - 14, hpColor, zb + 2, 0.9, 2)
    -- name
    tx(playerName, px + 14, py + 7, 15, C3c(228, 228, 234), zb + 4, Drawing.Fonts.SystemBold)
    -- percent + hp numbers, right-aligned
    local pctStr = tostring(pctNum) .. "%"
    tx(pctStr, px + pw - 12 - #pctStr * 8, py + 7, 14, hpColor, zb + 4, Drawing.Fonts.SystemBold)
    local hpStr = math.floor(hp + 0.5) .. " / " .. math.floor(maxHp + 0.5)
    tx(hpStr, px + pw - 18 - #pctStr * 8 - #hpStr * 7, py + 8, 12, C3c(150, 150, 158), zb + 4, Drawing.Fonts.Monospace)
    -- bar: taller, rounded, with a subtle top highlight
    local barX, barY, barW, barH = px + 14, py + ph - 13, pw - 28, 8
    sq(barX, barY, barW, barH, C3c(30, 30, 36), zb + 2, 0.9, 3)
    local fw = math.max(3, math.floor(barW * hpFrac))
    sq(barX, barY, fw, barH, hpColor, zb + 3, 0.96, 3)
    sq(barX + 1, barY + 1, math.max(1, fw - 2), 2, C3c(255, 255, 255), zb + 4, 0.22, 2)
end

