-- Returns min/max scalars (or nil) so the caller can do a distance check before
-- allocating Vector3 corners — saves 8 Vector3 allocs/titan/frame when off-screen.
local function getTitanAABB(partMap)
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
    local count = 0
    for _, part in pairs(partMap) do
        if part and part.Parent then
            pcall(function()
                local pos = part.Position
                local size = part.Size
                if pos and size then
                    local hx, hy, hz = size.X / 2, size.Y / 2, size.Z / 2
                    if pos.X - hx < minX then minX = pos.X - hx end
                    if pos.Y - hy < minY then minY = pos.Y - hy end
                    if pos.Z - hz < minZ then minZ = pos.Z - hz end
                    if pos.X + hx > maxX then maxX = pos.X + hx end
                    if pos.Y + hy > maxY then maxY = pos.Y + hy end
                    if pos.Z + hz > maxZ then maxZ = pos.Z + hz end
                    count = count + 1
                end
            end)
        end
    end
    if count == 0 then return nil end
    return minX, minY, minZ, maxX, maxY, maxZ
end

