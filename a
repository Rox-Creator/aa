local function ClearContent()
    CloseDropdown()
    -- Invalidate any in-flight content animations so their delayed task.spawn
    -- callbacks don't poke at Drawing objects we've already :Remove()'d.
    newAnimToken()
    -- pcall each Remove individually — if one fails the loop keeps going
    -- so we don't leak the rest of the elements (that was causing stale
    -- card underlines to stack up across rebuilds).
    for _, el in ipairs(GUI.ContentElements) do
        pcall(function() el:Remove() end)
    end
    GUI.ContentElements = {}
    GUI.Clickables = {}
    GUI.SliderDragging = nil
end

-- Tactile press feedback — shrink the element by 2px and offset
-- by +1,+1 for one frame, then restore. Matches AOTR's pressEffect
-- pattern, much more "clicky" than a color flash.
local function pressEffect(el)
    if not el then return end
    local gen = GUI.AnimToken
    task.spawn(function()
        if GUI.AnimToken ~= gen then return end
        local okP, pos = pcall(function() return el.Position end)
        local okS, sz  = pcall(function() return el.Size end)
        if not (okP and pos and okS and sz) then return end
        pcall(function()
            el.Position = Vector2.new(pos.X + 1, pos.Y + 1)
            el.Size     = Vector2.new(sz.X - 2, sz.Y - 2)
        end)
        task.wait(0.07)
        if GUI.AnimToken ~= gen then return end
        pcall(function() el.Position = pos; el.Size = sz end)
    end)
end

-- Smooth toggle animation — slides the knob along its travel and
-- lerps the bg color over 8 steps with cubic ease-out, then fires
-- the user onClick on completion. Matches AOTR's animateToggle.
animateToggle = function(knob, bg, fromX, toX, fromColor, toColor, knobY, onDone)
    local gen = GUI.AnimToken
    task.spawn(function()
        -- 16 steps × 0.016 = 256ms with cubic ease-out. Long enough to
        -- read as smooth, short enough that a rapid double-tap doesn't
        -- feel laggy.
        local steps, stepTime = 16, 0.016
        for i = 1, steps do
            if GUI.AnimToken ~= gen then break end
            local t = i / steps
            local et = 1 - (1 - t) ^ 3
            pcall(function()
                knob.Position = Vector2.new(fromX + (toX - fromX) * et, knobY)
                bg.Color      = lerpColor(fromColor, toColor, et)
            end)
            task.wait(stepTime)
        end
        if onDone then pcall(onDone) end
    end)
end

