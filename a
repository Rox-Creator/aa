    local closeX = px + pw - 30
    local closeY = py + 6
    local closeText = Drawing.new("Text")
    closeText.Position = Vector2.new(closeX + 6, closeY + 2); closeText.Text = "X"
    closeText.Color = Colors.AccentRed; closeText.Size = 17
    closeText.Font = Drawing.Fonts.SystemBold; closeText.Center = false
    closeText.Outline = false; closeText.Visible = true; closeText.ZIndex = zb + 3
    table.insert(GUI.RSDiffElements, closeText)
    table.insert(GUI.RSDiffClickables, {
        x = closeX, y = closeY, w = 24, h = 24,
        onClick = function()
            GUI.RSDiffOpen = false
            ClearRSDiffPanel()
            CreateContent(GUI.SelectedPage)
        end
    })

    -- Action button row: Snapshot + Compare + Load Saved + Clear.
    -- Per-button width keeps the row compact enough to leave space
    -- for the legend on the right.
    local actionY = py + headerH + 4
    local btnH = 30
    local btnGap = 10
    local actionX = px + 14
    local function actionBtn(label, color, onClick, customW)
        local w = customW or 110
        local bgBtn = Drawing.new("Square")
        bgBtn.Position = Vector2.new(actionX, actionY)
        bgBtn.Size = Vector2.new(w, btnH)
        bgBtn.Color = color; bgBtn.Filled = true
        bgBtn.Corner = 4; bgBtn.Visible = true; bgBtn.ZIndex = zb + 3
        table.insert(GUI.RSDiffElements, bgBtn)

        local txt = Drawing.new("Text")
        txt.Position = Vector2.new(actionX + w / 2, actionY + (btnH - 14) / 1.3 + 0.5)
        txt.Text = label; txt.Color = Color3.fromRGB(20, 20, 24)
        txt.Size = 14; txt.Font = Drawing.Fonts.SystemBold
        txt.Center = true; txt.Outline = false
        txt.Visible = true; txt.ZIndex = zb + 4
        table.insert(GUI.RSDiffElements, txt)

        table.insert(GUI.RSDiffClickables, {
            x = actionX, y = actionY, w = w, h = btnH, onClick = onClick,
        })
        actionX = actionX + w + btnGap
    end

    -- Snapshot button states:
    --   no snapshot yet  → "Snapshot"   (neutral white)
    --   snapshot exists  → "Overwrite"  (neutral white)
    --   confirm armed    → "Overwrite?" (danger red), 3s window
    -- Two-click confirm prevents accidentally clobbering an existing
    -- on-disk snapshot. After commit the snapshot is JSON-encoded
    -- and persisted to RS_SNAPSHOT_PATH so it survives restarts.
    local hasSnap    = GUI.RSSnapshot ~= nil
    local confirming = GUI.RSOverwriteConfirmAt and (tick() - GUI.RSOverwriteConfirmAt < 3)
    local snapLabel, snapColor
    if confirming then
        snapLabel = "Overwrite?"
        snapColor = Color3.fromRGB(220, 100, 100)
    elseif hasSnap then
        snapLabel = "Overwrite"
        snapColor = Color3.fromRGB(200, 200, 210)
    else
        snapLabel = "Snapshot"
        snapColor = Color3.fromRGB(200, 200, 210)
    end
    actionBtn(snapLabel, snapColor, function()
        -- First click on an existing snapshot just arms the confirm
        -- timer; user has to click again within 3s to commit. Fresh
        -- snapshots (no on-disk file) skip the confirm step.
        if hasSnap and not confirming then
            GUI.RSOverwriteConfirmAt = tick()
            GUI.RSDiffStatus = "Click again within 3s to overwrite."
            BuildRSDiffPanel()
            return
        end
        GUI.RSOverwriteConfirmAt = nil
        GUI.RSDiffStatus = "Snapshotting..."
        BuildRSDiffPanel()
        task.spawn(function()
            local snap, count = TakeRSSnapshot()
            GUI.RSSnapshot = snap
            GUI.RSSnapshotCount = count
            local okT, t = pcall(os.time)
            GUI.RSSnapshotAt = okT and t or nil
            GUI.RSDiffResults = nil
            GUI.RSDiffScrollOffset = 0
            local ok, err = saveRSSnapshot()
            if ok then
                GUI.RSDiffStatus = "Snapshot saved: " .. count .. " paths."
            else
                GUI.RSDiffStatus = "Captured " .. count .. " paths but save failed (" .. tostring(err) .. ")"
            end
            if GUI.RSDiffOpen then BuildRSDiffPanel() end
        end)
    end)

    actionBtn("Compare", Color3.fromRGB(120, 200, 255), function()
        if not GUI.RSSnapshot then
            GUI.RSDiffStatus = "No snapshot. Click 'Snapshot' first."
            BuildRSDiffPanel()
            return
        end
        GUI.RSDiffStatus = "Comparing..."
        BuildRSDiffPanel()
        task.spawn(function()
            local cur = TakeRSSnapshot()
            local res = CompareRSSnapshots(GUI.RSSnapshot, cur)
            GUI.RSDiffResults = res
            GUI.RSDiffScrollOffset = 0
            GUI.RSDiffStatus = #res .. " changes since snapshot."
            if GUI.RSDiffOpen then BuildRSDiffPanel() end
        end)
    end)

    -- Explicit load — pulls the on-disk snapshot into memory. Runs the
    -- decode on a background task so the UI thread isn't blocked even
    -- on a large file. Status updates surface success / failure.
    actionBtn("Load Saved", Color3.fromRGB(180, 200, 140), function()
        local exists = false
        pcall(function() exists = isfile and isfile(RS_SNAPSHOT_PATH) end)
        if not exists then
            GUI.RSDiffStatus = "No saved snapshot file on disk."
            BuildRSDiffPanel()
            return
        end
        GUI.RSDiffStatus = "Loading..."
        BuildRSDiffPanel()
        task.spawn(function()
            loadRSSnapshot()
            if GUI.RSSnapshot then
                GUI.RSDiffStatus = "Loaded " .. (GUI.RSSnapshotCount or 0) .. " paths from disk."
            else
                GUI.RSDiffStatus = "Load failed (see console)."
            end
            if GUI.RSDiffOpen then BuildRSDiffPanel() end
        end)
    end)

    -- Clear only wipes the on-screen diff list. The in-memory snapshot
    -- and the on-disk file are left alone so subsequent Compares still
    -- work without re-snapshotting.
    actionBtn("Clear", Color3.fromRGB(180, 100, 100), function()
        GUI.RSDiffResults      = nil
        GUI.RSDiffScrollOffset = 0
        GUI.RSDiffStatus       = ""
        BuildRSDiffPanel()
    end)

    -- Legend strip on the right (pulled in to make room for the 4-button row)
    local legend = Drawing.new("Text")
    legend.Position = Vector2.new(px + pw - 150, actionY + 9)
    legend.Text = "ADD  DEL  CLS"
    legend.Color = Colors.TextMuted; legend.Size = 12
    legend.Font = Drawing.Fonts.System; legend.Center = false
    legend.Outline = false; legend.Visible = true; legend.ZIndex = zb + 3
    table.insert(GUI.RSDiffElements, legend)

    -- Separator under action bar
    local sepY = actionY + btnH + 6
    local sep = Drawing.new("Line")
    sep.From = Vector2.new(px + 4, sepY); sep.To = Vector2.new(px + pw - 4, sepY)
    sep.Color = Color3.fromRGB(40, 40, 46); sep.Thickness = 1
    sep.Visible = true; sep.ZIndex = zb + 2
    table.insert(GUI.RSDiffElements, sep)

    -- Results list
    local listY = sepY + 8
    local listX = px + 14
    local listW = pw - 28 - 24    -- leave room for scrollbar
    local listH = ph - (listY - py) - 12

    local results = GUI.RSDiffResults
    if not results then
        local hint = Drawing.new("Text")
        hint.Position = Vector2.new(px + pw / 2, listY + listH / 2 - 8)
        hint.Text = GUI.RSSnapshot
            and "Snapshot stored. Click 'Compare' after the game changes ReplicatedStorage."
            or  "Click 'Snapshot' to record now, or 'Load Saved' to pull the last on-disk snapshot."
        hint.Color = Colors.TextMuted; hint.Size = 13
        hint.Font = Drawing.Fonts.System; hint.Center = true
        hint.Outline = false; hint.Visible = true; hint.ZIndex = zb + 3
        table.insert(GUI.RSDiffElements, hint)
    elseif #results == 0 then
        local hint = Drawing.new("Text")
        hint.Position = Vector2.new(px + pw / 2, listY + listH / 2 - 8)
        hint.Text = "No changes detected since last snapshot."
        hint.Color = Color3.fromRGB(80, 220, 100); hint.Size = 14
        hint.Font = Drawing.Fonts.SystemBold; hint.Center = true
        hint.Outline = false; hint.Visible = true; hint.ZIndex = zb + 3
        table.insert(GUI.RSDiffElements, hint)
    else
        local rowH = 18
        local maxRows = math.floor(listH / rowH)
        local total = #results
        local maxScroll = math.max(0, total - maxRows)
        GUI.RSDiffScrollOffset = math.max(0, math.min(GUI.RSDiffScrollOffset, maxScroll))
        local startIdx = GUI.RSDiffScrollOffset + 1
        local endIdx   = math.min(total, startIdx + maxRows - 1)

        for i = startIdx, endIdx do
            local r = results[i]
            local rowY = listY + (i - startIdx) * rowH
            local col = RS_DIFF_COLORS[r.kind] or Colors.TextPrimary

            -- Kind tag (fixed 4-char width)
            local kindTxt = Drawing.new("Text")
            kindTxt.Position = Vector2.new(listX, rowY)
            kindTxt.Text = string.format("%-4s", r.kind)
            kindTxt.Color = col; kindTxt.Size = 13
            kindTxt.Font = Drawing.Fonts.SystemBold; kindTxt.Center = false
            kindTxt.Outline = false; kindTxt.Visible = true; kindTxt.ZIndex = zb + 3
            table.insert(GUI.RSDiffElements, kindTxt)

            -- Path
            local pathTxt = Drawing.new("Text")
            pathTxt.Position = Vector2.new(listX + 44, rowY)
            pathTxt.Text = r.path
            pathTxt.Color = Colors.TextPrimary; pathTxt.Size = 12
            pathTxt.Font = Drawing.Fonts.System; pathTxt.Center = false
            pathTxt.Outline = false; pathTxt.Visible = true; pathTxt.ZIndex = zb + 3
            table.insert(GUI.RSDiffElements, pathTxt)

            -- Detail (right side, muted)
            if r.detail and r.detail ~= "" then
                local detTxt = Drawing.new("Text")
                local approxW = #r.detail * 6.5
                detTxt.Position = Vector2.new(listX + listW - approxW - 8, rowY)
                detTxt.Text = r.detail
                detTxt.Color = Colors.TextMuted; detTxt.Size = 11
                detTxt.Font = Drawing.Fonts.System; detTxt.Center = false
                detTxt.Outline = false; detTxt.Visible = true; detTxt.ZIndex = zb + 3
                table.insert(GUI.RSDiffElements, detTxt)
            end
        end

        -- Scrollbar (only if scrolling is needed)
        if maxScroll > 0 then
            local sbW = 8
            local sbX = px + pw - 18
            local trackH = listH
            local thumbH = math.max(24, trackH * maxRows / total)
            local thumbY = listY + (GUI.RSDiffScrollOffset / maxScroll) * (trackH - thumbH)

            local track = Drawing.new("Square")
            track.Position = Vector2.new(sbX, listY); track.Size = Vector2.new(sbW, trackH)
            track.Color = Color3.fromRGB(30, 30, 36); track.Filled = true
            track.Corner = 4; track.Visible = true; track.ZIndex = zb + 3
            table.insert(GUI.RSDiffElements, track)

            local thumb = Drawing.new("Square")
            thumb.Position = Vector2.new(sbX, thumbY); thumb.Size = Vector2.new(sbW, thumbH)
            thumb.Color = Colors.AccentRed; thumb.Filled = true
            thumb.Corner = 4; thumb.Visible = true; thumb.ZIndex = zb + 4
            table.insert(GUI.RSDiffElements, thumb)

            GUI._rsScrollTrack = {
                x = sbX - 6, y = listY, w = sbW + 12, h = trackH,
                thumbH = thumbH, maxScroll = maxScroll,
            }
        else
            GUI._rsScrollTrack = nil
        end
    end
end

