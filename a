-- Same scalar return as getTitanAABB — defer Vector3 alloc to the caller.
local function getAnimalAABB(partList)
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
    local count = 0
    for _, part in ipairs(partList) do
        if part and part.Parent then
            pcall(function()
                local pos = part.Position
                local size = part.Size
                if pos and size then
                    local hx, hy, hz = size.X / 2, size.Y / 2, size.Z / 2
                    if pos.X - hx < minX then minX = pos.X - hx end
                    if pos.Y - hy < minY then minY = pos.Y - hy end
                    if pos.Z - hz < minZ then minZ = pos.Z - hz end
                    if pos.X + hx > maxX then maxX = pos.X + hx end
                    if pos.Y + hy > maxY then maxY = pos.Y + hy end
                    if pos.Z + hz > maxZ then maxZ = pos.Z + hz end
                    count = count + 1
                end
            end)
        end
    end
    if count == 0 then return nil end
    return minX, minY, minZ, maxX, maxY, maxZ
end

local function animalRegisterObj(animalModel)
    pcall(function()
        if animalModel.ClassName ~= "Model" then return end
        local id = animalModel.Name
        if ANIMAL.Objects[id] then return end
        -- Find the largest sub-model (most parts) to avoid picking accessories like "Arrow"
        local subModel = nil
        local animalType = "Animal"
        local bestPartCount = 0
        for _, child in pairs(animalModel:GetChildren()) do
            pcall(function()
                if child.ClassName == "Model" then
                    local count = 0
                    for _, p in pairs(child:GetChildren()) do
                        pcall(function()
                            if p.Position and p.Size then count = count + 1 end
                        end)
                    end
                    if count > bestPartCount then
                        bestPartCount = count
                        subModel = child
                        animalType = child.Name
                    end
                end
            end)
        end
        -- Fallback: use the parent model name if the sub-model name looks like a projectile/accessory
        local skipNames = {Arrow = true, Projectile = true, Effect = true, Particle = true, Tool = true}
        if skipNames[animalType] then
            animalType = animalModel.Name or "Animal"
        end
        if not subModel then return end
        local partList = {}
        for _, child in pairs(subModel:GetChildren()) do
            pcall(function()
                if not ANIMAL_SKIP_PARTS[child.Name] and child.Position and child.Size then
                    table.insert(partList, child)
                end
            end)
        end
        if #partList < 2 then return end
        local wireLines = {}
        for i = 1, 4 do
            local ln = Drawing.new("Line")
            ln.Color = ANIMAL.ESPColor
            ln.Thickness = ANIMAL.LineThickness
            ln.Visible = false
            wireLines[i] = ln
        end
        local nameTag = Drawing.new("Text")
        nameTag.Color = ANIMAL.ESPColor
        nameTag.Size = 13
        nameTag.Font = TITAN_FONTS[ANIMAL.FontIndex].font
        nameTag.Center = true
        nameTag.Outline = true
        nameTag.Visible = false
        local refPart = partList[1]
        local refPos = nil
        pcall(function() refPos = refPart.Position end)
        ANIMAL.Objects[id] = {
            model = animalModel,
            partList = partList,
            wireLines = wireLines,
            nameTag = nameTag,
            animalType = animalType,
            refPart = refPart,
            lastPos = refPos,
            lastMoveTime = tick(),
            isDead = false,
        }
    end)
end

local function animalScan()
    local animalsFolder = Workspace:FindFirstChild("Animals")
    if not animalsFolder then return end
    for _, animalModel in ipairs(animalsFolder:GetChildren()) do
