-- Draw a card with title and red underline, returns Y for first content row
local function DrawCard(x, y, w, h, title, zbase)
    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(x, y)
    bg.Size = Vector2.new(w, h)
    bg.Color = Colors.CardBg
    bg.Filled = true
    bg.Corner = 5
    bg.Visible = true
    bg.ZIndex = zbase
    table.insert(GUI.ContentElements, bg)

    local border = Drawing.new("Square")
    border.Position = Vector2.new(x, y)
    border.Size = Vector2.new(w, h)
    border.Color = Colors.CardBorder
    border.Filled = false
    border.Corner = 5
    border.Thickness = 1
    border.Visible = true
    border.ZIndex = zbase + 1
    table.insert(GUI.ContentElements, border)

    if title and title ~= "" then
        local titleEl = Drawing.new("Text")
        titleEl.Position = Vector2.new(x + Config.CardPad, y + 10)
        titleEl.Text = title
        titleEl.Color = Colors.AccentRed
        titleEl.Size = 16
        titleEl.Font = Drawing.Fonts.SystemBold
        titleEl.Center = false
        titleEl.Outline = false
        titleEl.Visible = true
        titleEl.ZIndex = zbase + 3
        table.insert(GUI.ContentElements, titleEl)

        local underline = Drawing.new("Line")
        underline.From = Vector2.new(x + 1, y + 38)
        underline.To = Vector2.new(x + w - 1, y + 38)
        underline.Color = Colors.AccentRed
        underline.Thickness = 1
        underline.Visible = true
        underline.ZIndex = zbase + 3
        table.insert(GUI.ContentElements, underline)
    end

    return y + 52
end

-- Draw a toggle row inside a card
local function DrawCardToggleRow(cardX, cardW, curY, label, isOn, dotColor, zbase, onClick)
    local lx = cardX + Config.CardPad
    local rightEdge = cardX + cardW - Config.CardPad

    local lbl = Drawing.new("Text")
    lbl.Position = Vector2.new(lx, curY + 2)
    lbl.Text = label
    lbl.Color = Colors.TextPrimary
    lbl.Size = 14
    lbl.Font = Drawing.Fonts.System
    lbl.Center = false
    lbl.Outline = false
    lbl.Visible = true
    lbl.ZIndex = zbase + 5
    table.insert(GUI.ContentElements, lbl)

    local tw, th = Config.ToggleW, Config.ToggleH
    local toggleX = rightEdge - tw
    local bgColor = isOn and Colors.ToggleOn or Colors.ToggleOff

    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(toggleX, curY + 1)
    bg.Size = Vector2.new(tw, th)
    bg.Color = bgColor
    bg.Filled = true
    bg.Corner = 8
    bg.Visible = true
    bg.ZIndex = zbase + 3
    table.insert(GUI.ContentElements, bg)

    local offX  = toggleX + 2
    local onX   = toggleX + tw - th + 2
    local knobC = (th - 4) / 2
    local knobY = curY + 1 + th / 2
    local knobX = (isOn and onX or offX) + knobC
    local knob = Drawing.new("Circle")
    knob.Position = Vector2.new(knobX, knobY)
    knob.Radius = knobC
    knob.Color = Color3.fromRGB(230, 230, 235)
    knob.Filled = true
    knob.NumSides = 16
    knob.Visible = true
    knob.ZIndex = zbase + 4
    table.insert(GUI.ContentElements, knob)

    if dotColor then
        local dot = Drawing.new("Circle")
        dot.Position = Vector2.new(toggleX - 16, curY + 9)
        dot.Radius = 4
        dot.Color = dotColor
        dot.Filled = true
        dot.NumSides = 14
        dot.Visible = true
        dot.ZIndex = zbase + 4
        table.insert(GUI.ContentElements, dot)
    end

    table.insert(GUI.Clickables, {
        x = toggleX - 20, y = curY,
        w = tw + 20, h = th + 4,
        onClick = function()
            local newOn = not isOn
            local fromX = (isOn  and onX or offX) + knobC
