-- VK code name lookup
local VK_NAMES = {
    [0x70] = "F1", [0x71] = "F2", [0x72] = "F3", [0x73] = "F4",
    [0x74] = "F5", [0x75] = "F6", [0x76] = "F7", [0x77] = "F8",
    [0x78] = "F9", [0x79] = "F10", [0x7A] = "F11", [0x7B] = "F12",
    [0x2D] = "Insert", [0x2E] = "Delete", [0x24] = "Home", [0x23] = "End",
    [0x21] = "PgUp", [0x22] = "PgDn",
    [0x60] = "Num0", [0x61] = "Num1", [0x62] = "Num2", [0x63] = "Num3",
    [0x64] = "Num4", [0x65] = "Num5", [0x66] = "Num6", [0x67] = "Num7",
    [0x6A] = "Num*", [0x6B] = "Num+", [0x6D] = "Num-", [0x6E] = "Num.", [0x6F] = "Num/",
    [0x68] = "Num8", [0x69] = "Num9",
    [0x30] = "0", [0x31] = "1", [0x32] = "2", [0x33] = "3", [0x34] = "4",
    [0x35] = "5", [0x36] = "6", [0x37] = "7", [0x38] = "8", [0x39] = "9",
    [0xC0] = "`", [0xBD] = "-", [0xBB] = "=", [0xDC] = "\\",
    [0xDB] = "[", [0xDD] = "]", [0xBA] = ";", [0xDE] = "'",
    [0xBC] = ",", [0xBE] = ".", [0xBF] = "/",
}
-- Add A-Z
for i = 0x41, 0x5A do VK_NAMES[i] = string.char(i) end

-- All scannable VK codes
local VK_SCAN = {}
for code, _ in pairs(VK_NAMES) do table.insert(VK_SCAN, code) end

local function GetKeyName(vk)
    return VK_NAMES[vk] or string.format("0x%02X", vk)
end

