local function PageTools()
    local zb = 13
    local contentTopY = Config.WinY + Config.HeaderH + Config.SubTabH + Config.ContentPad
    local leftX = Config.WinX + Config.ContentPad
    local rightX = Config.WinX + Config.ContentPad + Config.ColW + Config.ColGap
    local colW = Config.ColW

    -- ===== LEFT COLUMN: Player List =====
    local plCardH = 52 + 2 * Config.RowHeight + 14
    local plContentY = DrawCard(leftX, contentTopY, colW, plCardH, "Player List", zb)

    -- Open/Close toggle
    DrawCardToggleRow(leftX, colW, plContentY, GUI.PlayerListOpen and "Close Player List" or "Open Player List", GUI.PlayerListOpen, nil, zb, function()
        GUI.PlayerListOpen = not GUI.PlayerListOpen
        if GUI.PlayerListOpen then
            GUI.PLScrollOffset = 0
            BuildPlayerList()
        else
            ClearPlayerList()
        end
        CreateContent(GUI.SelectedPage)
    end)

    -- Auto Update toggle
    DrawCardToggleRow(leftX, colW, plContentY + Config.RowHeight, "Auto Update", GUI.PLAutoUpdate, nil, zb, function()
        GUI.PLAutoUpdate = not GUI.PLAutoUpdate
        CreateContent(GUI.SelectedPage)
    end)

    -- ===== RIGHT COLUMN: Misc Tools (Counters + Enchants + RS Diff) =====
    local miscCardH = 52 + 3 * Config.RowHeight + 14
    local miscContentY = DrawCard(rightX, contentTopY, colW, miscCardH, "Misc Tools", zb)

    DrawCardToggleRow(rightX, colW, miscContentY, GUI.CounterVisible and "Hide Counters" or "Show Counters", GUI.CounterVisible, nil, zb, function()
        GUI.CounterVisible = not GUI.CounterVisible
        BuildCounterPanel()
        CreateContent(GUI.SelectedPage)
    end)

    DrawCardToggleRow(rightX, colW, miscContentY + Config.RowHeight, GUI.EnchantsOpen and "Hide Enchants" or "Show Enchants", GUI.EnchantsOpen, nil, zb, function()
        GUI.EnchantsOpen = not GUI.EnchantsOpen
        if GUI.EnchantsOpen then
            if not GUI.EnchantsAllData then
                GUI.EnchantsFetchStatus = "Fetching..."
                BuildEnchantsPanel()
                task.spawn(function()
                    FetchEnchantData()
                    FetchOwnedEnchants()
                    BuildEnchantsPanel()
                end)
            else
                FetchOwnedEnchants()
                BuildEnchantsPanel()
            end
        else
            GUI.EnchantsModal = nil
            ClearEnchantsPanel()
            if GUI._enchHoverEl then GUI._enchHoverEl.Visible = false end
        end
        CreateContent(GUI.SelectedPage)
    end)

    DrawCardToggleRow(rightX, colW, miscContentY + 2 * Config.RowHeight,
        GUI.RSDiffOpen and "Hide RS Diff" or "Show RS Diff",
        GUI.RSDiffOpen, nil, zb, function()
            GUI.RSDiffOpen = not GUI.RSDiffOpen
            if GUI.RSDiffOpen then
                BuildRSDiffPanel()
            else
                ClearRSDiffPanel()
            end
            CreateContent(GUI.SelectedPage)
        end)

    -- ===== RIGHT COLUMN: Player Indicators (Health Bar + Damage Indicator) =====
    local piCardY = contentTopY + miscCardH + 12
    local piCardH = 52 + 2 * Config.RowHeight + 14
    local piContentY = DrawCard(rightX, piCardY, colW, piCardH, "Player Indicators", zb)

    DrawCardToggleRow(rightX, colW, piContentY, "Health Bar", GUI.HealthBarVisible, nil, zb, function()
        GUI.HealthBarVisible = not GUI.HealthBarVisible
        BuildHealthBar()
        CreateContent(GUI.SelectedPage)
    end)

    DrawCardToggleRow(rightX, colW, piContentY + Config.RowHeight, "Damage Indicator", GUI.DmgIndicatorEnabled, nil, zb, function()
        GUI.DmgIndicatorEnabled = not GUI.DmgIndicatorEnabled
        CreateContent(GUI.SelectedPage)
    end)

    local maxBottom = math.max(contentTopY + plCardH, piCardY + piCardH)
    GUI.TotalContentH = maxBottom - (Config.WinY + Config.HeaderH + Config.SubTabH)
end

local function PageSettings()
    local baseY = Config.WinY + Config.HeaderH + Config.SubTabH + Config.ContentPad
    local zb = 13

    -- Center a half-width card column inside the content area, AOTR-style.
    local fullW = Config.WinW - Config.ContentPad * 2
    local cardW = math.floor(fullW * 0.55)
    local cardX = Config.WinX + Config.ContentPad + math.floor((fullW - cardW) / 2)

    -- Helper for buttons inside cards.
    local function DrawConfigButton(bx, by, bw, bh, label, fg, bgcol, onClick)
        local bg = Drawing.new("Square")
        bg.Position = Vector2.new(bx, by)
        bg.Size = Vector2.new(bw, bh)
        bg.Color = bgcol
        bg.Filled = true
        bg.Corner = 5
        bg.Visible = true
        bg.ZIndex = zb
        table.insert(GUI.ContentElements, bg)

        local brd = Drawing.new("Square")
        brd.Position = Vector2.new(bx, by)
        brd.Size = Vector2.new(bw, bh)
        brd.Color = Colors.Border
        brd.Filled = false
        brd.Corner = 5
        brd.Thickness = 1
        brd.Visible = true
        brd.ZIndex = zb + 1
        table.insert(GUI.ContentElements, brd)

        local txt = Drawing.new("Text")
        txt.Position = Vector2.new(bx + bw / 2, by + (bh - 13) / 1.3 + 0.5)
        txt.Text = label
        txt.Color = fg
        txt.Size = 13
        txt.Font = Drawing.Fonts.SystemBold
        txt.Center = true
        txt.Outline = false
        txt.Visible = true
        txt.ZIndex = zb + 2
        table.insert(GUI.ContentElements, txt)

        table.insert(GUI.Clickables, {
            x = bx, y = by, w = bw, h = bh, onClick = onClick,
        })
    end

    -- ===== Controls card =====
    local controlsH = 52 + 2 * Config.RowHeight + 14
    local controlsContentY = DrawCard(cardX, baseY, cardW, controlsH, "Controls", zb)

    local lx = cardX + Config.CardPad
    local rightEdge = cardX + cardW - Config.CardPad

    -- Renders one "Label .... [VK button]" row at rowY. `listening` is the
    -- bool that flips on while we're waiting for the user to press a key;
    -- `currentKey` is what the button label falls back to otherwise.
    local function DrawKeyBindRow(rowY, label, listening, currentKey, onArm)
        local lbl = Drawing.new("Text")
        lbl.Position = Vector2.new(lx, rowY + 4)
        lbl.Text = label
        lbl.Color = Colors.TextPrimary
        lbl.Size = 14
        lbl.Font = Drawing.Fonts.System
        lbl.Center = false
        lbl.Outline = false
        lbl.Visible = true
        lbl.ZIndex = zb + 5
        table.insert(GUI.ContentElements, lbl)

        local btnW, btnH = 90, 24
        local btnX = rightEdge - btnW
        local btnY = rowY + 2

        local btnBg = Drawing.new("Square")
        btnBg.Position = Vector2.new(btnX, btnY)
        btnBg.Size = Vector2.new(btnW, btnH)
        btnBg.Color = listening and Color3.fromRGB(80, 40, 40) or Color3.fromRGB(30, 30, 36)
        btnBg.Filled = true
        btnBg.Corner = 5
        btnBg.Visible = true
        btnBg.ZIndex = zb + 3
        table.insert(GUI.ContentElements, btnBg)

        local btnBorder = Drawing.new("Square")
        btnBorder.Position = Vector2.new(btnX, btnY)
        btnBorder.Size = Vector2.new(btnW, btnH)
        btnBorder.Color = listening and Color3.fromRGB(180, 60, 60) or Colors.Border
        btnBorder.Filled = false
        btnBorder.Corner = 5
        btnBorder.Thickness = 1
        btnBorder.Visible = true
        btnBorder.ZIndex = zb + 4
        table.insert(GUI.ContentElements, btnBorder)

        local btnText = Drawing.new("Text")
        btnText.Position = Vector2.new(btnX + btnW / 2, btnY + (btnH - 12) / 1.3 + 0.5)
        btnText.Text = listening and "..." or GetKeyName(currentKey)
        btnText.Color = listening and Color3.fromRGB(255, 100, 100) or Colors.Accent
        btnText.Size = 12
        btnText.Font = Drawing.Fonts.SystemBold
        btnText.Center = true
        btnText.Outline = false
        btnText.Visible = true
        btnText.ZIndex = zb + 5
        table.insert(GUI.ContentElements, btnText)

        table.insert(GUI.Clickables, {
            x = btnX, y = btnY, w = btnW, h = btnH,
            onClick = function()
                onArm()
                CreateContent("Settings")
            end,
        })
    end

    DrawKeyBindRow(controlsContentY, "Toggle Key", GUI.ListeningForKey, GUI.ToggleKey, function()
        GUI.ListeningForKey = true
    end)
    DrawKeyBindRow(controlsContentY + Config.RowHeight, "Close Key", GUI.ListeningForCloseKey, GUI.CloseKey, function()
        GUI.ListeningForCloseKey = true
    end)

    -- ===== Config card =====
    local configTopY = baseY + controlsH + 14
    local configH = 52 + 2 * Config.RowHeight + 14
    local configContentY = DrawCard(cardX, configTopY, cardW, configH, "Config", zb)

    local cBtnW, cBtnH = 110, 26
    local cBtnGap = 14
    local cTotalW = cBtnW * 2 + cBtnGap
    local cRowX = cardX + math.floor((cardW - cTotalW) / 2)
    local cRowY = configContentY + 5

    DrawConfigButton(cRowX, cRowY, cBtnW, cBtnH, "Save Config",
        Color3.fromRGB(220, 220, 225), Color3.fromRGB(40, 80, 50), function()
            saveConfig()
            notify("Requiem", "Config saved to " .. CONFIG_PATH, 2)
        end)

    DrawConfigButton(cRowX + cBtnW + cBtnGap, cRowY, cBtnW, cBtnH, "Load Config",
        Color3.fromRGB(220, 220, 225), Color3.fromRGB(60, 40, 80), function()
            loadConfig()
            notify("Requiem", "Config loaded from " .. CONFIG_PATH, 2)
            CreateContent("Settings")
            if GUI.HintText then
                pcall(function()
                    GUI.HintText.Text = GetKeyName(GUI.ToggleKey) .. " Toggle | " .. GetKeyName(GUI.CloseKey) .. " Unload"
                end)
            end
        end)

    -- Reset Config — first click arms a 3-second confirmation window.
    local confirming = GUI.ResetConfirmAt and (tick() - GUI.ResetConfirmAt < 3)
    local resetLabel = confirming and "Confirm Reset?" or "Reset Config"
    local resetBg = confirming and Colors.BtnDanger or Color3.fromRGB(60, 30, 30)

    DrawConfigButton(cRowX, cRowY + Config.RowHeight, cTotalW, cBtnH, resetLabel,
        Color3.fromRGB(255, 220, 220), resetBg, function()
            if GUI.ResetConfirmAt and (tick() - GUI.ResetConfirmAt < 3) then
                resetConfigToDefaults()
                GUI.ResetConfirmAt = nil
                notify("Requiem", "Config reset to defaults", 3)
                CreateContent("Settings")
                if GUI.HintText then
                    pcall(function()
                        GUI.HintText.Text = GetKeyName(GUI.ToggleKey) .. " Toggle | " .. GetKeyName(GUI.CloseKey) .. " Unload"
                    end)
                end
            else
                GUI.ResetConfirmAt = tick()
                CreateContent("Settings")
            end
        end)

    GUI.TotalContentH = (configTopY + configH) - baseY
end

