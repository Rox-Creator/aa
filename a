-- ============================================================

local function MoveWindow(dx, dy)
    Config.WinX = Config.WinX + dx
    Config.WinY = Config.WinY + dy

    local function moveEl(el)
        pcall(function()
            if el.Position then
                el.Position = Vector2.new(el.Position.X + dx, el.Position.Y + dy)
            end
        end)
        pcall(function()
            if el.From then
                el.From = Vector2.new(el.From.X + dx, el.From.Y + dy)
            end
        end)
        pcall(function()
            if el.To then
                el.To = Vector2.new(el.To.X + dx, el.To.Y + dy)
            end
        end)
    end

    for _, el in ipairs(GUI.Elements) do
        moveEl(el)
    end

    for _, el in ipairs(GUI.ContentElements) do
        moveEl(el)
    end

    for _, el in ipairs(GUI.SubTabElements) do
        moveEl(el)
    end

    -- Update nav button positions
    for _, btn in ipairs(GUI.NavButtons) do
        btn.X = btn.X + dx
        btn.Y = btn.Y + dy
    end

    -- Update sub-tab clickable positions
    for _, c in ipairs(GUI.SubTabClickables) do
        c.x = c.x + dx
        c.y = c.y + dy
    end
end

-- ============================================================
-- ORE ESP ENGINE
-- ============================================================

local function colorMatch(c1, r, g, b)
    if not c1 then return false end
    local pr = math.floor(c1.R + 0.5)
    local pg = math.floor(c1.G + 0.5)
    local pb = math.floor(c1.B + 0.5)
    local t = ESP.ColorTolerance
    return math.abs(pr - r) <= t and math.abs(pg - g) <= t and math.abs(pb - b) <= t
end

local function getOreInfo(color)
    for _, ore in ipairs(ORE_LIST) do
        if colorMatch(color, ore.Color[1], ore.Color[2], ore.Color[3]) then
            return ore
        end
    end
    return nil
end

local function anyOreEnabled()
    for _, ore in ipairs(ORE_LIST) do
        if ore.Enabled then return true end
    end
    return false
end

local function getPlayerPos()
    if LocalPlayer.Character then
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp.Position end
    end
    return nil
end

local function espRegisterObj(obj)
    if obj.Name ~= "Ore" then return end
    local minerals = obj:FindFirstChild("Minerals")
    if not minerals then return end
    local mineral = minerals:FindFirstChild("Mineral")
    if not mineral then return end
    local id = tostring(obj.Address)
    if ESP.Objects[id] then return end
    local ore = getOreInfo(mineral.Color)
    if not ore then return end
    local label = Drawing.new("Text")
    label.Text = ore.Name
    label.Color = ore.ESPColor
    label.Size = ESP.TextSize
    label.Center = true
    label.Outline = true
    label.Visible = false
    label.ZIndex = 50
    ESP.Objects[id] = {
        label = label,
        oreName = ore.Name,
        mineral = mineral,
    }
end

local function espScan()
    for _, obj in pairs(Workspace:GetChildren()) do
        espRegisterObj(obj)
    end
end

local function espUpdate()
    if not anyOreEnabled() then
        for _, data in pairs(ESP.Objects) do
            data.label.Visible = false
        end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end

    for id, data in pairs(ESP.Objects) do
        local mineral = data.mineral
        if not mineral or not mineral.Parent then
            data.label.Visible = false
        else
            local enabled = false
            for _, ore in ipairs(ORE_LIST) do
                if ore.Name == data.oreName then
                    enabled = ore.Enabled
                    break
                end
            end

            if not enabled then
                data.label.Visible = false
            else
                local pos = mineral.Position
                if not pos then
                    data.label.Visible = false
                else
                    local dx = playerPos.X - pos.X
                    local dy = playerPos.Y - pos.Y
                    local dz = playerPos.Z - pos.Z
                    local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

                    if dist > ESP.MaxDistance then
                        data.label.Visible = false
                    else
                        local screenPos, onScreen = WorldToScreen(pos)
                        if onScreen and screenPos then
                            local fd = math.floor(dist)
                            if data.lastDist ~= fd then
                                data.label.Text = data.oreName .. " [" .. fd .. "m]"
                                data.lastDist = fd
                            end
                            data.label.Position = Vector2.new(screenPos.X, screenPos.Y)
                            data.label.Visible = true
                        else
                            data.label.Visible = false
                        end
                    end
                end
            end
        end
    end
end

local function espCleanup()
    for id, data in pairs(ESP.Objects) do
        local mineral = data.mineral
        if not mineral or not mineral.Parent then
            data.label:Remove()
            ESP.Objects[id] = nil
        end
    end
end

-- ============================================================
-- MARCS ESP ENGINE
-- ============================================================

local function marcsRegisterObj(obj)
    if obj.Name ~= "Marcs" then return end
    local part = obj:FindFirstChild("Part")
    if part then
        local id = tostring(obj.Address)
        if not MARCS.Objects[id] then
            local label = Drawing.new("Text")
            label.Text = "Marcs"
            label.Color = MARCS.ESPColor
            label.Size = MARCS.TextSize
            label.Center = true
            label.Outline = true
            label.Visible = false
            label.ZIndex = 50
            MARCS.Objects[id] = {
                label = label,
                obj = obj,
                part = part,
            }
        end
    else
        for _, child in pairs(obj:GetChildren()) do
            local cpart = child:FindFirstChild("Part")
            if cpart then
                local id = tostring(child.Address)
                if not MARCS.Objects[id] then
                    local label = Drawing.new("Text")
                    label.Text = "Marcs"
                    label.Color = MARCS.ESPColor
                    label.Size = MARCS.TextSize
                    label.Center = true
                    label.Outline = true
                    label.Visible = false
                    label.ZIndex = 50
                    MARCS.Objects[id] = {
                        label = label,
                        obj = child,
                        part = cpart,
                    }
                end
            end
        end
    end
end

local function marcsScan()
    for _, obj in pairs(Workspace:GetChildren()) do
        marcsRegisterObj(obj)
    end
end

local function marcsUpdate()
    if not MARCS.Enabled then
        for _, data in pairs(MARCS.Objects) do
            data.label.Visible = false
        end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end

    for id, data in pairs(MARCS.Objects) do
        local obj = data.obj
        local part = data.part
        if not obj or not obj.Parent or not part or not part.Parent then
            data.label.Visible = false
        else
            local pos = part.Position
            if not pos then
                data.label.Visible = false
            else
                local dx = playerPos.X - pos.X
                local dy = playerPos.Y - pos.Y
                local dz = playerPos.Z - pos.Z
                local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

                if dist > MARCS.MaxDistance then
                    data.label.Visible = false
                else
                    local screenPos, onScreen = WorldToScreen(pos)
                    if onScreen and screenPos then
                        -- Read amount via cached source; re-probe fallback chain only on miss.
                        local amount = ""
                        local src = data.amountSource
                        if src == "Data" then
                            pcall(function() amount = tostring(part.Data) end)
                        elseif src == "child" then
                            local c = data.amountChild
                            if c and c.Parent then pcall(function() amount = tostring(c.Value) end) end
                        elseif src == "AttrData" then
                            pcall(function() amount = tostring(part:GetAttribute("Data")) end)
                        elseif src == "Name" then
                            pcall(function() if tonumber(part.Name) then amount = part.Name end end)
                        elseif src == "ParentName" then
                            pcall(function()
                                local p = part.Parent
                                if p and tonumber(p.Name) then amount = p.Name end
                            end)
                        end
                        if amount == "" or amount == "nil" then
                            data.amountSource = nil; data.amountChild = nil
                            pcall(function() amount = tostring(part.Data) end)
                            if amount ~= "" and amount ~= "nil" then data.amountSource = "Data" end
                            if not data.amountSource then
                                pcall(function()
                                    local dv = part:FindFirstChild("Data")
                                    if dv then amount = tostring(dv.Value); data.amountChild = dv end
                                end)
                                if amount ~= "" and amount ~= "nil" then data.amountSource = "child" end
                            end
                            if not data.amountSource then
                                pcall(function() amount = tostring(part:GetAttribute("Data")) end)
                                if amount ~= "" and amount ~= "nil" then data.amountSource = "AttrData" end
                            end
                            if not data.amountSource then
                                pcall(function() if tonumber(part.Name) then amount = part.Name end end)
                                if amount ~= "" and amount ~= "nil" then data.amountSource = "Name" end
                            end
                            if not data.amountSource then
                                pcall(function()
                                    local p = part.Parent
                                    if p and tonumber(p.Name) then amount = p.Name end
                                end)
                                if amount ~= "" and amount ~= "nil" then data.amountSource = "ParentName" end
                            end
                        end
                        local fd = math.floor(dist)
                        if data.lastDist ~= fd or data.lastAmount ~= amount then
                            local text = "Marcs"
                            if amount ~= "" and amount ~= "nil" then text = amount .. " Marcs" end
                            data.label.Text = text .. " [" .. fd .. "m]"
                            data.lastDist = fd
                            data.lastAmount = amount
                        end
                        data.label.Position = Vector2.new(screenPos.X, screenPos.Y)
                        data.label.Visible = true
                    else
                        data.label.Visible = false
                    end
                end
            end
        end
    end
end

