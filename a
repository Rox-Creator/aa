-- ============================================================
-- DEATH LOG WEBHOOK ENGINE
-- ============================================================
-- Detection model: when a player dies in Requiem, their character
-- Model in Workspace is replaced by a model named "<Name>_ragdoll"
-- carrying attributes (Reason, Damage, Category, Timestamp, Actor).
-- We poll Workspace:GetChildren() every PollInterval seconds.
--
-- Event filter: non-event deaths despawn the corpse after a few
-- seconds; event deaths leave the body forever. To filter out
-- non-event noise we don't fire on detection — we hold the ragdoll
-- in Pending and only webhook it if the body is STILL there after
-- PermaThreshold seconds (60s). If it despawns before then we drop
-- it silently and also clear `Seen` so a future death under the
-- same name re-evaluates fresh.
--
-- Routing: Actor=true ragdolls go to DEATHLOG.ActorWebhook (lore/NPC
-- channel), anything else goes to DEATHLOG.Webhook (normal player
-- deaths). Each channel only ever sees its own category.
--
-- Seeding: the first scan after enable adds every existing ragdoll
-- to .Seen WITHOUT queueing — only deaths that happen AFTER the
-- watcher is running can trigger a webhook.

-- Try to read an attribute by name from the ragdoll Model, then from
-- each first-level child. Matcha's GetAttribute is inconsistent on
-- Workspace Models (often returns nil) but works on BaseParts /
-- Humanoids — so probing children is the reliable path.
local function deathGetAttr(inst, name)
    local v
    pcall(function() v = inst:GetAttribute(name) end)
    if v ~= nil then return v end
    local kids
    pcall(function() kids = inst:GetChildren() end)
    if not kids then return nil end
    for _, c in ipairs(kids) do
        local cv
        pcall(function() cv = c:GetAttribute(name) end)
        if cv ~= nil then return cv end
    end
    return nil
end

local function deathReadAttrs(inst)
    return
        deathGetAttr(inst, "Reason"),
        deathGetAttr(inst, "Damage"),
        deathGetAttr(inst, "Category"),
        deathGetAttr(inst, "Timestamp"),
        deathGetAttr(inst, "Actor")
end

-- Strip "_ragdoll" suffix to recover the original player name.
local function deathCleanName(name)
    local stripped = (name or ""):gsub("_ragdoll$", "")
    if stripped == "" then return tostring(name or "?") end
    return stripped
end

-- Uppercase the first character only — "musket" -> "Musket",
-- "animal" -> "Animal". Used to clean up Reason / Category before
-- they're dropped into the message body.
local function deathCapitalize(s)
    if type(s) ~= "string" or #s == 0 then return s end
    return s:sub(1, 1):upper() .. s:sub(2)
end

-- Build the Discord message body. Format:
--   **Player** ( Name ) **Has died.**
--   **Reason:** <Reason>
--   **Amount:** <damage int>
--   **Details:** <Category>
--   **Died on:** <t:<int>:S>
-- Reason / Category are first-letter capitalized. Timestamp gets
-- math.floor() (the game stores 1779493554.14 — only integer seconds
-- are needed for Discord's <t:N:S> token).
local function deathFormatMessage(playerName, reason, damage, category, timestamp)
    local clean = deathCleanName(playerName)

    -- Timestamp → integer seconds. Handle number, numeric string, or nil.
    local tsInt
    if type(timestamp) == "number" then
        tsInt = math.floor(timestamp)
    elseif type(timestamp) == "string" then
        local n = tonumber((timestamp:match("^(%-?%d+)")))
        if n then tsInt = n end
    end
    if not tsInt then
        local okT, t = pcall(os.time)
        tsInt = okT and t or 0
    end

    -- Damage → integer if numeric, otherwise stringify.
    local dmgText
    if type(damage) == "number" then
        dmgText = tostring(math.floor(damage))
    elseif damage ~= nil then
        dmgText = tostring(damage)
    else
        dmgText = "?"
    end

    return string.format(
        "**Player** ( %s ) **Has died.**\n**Reason:** %s\n**Amount:** %s\n**Details:** %s\n**Died on:** <t:%d:S>",
        clean,
        deathCapitalize(tostring(reason or "?")),
        dmgText,
        deathCapitalize(tostring(category or "?")),
        tsInt
    )
end

-- `isActor`=true → post to the actor/lore webhook; otherwise the normal
-- player-deaths webhook. Each webhook only ever sees its own category
-- so neither channel gets cross-posted noise.
local function deathSendWebhook(content, isActor)
    if type(content) ~= "string" or #content == 0 then return end
    local url = isActor and DEATHLOG.ActorWebhook or DEATHLOG.Webhook
    if type(url) ~= "string" or #url == 0 then return end

    -- Prefer HttpService:JSONEncode (proper escaping) with a minimal
    -- manual fallback if it errors on weird control bytes.
    local body
    local okEnc, encoded = pcall(function()
        return HttpService:JSONEncode({ content = content })
    end)
    if okEnc and type(encoded) == "string" and #encoded > 0 then
        body = encoded
    else
        local esc = content
            :gsub("\\", "\\\\")
            :gsub('"', '\\"')
            :gsub("\n", "\\n")
            :gsub("\r", "\\r")
            :gsub("\t", "\\t")
        body = '{"content":"' .. esc .. '"}'
    end

    -- Fire-and-forget — never block the watcher thread on a 1-2s POST.
    task.spawn(function()
        pcall(function()
            if type(httppost) == "function" then
                httppost(url, body, "application/json")
            else
                game:HttpPost(url, body, "application/json")
            end
        end)
    end)
end

local function deathLogUpdate()
    if not DEATHLOG.Enabled then return end

    local now = tick()
    if now < DEATHLOG.NextPollAt then return end
    DEATHLOG.NextPollAt = now + DEATHLOG.PollInterval

    -- Hoist hot fields into locals — Lua field reads are cheap but
    -- not free, and this is the hot path.
    local seen    = DEATHLOG.Seen
    local pending = DEATHLOG.Pending
    local seeded  = DEATHLOG.Seeded

    -- Single outer pcall around the whole workspace scan. Matcha's
    -- per-pcall overhead is significant (each one crosses the
    -- emulator boundary), so batching all child reads into ONE pcall
    -- instead of one-per-child cuts scan cost dramatically on big
    -- workspaces.
    local liveByName
    pcall(function()
        local kids = Workspace:GetChildren()
        if not kids then return end
        local n = #kids
        local lbn = {}
        for i = 1, n do
            local c = kids[i]
            local nm = c.Name
            if type(nm) == "string" then
                local len = #nm
                if len > 8 and nm:sub(len - 7) == "_ragdoll" then
                    lbn[nm] = c
                    if not seen[nm] then
                        seen[nm] = true
                        if seeded then
                            pending[nm] = {
                                instance    = c,
                                firstSeenAt = now,
                            }
                        end
                    end
                end
            end
        end
        liveByName = lbn
    end)
    if not liveByName then
        DEATHLOG.Seeded = true
        return
    end

    -- Drain Pending. Two outcomes per entry:
    --   * Body still in Workspace AND age >= PermaThreshold → event-perma
    --     death, send the webhook now. (Non-event corpses despawn within
    --     ~5s, so any body that's still around past 60s is a real death.)
    --   * Body vanished before PermaThreshold → normal non-event death,
    --     drop silently. Also clear `seen[nm]` so if the same player
    --     dies again later we re-evaluate that body fresh.
    -- Anything in between just waits another poll.
    if next(pending) ~= nil then
        local threshold = DEATHLOG.PermaThreshold
        for nm, info in pairs(pending) do
            local inst       = liveByName[nm]
            local stillAlive = inst ~= nil
            local elapsed    = now - info.firstSeenAt

            if not stillAlive then
                -- Non-event corpse — body despawned before perma threshold.
                pending[nm] = nil
                seen[nm]    = nil
            elseif elapsed >= threshold then
                local reason, damage, category, timestamp, actor = deathReadAttrs(inst)
                local msg = deathFormatMessage(nm, reason, damage, category, timestamp)
                deathSendWebhook(msg, actor == true)
                DEATHLOG.SentCount = DEATHLOG.SentCount + 1
                local okT, t = pcall(os.time)
                DEATHLOG.LastSent = {
                    name = deathCleanName(nm),
                    when = okT and t or 0,
                }
                pending[nm] = nil
            end
        end
    end

    DEATHLOG.Seeded = true
end

-- On-demand snapshot: scan Workspace right now and webhook every
-- existing ragdoll, regardless of the watcher's Seeded state. Each
-- one is also added to DEATHLOG.Seen so the regular watcher won't
-- re-post the same body. Returns the count actually sent.
-- Assigned to the forward-declared module-level local so the PageLogs
-- button (built much earlier in the file) can resolve it as an upvalue.
deathFetchAllNow = function()
    -- Collect ragdoll Instances first under a single pcall, then do
    -- attribute reads + webhook sends outside the protected section.
    -- Same batching rationale as deathLogUpdate.
    local matches = {}
    pcall(function()
        local kids = Workspace:GetChildren()
        if not kids then return end
        for i = 1, #kids do
            local c = kids[i]
            local nm = c.Name
            if type(nm) == "string" then
                local len = #nm
                if len > 8 and nm:sub(len - 7) == "_ragdoll" then
                    matches[#matches + 1] = { inst = c, name = nm }
                end
            end
        end
    end)

    local sent = 0
    for i = 1, #matches do
        local m = matches[i]
        local nm = m.name
        local reason, damage, category, timestamp, actor = deathReadAttrs(m.inst)
        local msg = deathFormatMessage(nm, reason, damage, category, timestamp)
        deathSendWebhook(msg, actor == true)
        DEATHLOG.SentCount = DEATHLOG.SentCount + 1
        DEATHLOG.Seen[nm] = true
        DEATHLOG.Pending[nm] = nil
        sent = sent + 1
        local okT, t = pcall(os.time)
        DEATHLOG.LastSent = {
            name = deathCleanName(nm),
            when = okT and t or 0,
        }
    end
    return sent
end

-- ============================================================
-- ACTOR ESP ENGINE
-- ============================================================
-- See ACTOR_ESP config block at top of file for the data model. Brief:
-- we register an actor entry the first time we see a *_ragdoll model
-- in Workspace whose Actor attribute is true. Once registered, each
-- update we re-resolve the entry to either the live model or the
-- ragdoll (live wins), and draw a tag + name above it. When both refs
-- are gone we delete the entry and its Drawing handles.

local function actorEspRegisterByName(name)
    if ACTOR_ESP.Objects[name] then return end

    local prefixTag = Drawing.new("Text")
    prefixTag.Color = Color3.fromRGB(80, 220, 100)   -- "(ACTOR)" stays green; we never render the dead state
    prefixTag.Size = ACTOR_ESP.TextSize
    prefixTag.Font = TITAN_FONTS[ACTOR_ESP.FontIndex].font
    prefixTag.Center = false
    prefixTag.Outline = true
    prefixTag.Visible = false
    prefixTag.ZIndex = 52

    local nameTag = Drawing.new("Text")
    nameTag.Color = Color3.fromRGB(220, 220, 225)
    nameTag.Size = ACTOR_ESP.TextSize
    nameTag.Font = TITAN_FONTS[ACTOR_ESP.FontIndex].font
    nameTag.Center = false
    nameTag.Outline = true
    nameTag.Visible = false
    nameTag.ZIndex = 52

    ACTOR_ESP.Objects[name] = {
        liveModel    = nil,
        ragdollModel = nil,
        prefixTag    = prefixTag,
        nameTag      = nameTag,
    }
end

-- Walk Workspace once: any *_ragdoll Model with Actor=true gets its
-- base name registered. Already-registered names are no-ops.
local function actorEspScan()
    local kids
    pcall(function() kids = Workspace:GetChildren() end)
    if not kids then return end

    for i = 1, #kids do
        local c = kids[i]
        local cls
        pcall(function() cls = c.ClassName end)
        if cls == "Model" then
            local nm
            pcall(function() nm = c.Name end)
            if type(nm) == "string" then
                local len = #nm
                if len > 8 and nm:sub(len - 7) == "_ragdoll" then
                    if deathGetAttr(c, "Actor") == true then
                        local baseName = nm:sub(1, len - 8)
                        if baseName ~= "" then
                            actorEspRegisterByName(baseName)
                        end
                    end
                end
            end
        end
    end
end

local function actorEspHide(data)
    data.prefixTag.Visible = false
    data.nameTag.Visible = false
end

local function actorEspUpdate()
    if not ACTOR_ESP.Enabled then
        for _, data in pairs(ACTOR_ESP.Objects) do actorEspHide(data) end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end

    for name, data in pairs(ACTOR_ESP.Objects) do
        -- Look up both possible Workspace instances. We only DRAW for
        -- the live one — dead actors are covered by the (DEAD) ragdoll
        -- ESP under the Players toggle. We still cache the ragdoll ref
        -- so actorEspCleanup can tell when both are truly gone and the
        -- entry can be removed.
        local liveModel, ragdollModel
        pcall(function() liveModel = Workspace:FindFirstChild(name) end)
        pcall(function() ragdollModel = Workspace:FindFirstChild(name .. "_ragdoll") end)
        data.liveModel    = liveModel
        data.ragdollModel = ragdollModel

        if not liveModel then
            -- Either still dead or not respawned yet. Keep the entry —
            -- a future respawn will re-light it without re-registering.
            actorEspHide(data)
        else
            local pos = ragdollPosition(liveModel)
            if not pos then
                actorEspHide(data)
            else
                local dx = playerPos.X - pos.X
                local dy = playerPos.Y - pos.Y
                local dz = playerPos.Z - pos.Z
                local dist = math.sqrt(dx*dx + dy*dy + dz*dz)
                if dist > ACTOR_ESP.MaxDistance then
                    actorEspHide(data)
                else
                    local headTop = Vector3.new(pos.X, pos.Y + 3, pos.Z)
                    local screenPos, onScreen = WorldToScreen(headTop)
                    if not (screenPos and onScreen) then
                        actorEspHide(data)
                    else
                        local approxChar = ACTOR_ESP.TextSize * 0.55
                        local prefixStr  = "(ACTOR) "
                        local prefixW = #prefixStr * approxChar
                        local nameW   = #name * approxChar
                        local totalW  = prefixW + nameW
                        local leftX   = screenPos.X - totalW / 2
                        local y       = screenPos.Y - 20

                        data.prefixTag.Position = Vector2.new(leftX, y)
                        data.prefixTag.Text     = "(ACTOR)"
                        data.prefixTag.Visible  = true

                        data.nameTag.Position = Vector2.new(leftX + prefixW, y)
                        data.nameTag.Text     = name
                        data.nameTag.Visible  = true
                    end
                end
            end
        end
    end
end

-- Drop entries where BOTH the live model and the ragdoll are gone
-- (or unparented). Re-checks Workspace once before deleting in case
-- the cached refs are stale.
local function actorEspCleanup()
    for name, data in pairs(ACTOR_ESP.Objects) do
        local hasLive    = data.liveModel    and data.liveModel.Parent
        local hasRagdoll = data.ragdollModel and data.ragdollModel.Parent
        if not hasLive and not hasRagdoll then
            local live, ragdoll
            pcall(function() live = Workspace:FindFirstChild(name) end)
            pcall(function() ragdoll = Workspace:FindFirstChild(name .. "_ragdoll") end)
            if not live and not ragdoll then
                pcall(function() data.prefixTag:Remove() end)
                pcall(function() data.nameTag:Remove() end)
                ACTOR_ESP.Objects[name] = nil
            end
        end
    end
end

-- Helper: hide all labels for a simple ESP type
local function hideESPLabels(objects)
    for _, data in pairs(objects) do data.label.Visible = false end
end

-- Resupply ESP has three text fields per object (gas/blade/dist) instead
-- of a single `label`, so it needs its own hide helper.
local function hideResupplyLabels()
    for _, data in pairs(RESUPPLY.Objects) do
        data.gasText.Visible   = false
        data.bladeText.Visible = false
        data.distText.Visible  = false
    end
end

-- ESP loop (separate thread, optimized: only runs active features)
local function ESPLoop()
    local scanTimer = 0
    local wasOn = { ore = false, marcs = false, gear = false, resupply = false, flintlock = false, titan = false, animal = false, playerEsp = false, actorEsp = false }

    while GUI.Running do
        -- Check what's active
        local oreOn = anyOreEnabled()
        local anyActive = oreOn or MARCS.Enabled or GEAR.Enabled or RESUPPLY.Enabled or FLINTLOCK.Enabled
            or TITAN.Enabled or ANIMAL.Enabled or PLAYER_ESP.Enabled or ACTOR_ESP.Enabled or DEATHLOG.Enabled or GUI.CounterVisible

        -- If nothing is active, sleep longer
        if not anyActive then
            scanTimer = 0
            -- Hide anything that was just turned off
            if wasOn.ore then hideESPLabels(ESP.Objects); wasOn.ore = false end
            if wasOn.marcs then hideESPLabels(MARCS.Objects); wasOn.marcs = false end
            if wasOn.gear then hideESPLabels(GEAR.Objects); wasOn.gear = false end
            if wasOn.resupply then hideResupplyLabels(); wasOn.resupply = false end
            if wasOn.flintlock then hideESPLabels(FLINTLOCK.Objects); wasOn.flintlock = false end
            if wasOn.titan then
                for _, data in pairs(TITAN.Objects) do
                    for _, ln in ipairs(data.boneLines) do ln.Visible = false end
                    for _, dot in pairs(data.jointDots) do dot.Visible = false end
                    if data.headCircle then data.headCircle.Visible = false end
                    for _, ln in ipairs(data.wireLines) do ln.Visible = false end
                    data.nameTag.Visible = false
                end
                wasOn.titan = false
            end
            if wasOn.animal then
                for _, data in pairs(ANIMAL.Objects) do
                    for _, ln in ipairs(data.wireLines) do ln.Visible = false end
                    data.nameTag.Visible = false
                end
                wasOn.animal = false
            end
            if wasOn.playerEsp then
                for _, data in pairs(PLAYER_ESP.Objects) do
                    data.nameTag.Visible = false
                    data.tagBase.Visible = false
                    data.branchTag.Visible = false
                    data.hpTag.Visible = false
                end
                for _, data in pairs(PLAYER_ESP.DeadObjects) do
                    data.deadTag.Visible = false
                    data.nameTag.Visible = false
                end
                wasOn.playerEsp = false
            end
            if wasOn.actorEsp then
                for _, data in pairs(ACTOR_ESP.Objects) do
                    data.prefixTag.Visible = false
                    data.nameTag.Visible = false
                end
                wasOn.actorEsp = false
            end
            wait(0.1) -- Sleep longer when idle
        else
            -- Update only enabled features
            if oreOn then espUpdate(); wasOn.ore = true
            elseif wasOn.ore then hideESPLabels(ESP.Objects); wasOn.ore = false end

            if MARCS.Enabled then marcsUpdate(); wasOn.marcs = true
            elseif wasOn.marcs then hideESPLabels(MARCS.Objects); wasOn.marcs = false end

            if GEAR.Enabled then gearUpdate(); wasOn.gear = true
            elseif wasOn.gear then hideESPLabels(GEAR.Objects); wasOn.gear = false end

            if RESUPPLY.Enabled then resupplyUpdate(); wasOn.resupply = true
            elseif wasOn.resupply then hideResupplyLabels(); wasOn.resupply = false end

            if FLINTLOCK.Enabled then flintlockUpdate(); wasOn.flintlock = true
            elseif wasOn.flintlock then hideESPLabels(FLINTLOCK.Objects); wasOn.flintlock = false end

            if TITAN.Enabled then titanUpdate(); wasOn.titan = true
            elseif wasOn.titan then
                for _, data in pairs(TITAN.Objects) do
                    for _, ln in ipairs(data.boneLines) do ln.Visible = false end
                    for _, dot in pairs(data.jointDots) do dot.Visible = false end
                    if data.headCircle then data.headCircle.Visible = false end
                    for _, ln in ipairs(data.wireLines) do ln.Visible = false end
                    data.nameTag.Visible = false
                end
                wasOn.titan = false
            end

            if ANIMAL.Enabled then animalUpdate(); wasOn.animal = true
            elseif wasOn.animal then
                for _, data in pairs(ANIMAL.Objects) do
                    for _, ln in ipairs(data.wireLines) do ln.Visible = false end
                    data.nameTag.Visible = false
                end
                wasOn.animal = false
            end

            if PLAYER_ESP.Enabled then
                playerEspUpdate()
                playerEspDeadUpdate()
                wasOn.playerEsp = true
            elseif wasOn.playerEsp then
                for _, data in pairs(PLAYER_ESP.Objects) do
                    data.nameTag.Visible = false
                    data.tagBase.Visible = false
                    data.branchTag.Visible = false
                    data.hpTag.Visible = false
                end
                for _, data in pairs(PLAYER_ESP.DeadObjects) do
                    data.deadTag.Visible = false
                    data.nameTag.Visible = false
                end
                wasOn.playerEsp = false
            end

            if ACTOR_ESP.Enabled then
                actorEspUpdate()
                wasOn.actorEsp = true
            elseif wasOn.actorEsp then
                for _, data in pairs(ACTOR_ESP.Objects) do
                    data.prefixTag.Visible = false
                    data.nameTag.Visible = false
                end
                wasOn.actorEsp = false
            end

            if DEATHLOG.Enabled then deathLogUpdate() end

            -- Counter updates (only when visible) — text is repainted every frame but
            -- the Titans:GetChildren() count is refreshed during scan ticks below.
            if GUI.CounterVisible then
                if GUI.CounterGasText   then GUI.CounterGasText.Text   = tostring(math.floor(GUI.GasTotal))   end
                if GUI.CounterBladeText then GUI.CounterBladeText.Text = tostring(math.floor(GUI.BladeTotal)) end
                if GUI.CounterTitanText then GUI.CounterTitanText.Text = tostring(GUI.TitanCount)             end
            end

            -- Periodic scan/cleanup (only for enabled features). Resupply
            -- scan + cleanup also run when the Counter panel is open
            -- alone, so the gas/blade totals stay live without needing
            -- the ESP toggle on.
            scanTimer = scanTimer + 1
            if scanTimer >= 67 then
                if oreOn then espScan(); espCleanup() end
                if MARCS.Enabled then marcsScan(); marcsCleanup() end
                if GEAR.Enabled then gearScan(); gearCleanup() end
                if RESUPPLY.Enabled or GUI.CounterVisible then resupplyScan(); resupplyCleanup() end
                if RESUPPLY.Enabled or GUI.CounterVisible then updateResupplyCounter() end
                if FLINTLOCK.Enabled then flintlockScan(); flintlockCleanup() end
                if TITAN.Enabled then titanScan(); titanCleanup() end
                if ANIMAL.Enabled then animalScan(); animalCleanup() end
                if PLAYER_ESP.Enabled then
                    playerEspScan(); playerEspCleanup()
                    playerEspDeadScan(); playerEspDeadCleanup()
                end
                if ACTOR_ESP.Enabled then
                    actorEspScan(); actorEspCleanup()
                end
                if GUI.CounterVisible then
                    pcall(function()
                        local titans = Workspace:FindFirstChild("Titans")
                        GUI.TitanCount = titans and #titans:GetChildren() or 0
                    end)
                end
                scanTimer = 0
            end
            wait(0.016)
        end
    end
end

-- ============================================================
-- CONFIG SAVE / LOAD
-- ============================================================

-- saveConfig is only triggered by the explicit Save Config button on
-- Settings. Toggles/sliders DO NOT auto-save — keeps in-session
-- experiments from clobbering the on-disk file.
saveConfig = function()
    if type(writefile) ~= "function" then return end
    local oresOn = {}
    for _, ore in ipairs(ORE_LIST) do oresOn[ore.Name] = ore.Enabled end
    local data = {
        binds = {
            toggle     = GUI.ToggleKey,
            close      = GUI.CloseKey,
            playerList = GUI.PlayerListKey,
            playerEsp  = GUI.PlayerEspKey,
        },
        settings = {
            maxDistance        = ESP.MaxDistance,
            dmgIndicatorRadius = GUI.DmgIndicatorRadius,
        },
        features = {
            marcs        = MARCS.Enabled,
            gear         = GEAR.Enabled,
            resupply     = RESUPPLY.Enabled,
            flintlock    = FLINTLOCK.Enabled,
            titan        = TITAN.Enabled,
            animal       = ANIMAL.Enabled,
            playerEsp    = PLAYER_ESP.Enabled,
            plAutoUpdate = GUI.PLAutoUpdate,
            healthBar    = GUI.HealthBarVisible,
            counter      = GUI.CounterVisible,
            dmgIndicator = GUI.DmgIndicatorEnabled,
            deathLog     = DEATHLOG.Enabled,
            actorEsp     = ACTOR_ESP.Enabled,
        },
        ores = oresOn,
        titan = {
            mode           = TITAN.Mode,
            showNameTag    = TITAN.ShowNameTag,
            showJointDots  = TITAN.ShowJointDots,
            showHeadCircle = TITAN.ShowHeadCircle,
            fontIndex      = TITAN.FontIndex,
            colorIndex     = TITAN.ColorIndex,
        },
        animal = {
            fontIndex  = ANIMAL.FontIndex,
            colorIndex = ANIMAL.ColorIndex,
        },
        panels = {
            healthBarX  = GUI.HealthBarX,
            healthBarY  = GUI.HealthBarY,
            counterX    = GUI.CounterX,
            counterY    = GUI.CounterY,
            playerListX = GUI.PlayerListX,
            playerListY = GUI.PlayerListY,
        },
    }
    task.spawn(function()
        pcall(function()
            if type(makefolder) == "function" and type(isfolder) == "function"
               and not isfolder(CONFIG_DIR) then
                makefolder(CONFIG_DIR)
            end
            writefile(CONFIG_PATH, HttpService:JSONEncode(data))
        end)
    end)
end

loadConfig = function()
    if type(readfile) ~= "function" or type(isfile) ~= "function" then return end
    if not isfile(CONFIG_PATH) then return end
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not (ok and raw) then return end
    local okJ, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not (okJ and type(data) == "table") then return end

    if type(data.binds) == "table" then
        if type(data.binds.toggle)     == "number" then GUI.ToggleKey     = data.binds.toggle     end
        if type(data.binds.close)      == "number" then GUI.CloseKey      = data.binds.close      end
        if type(data.binds.playerList) == "number" then GUI.PlayerListKey = data.binds.playerList end
        if type(data.binds.playerEsp)  == "number" then GUI.PlayerEspKey  = data.binds.playerEsp  end
    end
    if type(data.settings) == "table" then
        if type(data.settings.maxDistance) == "number" then
            local v = data.settings.maxDistance
            ESP.MaxDistance       = v
            MARCS.MaxDistance     = v
            GEAR.MaxDistance      = v
            RESUPPLY.MaxDistance  = v
            FLINTLOCK.MaxDistance = v
            TITAN.MaxDistance     = v
            ANIMAL.MaxDistance    = v
            PLAYER_ESP.MaxDistance = v
        end
        if type(data.settings.dmgIndicatorRadius) == "number" then
            GUI.DmgIndicatorRadius = data.settings.dmgIndicatorRadius
        end
    end
    if type(data.features) == "table" then
        local f = data.features
        if type(f.marcs)        == "boolean" then MARCS.Enabled            = f.marcs        end
        if type(f.gear)         == "boolean" then GEAR.Enabled             = f.gear         end
        if type(f.resupply)     == "boolean" then RESUPPLY.Enabled         = f.resupply     end
        if type(f.flintlock)    == "boolean" then FLINTLOCK.Enabled        = f.flintlock    end
        if type(f.titan)        == "boolean" then TITAN.Enabled            = f.titan        end
        if type(f.animal)       == "boolean" then ANIMAL.Enabled           = f.animal       end
        if type(f.playerEsp)    == "boolean" then PLAYER_ESP.Enabled       = f.playerEsp    end
        if type(f.plAutoUpdate) == "boolean" then GUI.PLAutoUpdate         = f.plAutoUpdate end
        if type(f.healthBar)    == "boolean" then GUI.HealthBarVisible     = f.healthBar    end
        if type(f.counter)      == "boolean" then GUI.CounterVisible       = f.counter      end
        if type(f.dmgIndicator) == "boolean" then GUI.DmgIndicatorEnabled  = f.dmgIndicator end
        if type(f.actorEsp)     == "boolean" then ACTOR_ESP.Enabled        = f.actorEsp     end
        if type(f.deathLog)     == "boolean" then
            DEATHLOG.Enabled    = f.deathLog
            -- Re-seed so ragdolls already on the ground when the script
            -- (re-)launches don't fire as if they just died.
            DEATHLOG.Seeded     = false
            DEATHLOG.NextPollAt = 0
            DEATHLOG.Pending    = {}
        end
    end
    if type(data.ores) == "table" then
        for _, ore in ipairs(ORE_LIST) do
            if type(data.ores[ore.Name]) == "boolean" then
                ore.Enabled = data.ores[ore.Name]
            end
        end
    end
    if type(data.titan) == "table" then
        if data.titan.mode == "Bones" or data.titan.mode == "Wireframe" then TITAN.Mode = data.titan.mode end
        if type(data.titan.showNameTag)    == "boolean" then TITAN.ShowNameTag    = data.titan.showNameTag    end
        if type(data.titan.showJointDots)  == "boolean" then TITAN.ShowJointDots  = data.titan.showJointDots  end
        if type(data.titan.showHeadCircle) == "boolean" then TITAN.ShowHeadCircle = data.titan.showHeadCircle end
        if type(data.titan.fontIndex)      == "number"  and TITAN_FONTS[data.titan.fontIndex]           then TITAN.FontIndex  = data.titan.fontIndex  end
        if type(data.titan.colorIndex)     == "number"  and TITAN_COLOR_PRESETS[data.titan.colorIndex]  then TITAN.ColorIndex = data.titan.colorIndex end
    end
    if type(data.animal) == "table" then
        if type(data.animal.fontIndex)  == "number" and TITAN_FONTS[data.animal.fontIndex]          then ANIMAL.FontIndex  = data.animal.fontIndex  end
        if type(data.animal.colorIndex) == "number" and TITAN_COLOR_PRESETS[data.animal.colorIndex] then ANIMAL.ColorIndex = data.animal.colorIndex end
    end
    if type(data.panels) == "table" then
        if type(data.panels.healthBarX)  == "number" then GUI.HealthBarX  = data.panels.healthBarX  end
        if type(data.panels.healthBarY)  == "number" then GUI.HealthBarY  = data.panels.healthBarY  end
        if type(data.panels.counterX)    == "number" then GUI.CounterX    = data.panels.counterX    end
        if type(data.panels.counterY)    == "number" then GUI.CounterY    = data.panels.counterY    end
        if type(data.panels.playerListX) == "number" then GUI.PlayerListX = data.panels.playerListX end
        if type(data.panels.playerListY) == "number" then GUI.PlayerListY = data.panels.playerListY end
    end

    -- Re-apply derived state for things that read from the config tables
    pcall(function() if titanApplyColor  then titanApplyColor()  end end)
    pcall(function() if titanApplyFont   then titanApplyFont()   end end)
    pcall(function() if animalApplyColor then animalApplyColor() end end)
    pcall(function() if animalApplyFont  then animalApplyFont()  end end)

    -- Re-build dependent panels so they reflect the loaded state
    if GUI.HealthBarVisible then BuildHealthBar() else ClearHealthBar() end
    if GUI.CounterVisible   then BuildCounterPanel() end
end

-- Restores every persisted setting + bind + feature flag to its
-- in-source default and writes that out as the new on-disk config.
resetConfigToDefaults = function()
    GUI.ToggleKey     = 0x72   -- F3
    GUI.CloseKey      = 0x23   -- End
    GUI.PlayerListKey = 0x63   -- Numpad3
    GUI.PlayerEspKey  = 0x70   -- F1

    ESP.MaxDistance       = 50000
    MARCS.MaxDistance     = 50000
    GEAR.MaxDistance      = 50000
    RESUPPLY.MaxDistance  = 50000
    FLINTLOCK.MaxDistance = 50000
    TITAN.MaxDistance     = 5000
    ANIMAL.MaxDistance    = 5000
    PLAYER_ESP.MaxDistance = 5000
    GUI.DmgIndicatorRadius = 25

    MARCS.Enabled            = false
    GEAR.Enabled             = false
    RESUPPLY.Enabled         = false
    FLINTLOCK.Enabled        = false
    TITAN.Enabled            = false
    ANIMAL.Enabled           = false
    PLAYER_ESP.Enabled       = false
    ACTOR_ESP.Enabled        = false
    GUI.PLAutoUpdate         = false
    GUI.HealthBarVisible     = false
    GUI.CounterVisible       = false
    GUI.DmgIndicatorEnabled  = false
    DEATHLOG.Enabled         = false
    DEATHLOG.Seeded          = false
    DEATHLOG.Pending         = {}
    DEATHLOG.NextPollAt      = 0

    for _, ore in ipairs(ORE_LIST) do ore.Enabled = false end

    TITAN.Mode           = "Bones"
    TITAN.ShowNameTag    = false
    TITAN.ShowJointDots  = false
    TITAN.ShowHeadCircle = false
    TITAN.FontIndex      = 2
    TITAN.ColorIndex     = 1
    ANIMAL.FontIndex     = 2
    ANIMAL.ColorIndex    = 2

    pcall(function() titanApplyColor()  end)
    pcall(function() titanApplyFont()   end)
    pcall(function() animalApplyColor() end)
    pcall(function() animalApplyFont()  end)

    ClearHealthBar()
    for _, el in ipairs(GUI.CounterElements) do pcall(function() el:Remove() end) end
    GUI.CounterElements = {}
    GUI.CounterGasText = nil
    GUI.CounterBladeText = nil
    GUI.CounterTitanText = nil

    pcall(saveConfig)
end

-- ============================================================
-- START
-- ============================================================

-- Load saved config BEFORE Init() so the first paint reflects on-disk state
pcall(loadConfig)

-- NOTE: we intentionally do NOT auto-load the RS snapshot here.
-- The decode pass for a large saved snapshot is single-threaded and
-- noticeably stalls startup. Users now load it explicitly via the
-- "Load Saved" button in the RS Diff panel.

Init()

-- Pre-fetch player data
GUI.PLCachedPlayers = ReadPlayerData()

-- Initial scans deferred to ESPLoop when features are first enabled
spawn(InputLoop)
spawn(ESPLoop)
spawn(DmgIndicatorLoop)

-- Expose GUI globally so debug.lua can access it
pcall(function() getgenv().GUI = GUI end)

print("Requiem loaded! " .. GetKeyName(GUI.ToggleKey) .. " = toggle. " .. GetKeyName(GUI.CloseKey) .. " = unload.")
notify("Requiem", "Loaded! " .. GetKeyName(GUI.ToggleKey) .. " to toggle", 3)

return GUI
