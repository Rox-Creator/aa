-- CONTENT DISPATCHER
-- ============================================================

CreateContent = function(pageName)
    -- Bail if the menu is currently hidden. Stale animation
    -- coroutines (animateToggle) can fire their onDone after F3 has
    -- hidden the GUI — without this guard those callbacks rebuild
    -- visible content over a "hidden" menu and the panel appears to
    -- linger until the user toggles twice.
    if not GUI.Visible then
        ClearContent()
        return
    end
    ClearContent()
    CreateSubTabs()

    if pageName == "ESPs" then
        if GUI.SubTab == "Elements" then
            PageESPsElements()
        else
            PageESPsStyle()
        end
    elseif pageName == "Logs" then
        PageLogs()
    elseif pageName == "Tools" then
        PageTools()
    elseif pageName == "Settings" then
        PageSettings()
    end

    -- Update footer hint
    if GUI.HintText then
        GUI.HintText.Text = GetKeyName(GUI.ToggleKey) .. " Toggle | " .. GetKeyName(GUI.CloseKey) .. " Unload"
    end
end

-- ============================================================
-- NAV BUTTONS (horizontal header tabs)
-- ============================================================

-- Approximate per-character width for the nav text (size 18, SF System /
-- SystemBold). Used to size the active-tab underline to match the actual
-- text length so "Settings" gets a wider underline than "ESPs".
local NAV_CHAR_W = 10

-- Returns (leftX, rightX) for `btn`'s underline. Spans from the dot's
-- left edge all the way to the end of the text so the underline reads as
-- belonging to the WHOLE "● Settings" combo, not just the text. The
-- horizontal center of this range then lines up with the visual center
-- of the dot + text label.
local function navUnderlineBounds(btn)
    -- Dot center is at btn.X + NavDotOffsetX (=3), radius 4 → left edge at
    -- btn.X - 1. Text starts at btn.X + 14 and ends at btn.X + 14 + textW.
    local dotLeft   = btn.X - 1
    local textRight = btn.X + 14 + #btn.Name * NAV_CHAR_W
    return dotLeft, textRight
end

-- Click/hover hitbox for `btn`. Matches the visible dot+text bounds with
-- a small pad so the cursor can land right at the edge without missing.
-- The old hitbox was the full 150px tabSpacing — that meant clicking in
-- the empty gap between two tabs registered as the left tab.
local NAV_HIT_PAD = 6
local function navHitBounds(btn)
    local l, r = navUnderlineBounds(btn)
    return l - NAV_HIT_PAD, btn.Y, (r - l) + NAV_HIT_PAD * 2, btn.H
end

CreateNavButtons = function()
    GUI.NavButtons = {}
    local startX = Config.WinX + 110 + GUI.NavOffsetX
    local tabSpacing = 150
    local tabY = Config.WinY + GUI.NavOffsetY

    for i, name in ipairs(NavDefs) do
        local btn = {}
        btn.Name = name
        btn.X = startX + (i - 1) * tabSpacing
        btn.Y = tabY
        btn.W = tabSpacing
        btn.H = Config.HeaderH

        -- Dot before text
        btn.Dot = Drawing.new("Circle")
        btn.Dot.Position = Vector2.new(btn.X + GUI.NavDotOffsetX, tabY + Config.HeaderH / 2 + GUI.NavDotOffsetY)
        btn.Dot.Radius = 4
        btn.Dot.Color = Colors.NavNormal
        btn.Dot.Filled = true
        btn.Dot.NumSides = 12
        btn.Dot.Visible = true
        btn.Dot.ZIndex = 7
        table.insert(GUI.Elements, btn.Dot)

        -- Tab text
        btn.Text = Drawing.new("Text")
        btn.Text.Position = Vector2.new(btn.X + 14, tabY + Config.HeaderH / 2 - 8)
        btn.Text.Text = name
        btn.Text.Color = Colors.NavNormal
        btn.Text.Size = 18
        btn.Text.Font = Drawing.Fonts.System
        btn.Text.Center = false
        btn.Text.Outline = false
        btn.Text.Visible = true
        btn.Text.ZIndex = 7
        table.insert(GUI.Elements, btn.Text)

        GUI.NavButtons[i] = btn
    end

    -- Single persistent underline that slides between tabs. Lives in
    -- GUI.Elements (with the header) so MoveWindow drags it along, and
    -- so it stays put across CreateContent() rebuilds.
    local underlineY = tabY + Config.HeaderH - 2
    local activeBtn
    for _, b in ipairs(GUI.NavButtons) do
        if b.Name == GUI.SelectedPage then activeBtn = b; break end
    end
    activeBtn = activeBtn or GUI.NavButtons[1]
    local leftX, rightX = navUnderlineBounds(activeBtn)

    local under = Drawing.new("Line")
    under.From = Vector2.new(leftX,  underlineY)
    under.To   = Vector2.new(rightX, underlineY)
    under.Color = Colors.AccentRed
    under.Thickness = 2
    under.Visible = true
    under.ZIndex = 7
    table.insert(GUI.Elements, under)
    GUI.MainTabUnderline = under
end

-- Tween the main-tab underline from its current bounds to the given
-- target tab's bounds over ~180ms with cubic ease-out. Left and right
-- edges are interpolated independently so the underline both slides
-- AND grows/shrinks to match the target text width.
local function animateMainTabUnderline(toBtn, onDone)
    local under = GUI.MainTabUnderline
    if not (under and toBtn) then
        if onDone then onDone() end
        return
    end
    local fromL, fromR, fromY
    pcall(function() fromL = under.From.X end)
    pcall(function() fromR = under.To.X end)
    pcall(function() fromY = under.From.Y end)
    local toL, toR = navUnderlineBounds(toBtn)
    local lineY    = fromY or (toBtn.Y + Config.HeaderH - 2)
    fromL = fromL or toL
    fromR = fromR or toR
    local token = newAnimToken()
    task.spawn(function()
        local steps = 10
        for s = 1, steps do
            if not isAnimCurrent(token) then return end
            local t = s / steps
            local et = 1 - (1 - t) ^ 3
            local lx = fromL + (toL - fromL) * et
            local rx = fromR + (toR - fromR) * et
            pcall(function()
                under.From = Vector2.new(lx, lineY)
                under.To   = Vector2.new(rx, lineY)
            end)
            task.wait(0.018)
        end
        if onDone then pcall(onDone) end
    end)
end

-- Cache the visual state per button so we only touch Drawing instances
-- on state transitions. Avoids re-setting Color/Font every frame, and
-- gives us a hook to tween color changes if we want to later.
UpdateNavButton = function(btn, isSelected, isHovered)
    local state = isSelected and "active" or (isHovered and "hover" or "normal")
    if btn._navState == state then return end
    btn._navState = state
    if state == "active" then
        btn.Dot.Color  = Colors.AccentRed
        btn.Text.Color = Colors.NavActive
        btn.Text.Font  = Drawing.Fonts.SystemBold
    elseif state == "hover" then
        btn.Dot.Color  = Colors.AccentDim
        btn.Text.Color = Colors.TextPrimary
        btn.Text.Font  = Drawing.Fonts.System
    else
        btn.Dot.Color  = Colors.TextMuted
        btn.Text.Color = Colors.NavNormal
        btn.Text.Font  = Drawing.Fonts.System
    end
end

