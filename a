CreateSubTabs = function()
    ClearSubTabs()
    if GUI.SelectedPage ~= "ESPs" then return end

    local barY = Config.WinY + Config.HeaderH
    local zb = 8
    local halfW = Config.WinW / 2

    -- Elements tab zone = left half, Style tab zone = right half
    local elemCenterX = Config.WinX + halfW * 0.5
    local styleCenterX = Config.WinX + halfW + halfW * 0.5
    local tabTextY = barY + 8 + GUI.SubTabOffsetY

    -- Red glow background for selected tab. Reuses one Square (kept in
    -- GUI.SubTabGlow) so the sub-tab click handler can slide it across
    -- to the new tab before the rebuild snaps it into place.
    do
        local glowX = (GUI.SubTab == "Style") and (Config.WinX + halfW) or Config.WinX
        local glow = Drawing.new("Square")
        glow.Position = Vector2.new(glowX, barY)
        glow.Size = Vector2.new(halfW, Config.SubTabH)
        glow.Color = Colors.AccentRed
        glow.Filled = true
        glow.Transparency = 0.12
        glow.Visible = true
        glow.ZIndex = zb
        table.insert(GUI.SubTabElements, glow)
        GUI.SubTabGlow = glow
    end

    -- "Elements" label
    local elemText = Drawing.new("Text")
    elemText.Position = Vector2.new(elemCenterX, tabTextY)
    elemText.Text = "Elements"
    elemText.Color = GUI.SubTab == "Elements" and Colors.TextPrimary or Colors.TextMuted
    elemText.Size = 16
    elemText.Font = GUI.SubTab == "Elements" and Drawing.Fonts.SystemBold or Drawing.Fonts.System
    elemText.Center = true
    elemText.Outline = false
    elemText.Visible = true
    elemText.ZIndex = zb + 1
    table.insert(GUI.SubTabElements, elemText)

    -- "Style" label
    local styleText = Drawing.new("Text")
    styleText.Position = Vector2.new(styleCenterX, tabTextY)
    styleText.Text = "Style"
    styleText.Color = GUI.SubTab == "Style" and Colors.TextPrimary or Colors.TextMuted
    styleText.Size = 16
    styleText.Font = GUI.SubTab == "Style" and Drawing.Fonts.SystemBold or Drawing.Fonts.System
    styleText.Center = true
    styleText.Outline = false
    styleText.Visible = true
    styleText.ZIndex = zb + 1
    table.insert(GUI.SubTabElements, styleText)

    -- Single persistent underline that slides between sub-tabs. Cached on
    -- GUI.SubTabUnderline so the click handler can grab it and tween.
    do
        local underX = (GUI.SubTab == "Style") and (Config.WinX + halfW) or Config.WinX
        local underline = Drawing.new("Line")
        underline.From = Vector2.new(underX + 1, barY + Config.SubTabH - 2)
        underline.To   = Vector2.new(underX + halfW - 1, barY + Config.SubTabH - 2)
        underline.Color = Colors.AccentRed
        underline.Thickness = 2
        underline.Visible = true
        underline.ZIndex = zb + 2
        table.insert(GUI.SubTabElements, underline)
        GUI.SubTabUnderline = underline
    end

    -- Slide the cached glow + underline from old sub-tab to new, then
    -- trigger the rebuild + content fade-in. Same shape as
    -- animateMainTabUnderline but inlined here because it touches two
    -- elements (glow + line) and uses zone-based positioning.
    local function animateSubTabSwitch(newName)
        local under = GUI.SubTabUnderline
        local glow  = GUI.SubTabGlow
        local toX = (newName == "Style") and (Config.WinX + halfW) or Config.WinX
        local fromX = (GUI.SubTab == "Style") and (Config.WinX + halfW) or Config.WinX
        local lineY = barY + Config.SubTabH - 2
        GUI.SubTab = newName
        if not (under or glow) then
            CreateContent(GUI.SelectedPage)
            return
        end
        local token = newAnimToken()
        task.spawn(function()
            local steps = 10
            for s = 1, steps do
                if not isAnimCurrent(token) then return end
                local t = s / steps
                local et = 1 - (1 - t) ^ 3
                local zx = fromX + (toX - fromX) * et
                if under then
                    pcall(function()
                        under.From = Vector2.new(zx + 1, lineY)
                        under.To   = Vector2.new(zx + halfW - 1, lineY)
                    end)
                end
                if glow then
                    pcall(function() glow.Position = Vector2.new(zx, barY) end)
                end
                task.wait(0.018)
            end
            CreateContent(GUI.SelectedPage)
        end)
    end

    -- Clickable regions (full half-width each)
    table.insert(GUI.SubTabClickables, {
        x = Config.WinX, y = barY,
        w = halfW, h = Config.SubTabH,
        onClick = function()
            if GUI.SubTab ~= "Elements" then animateSubTabSwitch("Elements") end
        end
    })
    table.insert(GUI.SubTabClickables, {
        x = Config.WinX + halfW, y = barY,
        w = halfW, h = Config.SubTabH,
        onClick = function()
            if GUI.SubTab ~= "Style" then animateSubTabSwitch("Style") end
        end
    })
end

