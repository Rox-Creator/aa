local function ReadPlayerData()
    local players = {}
    pcall(function()
        for _, player in pairs(game:GetService("Players"):GetChildren()) do
            pcall(function()
                local data = {
                    Name = player.Name,
                    DisplayName = player.Name,
                    Health = 100, Dead = false,
                    Branch = 0, Rank = 0, StaffState = 0,
                }
                -- Try attributes first
                pcall(function()
                    local n = player:GetAttribute("Name")
                    if n and tostring(n) ~= "" then data.DisplayName = tostring(n) end
                    data.Health = tonumber(player:GetAttribute("Health")) or 100
                    data.Dead = player:GetAttribute("Dead") == true
                    data.Branch = tonumber(player:GetAttribute("Branch")) or 0
                    data.Rank = tonumber(player:GetAttribute("Rank")) or 0
                    data.StaffState = tonumber(player:GetAttribute("StaffState")) or 0
                end)
                -- Override from children (NumberValue/BoolValue/StringValue)
                pcall(function()
                    for _, child in pairs(player:GetChildren()) do
                        local n = child.Name
                        if n == "Name" then
                            local v = nil
                            pcall(function() v = child.Value end)
                            if v and tostring(v) ~= "" then data.DisplayName = tostring(v) end
                        elseif n == "Health" then data.Health = tonumber(child.Value) or data.Health
                        elseif n == "Dead" then data.Dead = child.Value == true
                        elseif n == "Branch" then data.Branch = tonumber(child.Value) or data.Branch
                        elseif n == "Rank" then data.Rank = tonumber(child.Value) or data.Rank
                        elseif n == "StaffState" then data.StaffState = tonumber(child.Value) or data.StaffState
                        end
                    end
                end)
                table.insert(players, data)
            end)
        end
    end)
    return players
end

