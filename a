local function readPlayerHpFast(player)
    local hp, maxHp = 100, 100
    local sawMax = false
    pcall(function()
        local h = player:GetAttribute("Health")
        if h then hp = tonumber(h) or hp end
        local m = player:GetAttribute("Maximum health")
        if not m then m = player:GetAttribute("MaxHealth") end
        if not m then m = player:GetAttribute("MaximumHealth") end
        if m then maxHp = tonumber(m) or maxHp; sawMax = true end
    end)
    if not sawMax then
        pcall(function()
            local char = player.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    local m = tonumber(hum.MaxHealth)
                    if m and m > 0 then maxHp = m; sawMax = true end
                    local h = tonumber(hum.Health)
                    if h then hp = h end
                end
            end
        end)
    end
    if not sawMax then maxHp = math.max(100, hp) end
    if maxHp <= 0 then maxHp = 100 end
    if hp < 0 then hp = 0 end
    if hp > maxHp then hp = maxHp end
    return hp, maxHp
end

local function playerEspUpdate()
    if not PLAYER_ESP.Enabled then
        for _, data in pairs(PLAYER_ESP.Objects) do
            data.nameTag.Visible = false
            data.tagBase.Visible = false
            data.branchTag.Visible = false
            data.hpTag.Visible = false
        end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end

    for id, data in pairs(PLAYER_ESP.Objects) do
        local player = data.player
        local hide = false

        if not player or not player.Parent then
            hide = true
        else
            local char = nil
            pcall(function() char = player.Character end)
            if not char then
                hide = true
            else
                local hrp = char:FindFirstChild("HumanoidRootPart")
                    or char:FindFirstChild("Torso")
                    or char:FindFirstChild("UpperTorso")
                    or char:FindFirstChild("Head")
                if not hrp then
                    hide = true
                else
                    local pos = nil
                    pcall(function() pos = hrp.Position end)
                    if not pos then
                        hide = true
                    else
                        local dx = playerPos.X - pos.X
                        local dy = playerPos.Y - pos.Y
                        local dz = playerPos.Z - pos.Z
                        local dist = math.sqrt(dx*dx + dy*dy + dz*dz)
                        if dist > PLAYER_ESP.MaxDistance then
                            hide = true
                        else
                            local headTop = Vector3.new(pos.X, pos.Y + 3, pos.Z)
                            local screenPos, onScreen = WorldToScreen(headTop)
                            if not (screenPos and onScreen) then
                                hide = true
                            else
                                local hp, maxHp = readPlayerHpFast(player)
                                local branch = nil
                                pcall(function() branch = tonumber(player:GetAttribute("Branch")) end)
                                local btInfo = branch and BRANCH_ESP_TAGS[branch] or nil
                                local approxChar = PLAYER_ESP.TextSize * 0.55
                                local nameW = #player.Name * approxChar
                                local nameY = screenPos.Y - 40
                                if btInfo then
                                    -- Base text "[XX]" rendered in white; colored "XX" overlay
                                    -- sits on top of the inner letters. bracketAdvance is the
                                    -- offset from the base's left edge to where the inner
                                    -- letters start (i.e. width of "[" glyph in this font).
                                    local tagStr = "[" .. btInfo.abbrev .. "]"
                                    local bracketAdvance = PLAYER_ESP.TextSize * 0.30
                                    local tagW = #tagStr * approxChar
                                    local gap = approxChar * -0.3
                                    local totalW = tagW + gap + nameW
                                    local leftX = screenPos.X - totalW / 2
                                    data.tagBase.Position = Vector2.new(leftX, nameY)
                                    data.tagBase.Text = tagStr
                                    data.tagBase.Visible = true
                                    data.branchTag.Position = Vector2.new(leftX + bracketAdvance, nameY)
                                    data.branchTag.Text = btInfo.abbrev
                                    data.branchTag.Color = btInfo.color
                                    data.branchTag.Visible = true
                                    data.nameTag.Position = Vector2.new(leftX + tagW + gap, nameY)
                                else
                                    data.tagBase.Visible = false
                                    data.branchTag.Visible = false
                                    data.nameTag.Position = Vector2.new(screenPos.X - nameW / 2, nameY)
                                end
                                data.nameTag.Text = player.Name
                                data.nameTag.Visible = true
                                data.hpTag.Position = Vector2.new(screenPos.X, screenPos.Y - 10)
                                data.hpTag.Text = "(" .. tostring(math.floor(hp + 0.5)) .. " / " .. tostring(math.floor(maxHp + 0.5)) .. ")"
                                data.hpTag.Visible = true
                            end
                        end
                    end
                end
            end
        end

        if hide then
            data.nameTag.Visible = false
            data.tagBase.Visible = false
            data.branchTag.Visible = false
            data.hpTag.Visible = false
        end
    end
end

