-- ============================================================
-- REPLICATED STORAGE DIFF
-- ============================================================
-- Snapshot every descendant of game.ReplicatedStorage into a flat
-- path → summary table, then diff a fresh snapshot against the
-- stored one to surface added / removed / class-changed paths.
--
-- Stored summary per path:
--   { class = "ModuleScript" }
--
-- We deliberately only record the instance tree (name + class). No
-- attributes, no source code, no ValueBase values — just the shape
-- and types of what lives in ReplicatedStorage. This catches new
-- files / removed files / replaced files (where a script becomes a
-- folder or similar) and keeps the snapshot cheap to capture, save,
-- load, and compare.

-- Names (case-insensitive) to skip during the walk. These folders
-- get touched constantly by the game's per-player runtime, which
-- spams the diff with noise that isn't useful for "what did the
-- update change?" — so we drop them at the recursion boundary.
-- The path itself isn't recorded, AND we don't descend into the
-- subtree.
-- Full-path matches (case-insensitive). When the walk is about to
-- record a node whose path matches one of these, we skip it entirely:
-- the node itself isn't recorded AND we don't descend into its
-- subtree. Paths are anchored at "ReplicatedStorage" — the walk's
-- root prefix — not "game.ReplicatedStorage".
local RS_IGNORE_PATHS = {
    -- Runtime / per-player churn
    ["replicatedstorage.cache"]                   = true,
    ["replicatedstorage.players"]                 = true,
    ["replicatedstorage.assets.titans.hitboxes"]  = true,

    -- Editor / engine state
    ["replicatedstorage.lightingeditorcolordata"] = true,
    ["replicatedstorage.animationgrapheditor"]    = true,
    ["replicatedstorage.track"]                   = true,
    ["replicatedstorage.packages"]                = true,

    -- Assets buckets (huge static trees that don't change between updates)
    ["replicatedstorage.assets.prefabs"]          = true,
    ["replicatedstorage.assets.objects"]          = true,
    ["replicatedstorage.assets.attachables"]      = true,
    ["replicatedstorage.assets.generation"]       = true,
    ["replicatedstorage.assets.emotes"]           = true,
    ["replicatedstorage.assets.gore"]             = true,
    ["replicatedstorage.assets.customs"]          = true,
    ["replicatedstorage.assets.accessories"]      = true,
    ["replicatedstorage.assets.chat"]             = true,
    ["replicatedstorage.assets.gear"]             = true,
    ["replicatedstorage.assets.meshes"]           = true,
}

TakeRSSnapshot = function()
    local snap = {}
    local count = 0
    local rs = nil
    pcall(function() rs = game:GetService("ReplicatedStorage") end)
    if not rs then return snap, 0 end

    -- Recursive walk with a depth limit. ReplicatedStorage can be
    -- huge in some games — limit to 8 levels deep and budget the
    -- walk on a counter so a runaway tree can't freeze the VM.
    local MAX_DEPTH   = 8
    local MAX_NODES   = 20000
    local visited     = 0

    local function walk(node, prefix, depth)
        if depth > MAX_DEPTH or visited > MAX_NODES then return end
        local kids = nil
        pcall(function() kids = node:GetChildren() end)
        if not kids then return end
        for _, c in ipairs(kids) do
            visited = visited + 1
            if visited > MAX_NODES then return end

            local nm, cls
            pcall(function() nm = c.Name end)
            pcall(function() cls = c.ClassName end)
            if nm and cls then
                local path = prefix .. "." .. nm
                if not RS_IGNORE_PATHS[path:lower()] then
                    snap[path] = { class = cls }
                    count = count + 1
                    walk(c, path, depth + 1)
                end
            end
        end
    end
    walk(rs, "ReplicatedStorage", 0)

    return snap, count
end

CompareRSSnapshots = function(old, new)
    -- Diff result is a flat list so the UI can render it sequentially.
    -- kind ∈ { "ADD", "DEL", "CLS" }
    local results = {}

    -- Additions + class changes on existing paths
    for path, info in pairs(new) do
        local prev = old[path]
        if prev == nil then
            table.insert(results, { kind = "ADD", path = path,
                detail = "(" .. info.class .. ")" })
        elseif prev.class ~= info.class then
            table.insert(results, { kind = "CLS", path = path,
                detail = prev.class .. " -> " .. info.class })
        end
    end

    -- Removals
    for path, info in pairs(old) do
        if new[path] == nil then
            table.insert(results, { kind = "DEL", path = path,
                detail = "(" .. info.class .. ")" })
        end
    end

    -- Sort: kind priority (ADD, DEL, CLS) then path
    local kindRank = { ADD = 1, DEL = 2, CLS = 3 }
    table.sort(results, function(a, b)
        local ra = kindRank[a.kind] or 9
        local rb = kindRank[b.kind] or 9
        if ra ~= rb then return ra < rb end
        return a.path < b.path
    end)
    return results
end

-- Hand-rolled JSON escape + encoder for the snapshot. HttpService:JSONEncode
-- in Matcha has been observed to choke on large mixed-string-key tables
-- with control bytes / odd characters (instance names can contain
-- anything). Since our schema is fixed and shallow, a small purpose-
-- built encoder is bulletproof and faster than the generic one.
local function rsJsonEscape(s)
    s = tostring(s)
    s = s:gsub("\\", "\\\\"):gsub('"', '\\"')
    -- escape every control char (0x00-0x1F) plus DEL (0x7F) as \uXXXX
    s = s:gsub("[%z\1-\31\127]", function(c)
        return string.format("\\u%04x", c:byte())
    end)
    return '"' .. s .. '"'
end

local function rsEncodeSnapshot(payload)
    -- Shape: { paths = { [path] = { class } }, count = N, savedAt = N }
    -- Single table.concat at end so we don't allocate O(n²) strings.
    local parts = { '{"paths":{' }
    local first = true
    for path, info in pairs(payload.paths or {}) do
        if not first then parts[#parts + 1] = "," end
        first = false
        parts[#parts + 1] = rsJsonEscape(path)
        parts[#parts + 1] = ':{"class":'
        parts[#parts + 1] = rsJsonEscape(info.class or "")
        parts[#parts + 1] = "}"
    end
    parts[#parts + 1] = '},"count":'
    parts[#parts + 1] = tostring(tonumber(payload.count) or 0)
    parts[#parts + 1] = ',"savedAt":'
    parts[#parts + 1] = tostring(tonumber(payload.savedAt) or 0)
    parts[#parts + 1] = "}"
    return table.concat(parts)
end

-- Persist the current snapshot to disk so it survives script
-- unload / game restarts. Uses the hand-rolled encoder (safe for
-- weird instance names with control chars), with HttpService as a
-- fallback in case rsEncodeSnapshot itself ever throws. savedAt is
-- os.time() (Unix epoch seconds) so the "X minutes ago" status
-- works across runs — tick() resets every reload.
--
-- Now with end-to-end verification: after the write, we re-read
-- the file with isfile()+readfile() and confirm the byte count
-- matches what we wrote. If anything went sideways (write
-- silently dropped, wrong working dir, etc.) the user gets a
-- specific error in the status line instead of a misleading
-- "Snapshot saved" message.
local function saveRSSnapshot()
    if type(writefile) ~= "function" then return false, "writefile not available" end
    if not GUI.RSSnapshot then return false, "no snapshot in memory" end
    local payload = {
        paths   = GUI.RSSnapshot,
        count   = GUI.RSSnapshotCount,
        savedAt = (function() local ok, t = pcall(os.time); return ok and t or 0 end)(),
    }
    local okJ, encoded = pcall(rsEncodeSnapshot, payload)
    if not okJ then
        local okH, enc2 = pcall(function() return HttpService:JSONEncode(payload) end)
        if not okH then return false, "encode failed: " .. tostring(encoded) end
        encoded = enc2
    end
    if type(encoded) ~= "string" or #encoded == 0 then
        return false, "encoder produced empty string"
    end

    -- Make sure the config folder exists. If makefolder isn't
    -- available we still try the write — some executors auto-create.
    pcall(function()
        if type(makefolder) == "function" and type(isfolder) == "function"
           and not isfolder(CONFIG_DIR) then
            makefolder(CONFIG_DIR)
        end
    end)

    local okW, werr = pcall(writefile, RS_SNAPSHOT_PATH, encoded)
    if not okW then return false, "writefile threw: " .. tostring(werr) end

    -- Verify the file actually landed on disk with the right size.
    -- This is what catches "writefile returned success but nothing
    -- was actually written" — usually a working-directory mismatch
    -- between the executor and the snapshot path.
    if type(isfile) == "function" then
        local exists = false
        pcall(function() exists = isfile(RS_SNAPSHOT_PATH) end)
        if not exists then
            return false, "post-write isfile() reports missing — check writefile working dir"
        end
    end
    if type(readfile) == "function" then
        local okR, back = pcall(readfile, RS_SNAPSHOT_PATH)
        if okR and type(back) == "string" then
            if #back ~= #encoded then
                return false, string.format("wrote %d bytes, file has %d", #encoded, #back)
            end
        end
    end

    print(string.format("[RS Diff] saved snapshot: %d paths, %d bytes -> %s",
        GUI.RSSnapshotCount or 0, #encoded, RS_SNAPSHOT_PATH))
    return true
end

-- Purpose-built decoder for the exact schema rsEncodeSnapshot writes.
-- HttpService:JSONDecode in Matcha has been observed to return tables
-- where nested object values come back as userdata / proxy objects
-- (type(data.paths) ~= "table" even though the JSON is valid), which
-- broke load across reloads. This decoder reads the file straight and
-- never goes through HttpService, so the shape is guaranteed.
--
-- Grammar handled (exactly what the encoder produces):
--   { "paths": { "<path>": { "class":"...","attrs":"...","value":"..." }, ... },
--     "count": N, "savedAt": N }
local function rsDecodeJsonString(raw, i)
    -- raw[i] must be '"'. Returns (value, nextIndex).
    if raw:sub(i, i) ~= '"' then return nil, i, "expected '\"' at " .. i end
    i = i + 1
    local buf = {}
    while i <= #raw do
        local c = raw:sub(i, i)
        if c == '"' then
            return table.concat(buf), i + 1
        elseif c == "\\" then
            local nxt = raw:sub(i + 1, i + 1)
            if nxt == '"' or nxt == "\\" or nxt == "/" then
                buf[#buf + 1] = nxt; i = i + 2
            elseif nxt == "n" then buf[#buf + 1] = "\n"; i = i + 2
            elseif nxt == "t" then buf[#buf + 1] = "\t"; i = i + 2
            elseif nxt == "r" then buf[#buf + 1] = "\r"; i = i + 2
            elseif nxt == "b" then buf[#buf + 1] = "\b"; i = i + 2
            elseif nxt == "f" then buf[#buf + 1] = "\f"; i = i + 2
            elseif nxt == "u" then
                local hex = raw:sub(i + 2, i + 5)
                local code = tonumber(hex, 16) or 0
                if code < 128 then
                    buf[#buf + 1] = string.char(code)
                else
                    -- represent as ? to avoid utf8 work; we only escape
                    -- control bytes in the encoder so this rarely fires
                    buf[#buf + 1] = "?"
                end
                i = i + 6
            else
                buf[#buf + 1] = nxt; i = i + 2
            end
        else
            buf[#buf + 1] = c; i = i + 1
        end
    end
    return nil, i, "unterminated string"
end

local function rsSkipWs(raw, i)
    while i <= #raw do
        local c = raw:sub(i, i)
        if c ~= " " and c ~= "\t" and c ~= "\n" and c ~= "\r" then return i end
        i = i + 1
    end
    return i
end

local function rsDecodeSnapshot(raw)
    -- Returns ({ paths=..., count=..., savedAt=... }, nil) or (nil, err).
    local i = rsSkipWs(raw, 1)
    if raw:sub(i, i) ~= "{" then return nil, "root not object" end
    i = i + 1

    local out = { paths = {}, count = 0, savedAt = 0 }

    while true do
        i = rsSkipWs(raw, i)
        if raw:sub(i, i) == "}" then return out end
        local key, ni, err = rsDecodeJsonString(raw, i)
        if not key then return nil, "key parse: " .. tostring(err) end
        i = rsSkipWs(raw, ni)
        if raw:sub(i, i) ~= ":" then return nil, "expected ':' after key " .. key end
        i = rsSkipWs(raw, i + 1)

        if key == "paths" then
            if raw:sub(i, i) ~= "{" then return nil, "paths not object" end
            i = i + 1
            while true do
                i = rsSkipWs(raw, i)
                if raw:sub(i, i) == "}" then i = i + 1; break end
                local pathKey, ni2, perr = rsDecodeJsonString(raw, i)
                if not pathKey then return nil, "path key: " .. tostring(perr) end
                i = rsSkipWs(raw, ni2)
                if raw:sub(i, i) ~= ":" then return nil, "expected ':' after path key" end
                i = rsSkipWs(raw, i + 1)
                if raw:sub(i, i) ~= "{" then return nil, "path value not object" end
                i = i + 1
                local info = {}
                while true do
                    i = rsSkipWs(raw, i)
                    if raw:sub(i, i) == "}" then i = i + 1; break end
                    local fk, ni3, ferr = rsDecodeJsonString(raw, i)
                    if not fk then return nil, "field key: " .. tostring(ferr) end
                    i = rsSkipWs(raw, ni3)
                    if raw:sub(i, i) ~= ":" then return nil, "expected ':' after field key" end
                    i = rsSkipWs(raw, i + 1)
                    local fv, ni4, verr = rsDecodeJsonString(raw, i)
                    if not fv then return nil, "field val: " .. tostring(verr) end
                    info[fk] = fv
                    i = rsSkipWs(raw, ni4)
                    if raw:sub(i, i) == "," then i = i + 1 end
                end
                out.paths[pathKey] = info
                i = rsSkipWs(raw, i)
                if raw:sub(i, i) == "," then i = i + 1 end
            end
        else
            -- numeric scalar (count / savedAt). Read until , or }
            local j = i
            while j <= #raw do
                local c = raw:sub(j, j)
                if c == "," or c == "}" or c == " " or c == "\t" or c == "\n" or c == "\r" then break end
                j = j + 1
            end
            out[key] = tonumber(raw:sub(i, j - 1)) or 0
            i = j
        end

        i = rsSkipWs(raw, i)
        if raw:sub(i, i) == "," then i = i + 1
        elseif raw:sub(i, i) == "}" then return out end
    end
end

-- loadRSSnapshot now uses the purpose-built decoder, falls back to
-- HttpService:JSONDecode only if the custom one fails, and dumps
-- detailed diagnostics so we can see exactly why a load missed.
local function loadRSSnapshot()
    if type(readfile) ~= "function" or type(isfile) ~= "function" then
        print("[RS Diff] load: readfile/isfile not available in this executor")
        return
    end
    local exists = false
    pcall(function() exists = isfile(RS_SNAPSHOT_PATH) end)
    if not exists then
        print("[RS Diff] load: no file at " .. RS_SNAPSHOT_PATH .. " (nothing saved yet, or executor wrote it elsewhere)")
        return
    end
    local ok, raw = pcall(readfile, RS_SNAPSHOT_PATH)
    if not (ok and type(raw) == "string") then
        print("[RS Diff] load: readfile failed -> " .. tostring(raw))
        return
    end
    if #raw == 0 then
        print("[RS Diff] load: file is empty")
        return
    end

    -- Try the hand-rolled decoder first (matches our encoder's exact schema).
    local okD, data = pcall(rsDecodeSnapshot, raw)
    if not okD or type(data) ~= "table" then
        print("[RS Diff] load: custom decoder threw -> " .. tostring(data))
        -- Fall through to HttpService as last resort
        local okJ, data2 = pcall(function() return HttpService:JSONDecode(raw) end)
        if not okJ then
            print("[RS Diff] load: HttpService:JSONDecode also failed -> " .. tostring(data2))
            print("[RS Diff] load: raw head = " .. raw:sub(1, 200))
            return
        end
        data = data2
    end

    if type(data) ~= "table" then
        print("[RS Diff] load: decoded data is " .. type(data) .. ", not a table")
        return
    end
    if type(data.paths) ~= "table" then
        local keys = {}
        for k, _ in pairs(data) do keys[#keys + 1] = tostring(k) end
        print(string.format("[RS Diff] load: data.paths is %s, keys=[%s], head=%s",
            type(data.paths), table.concat(keys, ","), raw:sub(1, 200)))
        return
    end

    -- Sanity check the inner shape — paths entries must be tables.
    local sampleOk, sampleBad = 0, 0
    for _, v in pairs(data.paths) do
        if type(v) == "table" then sampleOk = sampleOk + 1
        else sampleBad = sampleBad + 1 end
        if sampleOk + sampleBad >= 5 then break end
    end
    if sampleOk == 0 then
        print("[RS Diff] load: paths entries are not tables (got " .. (sampleBad > 0 and type(next(data.paths)) or "empty") .. ")")
        return
    end

    GUI.RSSnapshot      = data.paths
    GUI.RSSnapshotCount = tonumber(data.count) or 0
    GUI.RSSnapshotAt    = tonumber(data.savedAt)

    -- Recount if count is missing/wrong — old saves may not have it.
    if GUI.RSSnapshotCount == 0 then
        local n = 0
        for _ in pairs(GUI.RSSnapshot) do n = n + 1 end
        GUI.RSSnapshotCount = n
    end

    print(string.format("[RS Diff] load: restored %d paths from %s",
        GUI.RSSnapshotCount, RS_SNAPSHOT_PATH))
end

-- "5m ago" / "2h ago" / "3d ago" — takes os.time() epoch seconds and
-- formats relative to now. Returns "just now" if delta < 1s, "?"
-- if input is nil.
local function rsTimeAgo(savedAt)
    if not savedAt then return "?" end
    local ok, now = pcall(os.time)
    if not ok then return "?" end
    local d = now - savedAt
    if d < 1   then return "just now" end
    if d < 60  then return d .. "s ago" end
    if d < 3600 then return math.floor(d / 60) .. "m ago" end
    if d < 86400 then return math.floor(d / 3600) .. "h ago" end
    return math.floor(d / 86400) .. "d ago"
end

