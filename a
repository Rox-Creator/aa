-- Read a player's health and max-health by name. Returns (hp, maxHp).
-- Defaults: hp=100, maxHp=100. Tries attributes/NumberValues first, then Humanoid.
local function ReadPlayerHealth(playerName)
    local hp = 100
    local maxHp = 100
    local sawMax = false
    pcall(function()
        local p = game:GetService("Players"):FindFirstChild(playerName)
        if p then
            pcall(function()
                local h = p:GetAttribute("Health")
                if h then hp = tonumber(h) or hp end
                local m = p:GetAttribute("Maximum health")
                if not m then m = p:GetAttribute("MaxHealth") end
                if not m then m = p:GetAttribute("MaximumHealth") end
                if m then maxHp = tonumber(m) or maxHp; sawMax = true end
            end)
            pcall(function()
                for _, child in pairs(p:GetChildren()) do
                    if child.Name == "Health" then
                        hp = tonumber(child.Value) or hp
                    elseif child.Name == "MaxHealth" or child.Name == "Maximum health" or child.Name == "MaximumHealth" then
                        maxHp = tonumber(child.Value) or maxHp
                        sawMax = true
                    end
                end
            end)
            if not sawMax then
                pcall(function()
                    local char = p.Character
                    if char then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then
                            local m = tonumber(hum.MaxHealth)
                            if m and m > 0 then maxHp = m; sawMax = true end
                            -- Humanoid.Health is authoritative when present
                            local h = tonumber(hum.Health)
                            if h then hp = h end
                        end
                    end
                end)
            end
        end
    end)
    -- If we never found a max, assume max is at least the current hp (so a
    -- buffed player at 145 still reads as 100% instead of being stuck).
    if not sawMax then maxHp = math.max(100, hp) end
    if maxHp <= 0 then maxHp = 100 end
    if hp < 0 then hp = 0 end
    if hp > maxHp then hp = maxHp end
    return hp, maxHp
end

-- Generic health bar drawing (reused for self and monitors)
local function DrawHealthBarWidget(px, py, pw, ph, playerName, hp, maxHp, zb, elemTable)
    maxHp = (maxHp and maxHp > 0) and maxHp or 100
    local hpFrac = math.max(0, math.min(1, hp / maxHp))
    local pctNum = math.floor(hpFrac * 100 + 0.5)
    local hpColor = GetHealthColor(pctNum)

    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(px, py); bg.Size = Vector2.new(pw, ph)
    bg.Color = Color3.fromRGB(16, 16, 20); bg.Filled = true
    bg.Corner = 5; bg.Transparency = 0.85
    bg.Visible = true; bg.ZIndex = zb
    table.insert(elemTable, bg)

    local brd = Drawing.new("Square")
    brd.Position = Vector2.new(px, py); brd.Size = Vector2.new(pw, ph)
    brd.Color = Color3.fromRGB(44, 44, 50); brd.Filled = false
    brd.Corner = 5; brd.Thickness = 1
    brd.Visible = true; brd.ZIndex = zb + 1
    table.insert(elemTable, brd)

    local barX, barY = px + 6, py + ph - 10
    local barW, barH = pw - 12, 4

    local track = Drawing.new("Square")
    track.Position = Vector2.new(barX, barY); track.Size = Vector2.new(barW, barH)
    track.Color = Color3.fromRGB(30, 30, 36); track.Filled = true
    track.Corner = 2; track.Visible = true; track.ZIndex = zb + 2
    table.insert(elemTable, track)

    local fillW = math.max(1, math.floor(barW * hpFrac))
    local fill = Drawing.new("Square")
    fill.Position = Vector2.new(barX, barY); fill.Size = Vector2.new(fillW, barH)
    fill.Color = hpColor; fill.Filled = true
    fill.Corner = 2; fill.Visible = true; fill.ZIndex = zb + 3
    table.insert(elemTable, fill)

    local nameText = Drawing.new("Text")
    nameText.Position = Vector2.new(px + 10, py + 6)
    nameText.Text = playerName; nameText.Color = Colors.TextPrimary
    nameText.Size = 15; nameText.Font = Drawing.Fonts.SystemBold
    nameText.Center = false; nameText.Outline = false
    nameText.Visible = true; nameText.ZIndex = zb + 4
    table.insert(elemTable, nameText)

    local pctStr = tostring(pctNum) .. "%"
    local pctText = Drawing.new("Text")
    pctText.Position = Vector2.new(px + pw - 10 - #pctStr * 8, py + 6)
    pctText.Text = pctStr; pctText.Color = hpColor
    pctText.Size = 15; pctText.Font = Drawing.Fonts.SystemBold
    pctText.Center = false; pctText.Outline = false
    pctText.Visible = true; pctText.ZIndex = zb + 4
    table.insert(elemTable, pctText)

    local hpStr = tostring(math.floor(hp + 0.5)) .. "/" .. tostring(math.floor(maxHp + 0.5))
    local hpText = Drawing.new("Text")
    hpText.Position = Vector2.new(px + pw - 14 - #pctStr * 8 - #hpStr * 7, py + 7)
    hpText.Text = hpStr; hpText.Color = Color3.fromRGB(255, 255, 255)
    hpText.Size = 13; hpText.Font = Drawing.Fonts.Monospace
    hpText.Center = false; hpText.Outline = false
    hpText.Visible = true; hpText.ZIndex = zb + 4
    table.insert(elemTable, hpText)
end

