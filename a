-- Returns min/max scalars (or nil) so the caller can do a distance check before
-- allocating Vector3 corners — saves 8 Vector3 allocs/titan/frame when off-screen.
local function getTitanAABB(partMap)
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
    local count = 0
    for _, part in pairs(partMap) do
        if part and part.Parent then
            pcall(function()
                local pos = part.Position
                local size = part.Size
                if pos and size then
                    local hx, hy, hz = size.X / 2, size.Y / 2, size.Z / 2
                    if pos.X - hx < minX then minX = pos.X - hx end
                    if pos.Y - hy < minY then minY = pos.Y - hy end
                    if pos.Z - hz < minZ then minZ = pos.Z - hz end
                    if pos.X + hx > maxX then maxX = pos.X + hx end
                    if pos.Y + hy > maxY then maxY = pos.Y + hy end
                    if pos.Z + hz > maxZ then maxZ = pos.Z + hz end
                    count = count + 1
                end
            end)
        end
    end
    if count == 0 then return nil end
    return minX, minY, minZ, maxX, maxY, maxZ
end

titanApplyColor = function()
    local c = TITAN_COLOR_PRESETS[TITAN.ColorIndex].color
    TITAN.ESPColor = c
    for _, data in pairs(TITAN.Objects) do
        for _, ln in ipairs(data.boneLines) do ln.Color = c end
        for _, dot in pairs(data.jointDots) do dot.Color = c end
        if data.headCircle then data.headCircle.Color = c end
        for _, ln in ipairs(data.wireLines) do ln.Color = c end
        data.nameTag.Color = c
    end
end

titanApplyFont = function()
    local f = TITAN_FONTS[TITAN.FontIndex].font
    for _, data in pairs(TITAN.Objects) do
        data.nameTag.Font = f
    end
end

local function titanRegisterObj(titanModel)
    pcall(function()
        if titanModel.ClassName ~= "Model" then return end
        local id = titanModel.Name
        if TITAN.Objects[id] then return end
        local defaultModel = titanModel:FindFirstChild("Default")
        if not defaultModel then return end
        local partMap = {}
        for _, bone in ipairs(TITAN_BONES) do
            for _, name in ipairs(bone) do
                if not partMap[name] then
                    local part = defaultModel:FindFirstChild(name)
                    if part then
                        partMap[name] = part
                    end
                end
            end
        end
        local partCount = 0
        for _ in pairs(partMap) do partCount = partCount + 1 end
        if partCount < 3 then return end
        local boneLines = {}
        for i = 1, #TITAN_BONES do
            local ln = Drawing.new("Line")
            ln.Color = TITAN.ESPColor
            ln.Thickness = TITAN.LineThickness
            ln.Visible = false
            boneLines[i] = ln
        end
        local jointDots = {}
        for name, _ in pairs(partMap) do
            local dot = Drawing.new("Circle")
            dot.Color = TITAN.ESPColor
            dot.Radius = 3
            dot.NumSides = 8
            dot.Filled = true
            dot.Visible = false
            jointDots[name] = dot
        end
        local headCircle = nil
        if partMap["Head"] then
            headCircle = Drawing.new("Circle")
            headCircle.Color = TITAN.ESPColor
            headCircle.Radius = 8
            headCircle.NumSides = 16
            headCircle.Filled = false
            headCircle.Thickness = TITAN.LineThickness
            headCircle.Visible = false
        end
        local wireLines = {}
        for i = 1, #CUBE_EDGES do
            local ln = Drawing.new("Line")
            ln.Color = TITAN.ESPColor
            ln.Thickness = TITAN.LineThickness
            ln.Visible = false
            wireLines[i] = ln
        end
        local nameTag = Drawing.new("Text")
        nameTag.Color = TITAN.ESPColor
        nameTag.Size = 14
        nameTag.Font = TITAN_FONTS[TITAN.FontIndex].font
        nameTag.Center = true
        nameTag.Outline = true
        nameTag.Visible = false
        TITAN.Objects[id] = {
            model = titanModel,
            partMap = partMap,
            boneLines = boneLines,
            jointDots = jointDots,
            headCircle = headCircle,
            wireLines = wireLines,
            nameTag = nameTag,
        }
    end)
end

local function titanScan()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return end
    for _, titanModel in ipairs(titansFolder:GetChildren()) do
        titanRegisterObj(titanModel)
    end
end

local function titanUpdate()
    if not TITAN.Enabled then
        for _, data in pairs(TITAN.Objects) do
            for _, ln in ipairs(data.boneLines) do ln.Visible = false end
            for _, dot in pairs(data.jointDots) do dot.Visible = false end
            if data.headCircle then data.headCircle.Visible = false end
            for _, ln in ipairs(data.wireLines) do ln.Visible = false end
            data.nameTag.Visible = false
        end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end
    local isBones = (TITAN.Mode == "Bones")

    for id, data in pairs(TITAN.Objects) do
        local model = data.model

        local function hideAll()
            for _, ln in ipairs(data.boneLines) do ln.Visible = false end
            for _, dot in pairs(data.jointDots) do dot.Visible = false end
            if data.headCircle then data.headCircle.Visible = false end
            for _, ln in ipairs(data.wireLines) do ln.Visible = false end
            data.nameTag.Visible = false
        end

        if not model or not model.Parent then
            hideAll()
        elseif isBones then
            for _, ln in ipairs(data.wireLines) do ln.Visible = false end

            local screenParts = {}
            local anyVisible = false
            local topScreenY = math.huge
            local topScreenX = 0

            for name, part in pairs(data.partMap) do
                if part and part.Parent then
                    pcall(function()
                        local pos = part.Position
                        if pos then
                            if not anyVisible then
                                local dx = playerPos.X - pos.X
                                local dy = playerPos.Y - pos.Y
                                local dz = playerPos.Z - pos.Z
                                local dist = math.sqrt(dx*dx + dy*dy + dz*dz)
                                if dist > TITAN.MaxDistance then return end
                            end
                            local screenPos, onScreen = WorldToScreen(pos)
                            if screenPos and onScreen then
                                screenParts[name] = screenPos
                                anyVisible = true
                                if screenPos.Y < topScreenY then
                                    topScreenY = screenPos.Y
                                    topScreenX = screenPos.X
                                end
                            end
                        end
                    end)
                end
            end

            if not anyVisible then
                hideAll()
            else
                for i, bone in ipairs(TITAN_BONES) do
                    local ln = data.boneLines[i]
                    local scA = screenParts[bone[1]]
                    local scB = screenParts[bone[2]]
                    if scA and scB then
                        ln.From = Vector2.new(scA.X, scA.Y)
                        ln.To = Vector2.new(scB.X, scB.Y)
                        ln.Visible = true
                    else
                        ln.Visible = false
                    end
                end

                for name, dot in pairs(data.jointDots) do
                    local sc = screenParts[name]
                    if sc and TITAN.ShowJointDots then
                        dot.Position = Vector2.new(sc.X, sc.Y)
                        dot.Visible = true
                    else
                        dot.Visible = false
                    end
                end

                if data.headCircle then
                    local headSc = screenParts["Head"]
                    if headSc and TITAN.ShowHeadCircle then
                        data.headCircle.Position = Vector2.new(headSc.X, headSc.Y)
                        data.headCircle.Visible = true
                    else
                        data.headCircle.Visible = false
                    end
                end

                if TITAN.ShowNameTag then
                    data.nameTag.Position = Vector2.new(topScreenX, topScreenY - 20)
                    data.nameTag.Text = "Titan"
                    data.nameTag.Visible = true
                else
                    data.nameTag.Visible = false
                end
            end
        else
            -- WIREFRAME MODE
            for _, ln in ipairs(data.boneLines) do ln.Visible = false end
            for _, dot in pairs(data.jointDots) do dot.Visible = false end
            if data.headCircle then data.headCircle.Visible = false end

            local mnX, mnY, mnZ, mxX, mxY, mxZ = getTitanAABB(data.partMap)
            if not mnX then
                hideAll()
            else
                local cx = (mnX + mxX) / 2
                local cy = (mnY + mxY) / 2
                local cz = (mnZ + mxZ) / 2
                local dx = playerPos.X - cx
                local dy = playerPos.Y - cy
                local dz = playerPos.Z - cz
                local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

                if dist > TITAN.MaxDistance then
                    for _, ln in ipairs(data.wireLines) do ln.Visible = false end
                    data.nameTag.Visible = false
                else
                    -- Build the 8 corners only now that the titan is in range
                    local corners = {
                        Vector3.new(mnX, mnY, mnZ),
                        Vector3.new(mxX, mnY, mnZ),
                        Vector3.new(mxX, mnY, mxZ),
                        Vector3.new(mnX, mnY, mxZ),
                        Vector3.new(mnX, mxY, mnZ),
                        Vector3.new(mxX, mxY, mnZ),
                        Vector3.new(mxX, mxY, mxZ),
                        Vector3.new(mnX, mxY, mxZ),
                    }
                    local sc = {}
                    local anyOn = false
                    local topScreenY = math.huge
                    local topScreenX = 0
                    for i = 1, 8 do
                        local screenPos, onScreen = WorldToScreen(corners[i])
                        if screenPos and onScreen then
                            sc[i] = screenPos
                            anyOn = true
                            if screenPos.Y < topScreenY then
                                topScreenY = screenPos.Y
                                topScreenX = screenPos.X
                            end
                        end
                    end

                    if not anyOn then
                        for _, ln in ipairs(data.wireLines) do ln.Visible = false end
                        data.nameTag.Visible = false
                    else
                        for i, edge in ipairs(CUBE_EDGES) do
                            local ln = data.wireLines[i]
                            local scA = sc[edge[1]]
                            local scB = sc[edge[2]]
                            if scA and scB then
                                ln.From = Vector2.new(scA.X, scA.Y)
                                ln.To = Vector2.new(scB.X, scB.Y)
                                ln.Visible = true
                            else
                                ln.Visible = false
                            end
                        end

                        if TITAN.ShowNameTag then
                            data.nameTag.Position = Vector2.new(topScreenX, topScreenY - 20)
                            data.nameTag.Text = "Titan"
                            data.nameTag.Visible = true
                        else
                            data.nameTag.Visible = false
                        end
                    end
                end
            end
        end
    end
end

local function titanCleanup()
    for id, data in pairs(TITAN.Objects) do
