-- ============================================================
-- DEAD PLAYER ESP (ragdolls in Workspace)
-- ============================================================
-- Same toggle as live Player ESP. When a player dies the game spawns
-- "<Name>_ragdoll" Models in Workspace; we scan for those and draw a
-- red "(DEAD)" + white player name above each one.

local function ragdollPosition(model)
    -- Try PrimaryPart, then common rig parts, then the first BasePart child.
    local pp
    pcall(function() pp = model.PrimaryPart end)
    if pp then
        local pos
        pcall(function() pos = pp.Position end)
        if pos then return pos end
    end
    for _, partName in ipairs({"HumanoidRootPart", "UpperTorso", "Torso", "Head"}) do
        local part
        pcall(function() part = model:FindFirstChild(partName) end)
        if part then
            local pos
            pcall(function() pos = part.Position end)
            if pos then return pos end
        end
    end
    local kids
    pcall(function() kids = model:GetChildren() end)
    if kids then
        for _, c in ipairs(kids) do
            local pos
            pcall(function() pos = c.Position end)
            if pos then return pos end
        end
    end
    return nil
end

local function playerEspDeadRegister(model)
    pcall(function()
        local cls
        pcall(function() cls = model.ClassName end)
        if cls ~= "Model" then return end
        local nm = model.Name
        if type(nm) ~= "string" then return end
        local len = #nm
        if len <= 8 or nm:sub(len - 7) ~= "_ragdoll" then return end
        if PLAYER_ESP.DeadObjects[nm] then return end

        -- "Player_ragdoll" → "Player"
        local clean = nm:sub(1, len - 8)
        if clean == "" then clean = nm end

        local deadTag = Drawing.new("Text")
        deadTag.Color = Color3.fromRGB(255, 60, 60)
        deadTag.Size = PLAYER_ESP.TextSize
        deadTag.Font = TITAN_FONTS[PLAYER_ESP.FontIndex].font
        deadTag.Center = false
        deadTag.Outline = true
        deadTag.Visible = false
        deadTag.ZIndex = 52

        local nameTag = Drawing.new("Text")
        nameTag.Color = Color3.fromRGB(220, 220, 225)
        nameTag.Size = PLAYER_ESP.TextSize
        nameTag.Font = TITAN_FONTS[PLAYER_ESP.FontIndex].font
        nameTag.Center = false
        nameTag.Outline = true
        nameTag.Visible = false
        nameTag.ZIndex = 52

        PLAYER_ESP.DeadObjects[nm] = {
            model     = model,
            deadTag   = deadTag,
            nameTag   = nameTag,
            cleanName = clean,
        }
    end)
end

local function playerEspDeadScan()
    local kids
    pcall(function() kids = Workspace:GetChildren() end)
    if not kids then return end
    for _, c in ipairs(kids) do
        playerEspDeadRegister(c)
    end
end

local function playerEspDeadHide(data)
    data.deadTag.Visible = false
    data.nameTag.Visible = false
end

local function playerEspDeadUpdate()
    if not PLAYER_ESP.Enabled then
        for _, data in pairs(PLAYER_ESP.DeadObjects) do playerEspDeadHide(data) end
        return
    end
    local playerPos = getPlayerPos()
    if not playerPos then return end

    for nm, data in pairs(PLAYER_ESP.DeadObjects) do
        local model = data.model
        if not model or not model.Parent then
            playerEspDeadHide(data)
        else
            local pos = ragdollPosition(model)
            if not pos then
                playerEspDeadHide(data)
            else
                local dx = playerPos.X - pos.X
                local dy = playerPos.Y - pos.Y
                local dz = playerPos.Z - pos.Z
                local dist = math.sqrt(dx*dx + dy*dy + dz*dz)
                if dist > PLAYER_ESP.MaxDistance then
                    playerEspDeadHide(data)
                else
                    local headTop = Vector3.new(pos.X, pos.Y + 3, pos.Z)
                    local screenPos, onScreen = WorldToScreen(headTop)
                    if not (screenPos and onScreen) then
                        playerEspDeadHide(data)
                    else
                        -- Center "(DEAD) Name" horizontally above the body.
                        -- Approx glyph width = TextSize * 0.55 matches the
                        -- live player ESP's centering math.
                        local approxChar = PLAYER_ESP.TextSize * 0.55
                        local deadStr = "(DEAD) "
                        local deadW = #deadStr * approxChar
                        local nameW = #data.cleanName * approxChar
                        local totalW = deadW + nameW
                        local leftX = screenPos.X - totalW / 2
                        local y = screenPos.Y - 20

                        data.deadTag.Position = Vector2.new(leftX, y)
                        data.deadTag.Text = "(DEAD)"
                        data.deadTag.Visible = true

                        data.nameTag.Position = Vector2.new(leftX + deadW, y)
                        data.nameTag.Text = data.cleanName
                        data.nameTag.Visible = true
                    end
                end
            end
        end
    end
end

local function playerEspDeadCleanup()
    for nm, data in pairs(PLAYER_ESP.DeadObjects) do
        local model = data.model
        if not model or not model.Parent then
            pcall(function() data.deadTag:Remove() end)
            pcall(function() data.nameTag:Remove() end)
            PLAYER_ESP.DeadObjects[nm] = nil
        end
    end
end

-- ============================================================
-- MAIN LOOP (polling Mouse.X/Y + ismouse1pressed)
-- ============================================================

local function InputLoop()
    while GUI.Running do
        local toggleDown = iskeypressed(GUI.ToggleKey)

        -- Close key = unload (skip first frame so a held-down key from
        -- before script launch doesn't immediately unload). The bound key
        -- is user-configurable in Settings; default is End.
        local closeDown = iskeypressed(GUI.CloseKey)
        if GUI.CloseKeyReady then
            if closeDown and not GUI.WasCloseDown then
                UnloadScript()
                return
            end
        else
            if not closeDown then
                GUI.CloseKeyReady = true
            end
        end
        GUI.WasCloseDown = closeDown

        -- Player list toggle key
        local plKeyDown = iskeypressed(GUI.PlayerListKey)
        if plKeyDown and not GUI.WasPLKeyDown then
            GUI.PlayerListOpen = not GUI.PlayerListOpen
            if GUI.PlayerListOpen then
                GUI.PLScrollOffset = 0
                BuildPlayerList()
            else
                ClearPlayerList()
            end
            if GUI.Visible then CreateContent(GUI.SelectedPage) end
        end
        GUI.WasPLKeyDown = plKeyDown

        -- Player ESP toggle key
        local peKeyDown = iskeypressed(GUI.PlayerEspKey)
        if peKeyDown and not GUI.WasPEKeyDown then
            PLAYER_ESP.Enabled = not PLAYER_ESP.Enabled
            if GUI.Visible then CreateContent(GUI.SelectedPage) end
        end
        GUI.WasPEKeyDown = peKeyDown

        -- Keybind listening mode: scan for any key press (GUI toggle or PL key)
        -- PL keybind listening (independent, always runs)
        if GUI.ListeningForPLKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.PlayerListKey = vk
                    GUI.ListeningForPLKey = false
                    BuildPlayerList()
                    task.wait(0.2)
                    break
                end
            end
        end

        -- PE keybind listening (independent, always runs)
        if GUI.ListeningForPEKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.PlayerEspKey = vk
                    GUI.ListeningForPEKey = false
                    if GUI.Visible then CreateContent(GUI.SelectedPage) end
                    task.wait(0.2)
                    break
                end
            end
        end

        -- Close keybind listening (independent, always runs). After capture
        -- we reset CloseKeyReady so the just-captured key — which is by
        -- definition currently down — doesn't immediately unload.
        if GUI.ListeningForCloseKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.CloseKey = vk
                    GUI.ListeningForCloseKey = false
                    GUI.CloseKeyReady = false
                    GUI.WasCloseDown = true
                    if GUI.SelectedPage == "Settings" then
                        CreateContent("Settings")
                    end
                    if GUI.HintText then
                        pcall(function()
                            GUI.HintText.Text = GetKeyName(GUI.ToggleKey) .. " Toggle | " .. GetKeyName(GUI.CloseKey) .. " Unload"
                        end)
                    end
                    task.wait(0.2)
                    break
                end
            end
        end

        if GUI.ListeningForKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.ToggleKey = vk
                    GUI.ListeningForKey = false
                    if GUI.SelectedPage == "Settings" then
                        CreateContent("Settings")
                    end
                    task.wait(0.2)
                    break
                end
            end
            GUI.WasToggleDown = toggleDown
            task.wait(0.016)
        else
            -- Toggle visibility (rising edge)
            if toggleDown and not GUI.WasToggleDown then
                GUI.Visible = not GUI.Visible
                for _, el in ipairs(GUI.Elements) do
                    el.Visible = GUI.Visible
                end
                if not GUI.Visible then
                    ClearContent()
                    ClearSubTabs()
                else
                    CreateContent(GUI.SelectedPage)
                end
            end
            GUI.WasToggleDown = toggleDown

            if GUI.Visible then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local justPressed = mouseDown and not GUI.WasMouseDown

            -- Header is the drag handle
            local onHeader = IsInside(mx, my, Config.WinX, Config.WinY, Config.WinW, Config.HeaderH)

            -- Handle header drag
            if GUI.Dragging then
                if mouseDown then
                    local newX = mx - GUI.DragOffsetX
                    local newY = my - GUI.DragOffsetY
                    local ddx = newX - Config.WinX
                    local ddy = newY - Config.WinY
                    if ddx ~= 0 or ddy ~= 0 then
                        MoveWindow(ddx, ddy)
                    end
                else
                    GUI.Dragging = false
                    CreateContent(GUI.SelectedPage)
                end
            end

            -- Handle slider drag (continuous while held)
            if GUI.SliderDragging and mouseDown then
                local s = GUI.SliderDragging
                s.onClick(mx)
                for _, c in ipairs(GUI.Clickables) do
                    if c.isSlider then
                        GUI.SliderDragging = c
                        break
                    end
                end
            elseif not mouseDown then
                GUI.SliderDragging = nil
            end

            -- Handle mouse press (rising edge)
            if justPressed then
                local handled = false

                -- Check dropdown clickables first (highest priority)
                if GUI.DropdownOpen then
                    local ddHandled = false
                    for _, c in ipairs(GUI.DropdownClickables) do
                        if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                            c.onClick()
                            ddHandled = true
                            handled = true
                            break
                        end
                    end
                    if not ddHandled then
                        CloseDropdown()
                        handled = true
                    end
                end

                -- Check player list clickables (works whether GUI visible or not)
                if not handled and GUI.PlayerListOpen then
                    if IsInside(mx, my, GUI.PlayerListX, GUI.PlayerListY, GUI.PlayerListW, GUI.PlayerListH) then
                        for _, c in ipairs(GUI.PlayerListClickables) do
                            if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                                c.onClick()
                                handled = true
                                break
                            end
                        end
                        if not handled then handled = true end -- absorb click inside panel
                    end
                end

                -- Check enchants panel clickables (works whether GUI visible or not)
                if not handled and GUI.EnchantsOpen then
                    if IsInside(mx, my, GUI.EnchantsX, GUI.EnchantsY, GUI.EnchantsW, GUI.EnchantsH) then
                        for _, c in ipairs(GUI.EnchantsClickables) do
                            if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                                c.onClick()
                                handled = true
                                break
                            end
                        end
                        if not handled then handled = true end -- absorb click inside panel
                    end
                end

                -- Check RS diff panel clickables (works whether GUI visible or not)
                if not handled and GUI.RSDiffOpen then
                    if IsInside(mx, my, GUI.RSDiffX, GUI.RSDiffY, GUI.RSDiffW, GUI.RSDiffH) then
                        for _, c in ipairs(GUI.RSDiffClickables) do
                            if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                                c.onClick()
                                handled = true
                                break
                            end
                        end
                        if not handled then handled = true end -- absorb click inside panel
                    end
                end

                -- Check sub-tab clickables
                if not handled then
                    for _, c in ipairs(GUI.SubTabClickables) do
                        if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                            c.onClick()
                            handled = true
                            break
                        end
                    end
                end

                -- Check content clickables
                if not handled then
                    for _, c in ipairs(GUI.Clickables) do
                        if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                            if c.isSlider then
                                c.onClick(mx)
                                for _, nc in ipairs(GUI.Clickables) do
                                    if nc.isSlider then
                                        GUI.SliderDragging = nc
                                        break
                                    end
                                end
                            else
                                if c.hover and c.hover.el then
                                    pressEffect(c.hover.el)
                                end
                                c.onClick()
                            end
                            handled = true
                            break
                        end
                    end
                end

                -- Check nav tabs (horizontal header)
                if not handled then
                    for _, btn in ipairs(GUI.NavButtons) do
                        local hx, hy, hw, hh = navHitBounds(btn)
                        if IsInside(mx, my, hx, hy, hw, hh) then
                            handled = true
                            if GUI.SelectedPage ~= btn.Name then
                                GUI.SelectedPage = btn.Name
                                GUI.SubTab = "Elements"
                                for _, b in ipairs(GUI.NavButtons) do
                                    UpdateNavButton(b, b.Name == GUI.SelectedPage, false)
                                end
                                -- Slide the underline from the old tab to the
                                -- new one, then rebuild content. The underline
                                -- tween chains into the content snap so the
                                -- switch reads as a single fluid motion.
                                animateMainTabUnderline(btn, function()
                                    CreateContent(btn.Name)
                                end)
                            end
                            break
                        end
                    end
                end

                -- Header drag start
                if not handled and onHeader and not GUI.Dragging then
                    GUI.Dragging = true
                    GUI.DragOffsetX = mx - Config.WinX
                    GUI.DragOffsetY = my - Config.WinY
                end
            end

            -- Hover lighten for content clickables (toggles, bind buttons)
            for _, c in ipairs(GUI.Clickables) do
                if c.hover and c.hover.el then
                    local isOver = IsInside(mx, my, c.x, c.y, c.w, c.h)
                    if isOver and not c.hover.hovered then
                        pcall(function() c.hover.el.Color = lighten(c.hover.base, 0.10) end)
                        c.hover.hovered = true
                    elseif (not isOver) and c.hover.hovered then
                        pcall(function() c.hover.el.Color = c.hover.base end)
                        c.hover.hovered = false
                    end
                end
            end

            -- Nav hover visuals (horizontal tabs)
            for _, btn in ipairs(GUI.NavButtons) do
                local hx, hy, hw, hh = navHitBounds(btn)
                local isHovered = IsInside(mx, my, hx, hy, hw, hh)
                local isSelected = GUI.SelectedPage == btn.Name
                UpdateNavButton(btn, isSelected, isHovered and not GUI.Dragging)
            end

            GUI.WasMouseDown = mouseDown
            end -- if GUI.Visible
        end -- else (not listening)

        -- Counter panel drag (always, independent of main GUI)
        if GUI.CounterVisible and #GUI.CounterElements > 0 then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local onCounter = IsInside(mx, my, GUI.CounterX, GUI.CounterY, GUI.CounterW, GUI.CounterH)
            if GUI.CounterDragging then
                if mouseDown then
                    local nx = mx - GUI.CounterDragOX
                    local ny = my - GUI.CounterDragOY
                    local ddx = nx - GUI.CounterX
                    local ddy = ny - GUI.CounterY
                    if ddx ~= 0 or ddy ~= 0 then
                        MoveCounterPanel(ddx, ddy)
                    end
                else
                    GUI.CounterDragging = false
                end
            elseif mouseDown and onCounter and not GUI.Dragging then
                GUI.CounterDragging = true
                GUI.CounterDragOX = mx - GUI.CounterX
                GUI.CounterDragOY = my - GUI.CounterY
            end
        end

        -- Health bar drag + auto-refresh (independent of main GUI)
        if GUI.HealthBarVisible and #GUI.HealthBarElements > 0 then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local onBar = IsInside(mx, my, GUI.HealthBarX, GUI.HealthBarY, GUI.HealthBarW, GUI.HealthBarH)

            if GUI.HealthBarDragging then
                if mouseDown then
                    local nx = mx - GUI.HealthBarDragOX
                    local ny = my - GUI.HealthBarDragOY
                    local ddx = nx - GUI.HealthBarX
                    local ddy = ny - GUI.HealthBarY
                    if ddx ~= 0 or ddy ~= 0 then
                        GUI.HealthBarX = GUI.HealthBarX + ddx
                        GUI.HealthBarY = GUI.HealthBarY + ddy
                        for _, el in ipairs(GUI.HealthBarElements) do
                            pcall(function()
                                if el.Position then
                                    el.Position = Vector2.new(el.Position.X + ddx, el.Position.Y + ddy)
                                end
                            end)
                        end
                    end
                else
                    GUI.HealthBarDragging = false
                end
            elseif mouseDown and onBar and not GUI.Dragging and not GUI.CounterDragging then
                GUI.HealthBarDragging = true
                GUI.HealthBarDragOX = mx - GUI.HealthBarX
                GUI.HealthBarDragOY = my - GUI.HealthBarY
            end

            -- Auto-refresh health bar every ~2s
            GUI._hbRefreshTimer = (GUI._hbRefreshTimer or 0) + 1
            if GUI._hbRefreshTimer >= 120 then
                GUI._hbRefreshTimer = 0
                BuildHealthBar()
            end
        end

        -- Monitor bars drag + auto-refresh (independent). Whole block is
        -- gated on `next(GUI.MonitorBars)` so we don't poll Mouse / fire
        -- ismouse1pressed every frame when no monitor bars exist (which
        -- is the default case — saves the per-frame cost for users who
        -- never open a monitor bar).
        if next(GUI.MonitorBars) then
            local monMx, monMy = Mouse.X, Mouse.Y
            local monMouseDown = ismouse1pressed()
            for mName, mBar in pairs(GUI.MonitorBars) do
                if #mBar.elements > 0 then
                    local onMBar = IsInside(monMx, monMy, mBar.x, mBar.y, mBar.w, mBar.h)
                    if mBar.dragging then
                        if monMouseDown then
                            local ddx = monMx - mBar.dragOX - mBar.x
                            local ddy = monMy - mBar.dragOY - mBar.y
                            if ddx ~= 0 or ddy ~= 0 then
                                mBar.x = mBar.x + ddx
                                mBar.y = mBar.y + ddy
                                for _, el in ipairs(mBar.elements) do
                                    pcall(function()
                                        if el.Position then
                                            el.Position = Vector2.new(el.Position.X + ddx, el.Position.Y + ddy)
                                        end
                                    end)
                                end
                            end
                        else
                            mBar.dragging = false
                        end
                    elseif monMouseDown and onMBar and not GUI.Dragging and not GUI.HealthBarDragging then
                        mBar.dragging = true
                        mBar.dragOX = monMx - mBar.x
                        mBar.dragOY = monMy - mBar.y
                    end
                end
            end
            -- Refresh all monitor bars every ~2s
            GUI._monRefreshTimer = (GUI._monRefreshTimer or 0) + 1
            if GUI._monRefreshTimer >= 120 then
                GUI._monRefreshTimer = 0
                RefreshAllMonitorBars()
            end
        end

        -- Player list panel drag + click (independent of main GUI)
        if GUI.PlayerListOpen and #GUI.PlayerListElements > 0 then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local justP = mouseDown and not (GUI._plWasMouseDown or false)
            local headerH = 34
            local onHeader = IsInside(mx, my, GUI.PlayerListX, GUI.PlayerListY, GUI.PlayerListW, headerH)

            if GUI.PlayerListDragging then
                if mouseDown then
                    local nx = mx - GUI.PlayerListDragOX
                    local ny = my - GUI.PlayerListDragOY
                    local ddx = nx - GUI.PlayerListX
                    local ddy = ny - GUI.PlayerListY
                    if ddx ~= 0 or ddy ~= 0 then
                        GUI.PlayerListX = GUI.PlayerListX + ddx
                        GUI.PlayerListY = GUI.PlayerListY + ddy
                        -- Move all elements
                        for _, el in ipairs(GUI.PlayerListElements) do
                            pcall(function()
                                if el.Position then
                                    el.Position = Vector2.new(el.Position.X + ddx, el.Position.Y + ddy)
                                end
                            end)
                            pcall(function()
                                if el.From then
                                    el.From = Vector2.new(el.From.X + ddx, el.From.Y + ddy)
                                    el.To = Vector2.new(el.To.X + ddx, el.To.Y + ddy)
                                end
                            end)
                        end
                        -- Update clickable positions
                        for _, c in ipairs(GUI.PlayerListClickables) do
                            c.x = c.x + ddx
                            c.y = c.y + ddy
                        end
                    end
                else
                    GUI.PlayerListDragging = false
                end
            elseif mouseDown and onHeader and not GUI.Dragging and not GUI.CounterDragging then
                GUI.PlayerListDragging = true
                GUI.PlayerListDragOX = mx - GUI.PlayerListX
                GUI.PlayerListDragOY = my - GUI.PlayerListY
            end

            -- Player list clicks (only when main GUI is NOT visible)
            if not GUI.Visible and justP and not GUI.PlayerListDragging then
                for _, c in ipairs(GUI.PlayerListClickables) do
                    if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                        c.onClick()
                        break
                    end
                end
            end

            -- Scrollbar: start drag on press, continue on hold, stop on release.
            -- Reuses the `mouseDown` already read at the top of this PL block —
            -- no need for a second ismouse1pressed() call per frame.
            if GUI.PLScrollDragging then
                if mouseDown then
                    local dy = my - GUI.PLScrollDragLastY
                    if dy ~= 0 and GUI._plScrollTrack then
                        local st = GUI._plScrollTrack
                        local scrollPerPx = st.maxScroll / math.max(1, st.h - st.thumbH)
                        local newOffset = GUI.PLScrollOffset + dy * scrollPerPx
                        newOffset = math.max(0, math.min(st.maxScroll, newOffset))
                        local rounded = math.floor(newOffset + 0.5)
                        if rounded ~= GUI.PLScrollOffset then
                            GUI.PLScrollOffset = rounded
                            BuildPlayerList()
                        end
                        GUI.PLScrollDragLastY = my
                    end
                else
                    GUI.PLScrollDragging = false
                end
            elseif mouseDown and not GUI.PlayerListDragging and GUI._plScrollTrack then
                local st = GUI._plScrollTrack
                if IsInside(mx, my, st.x, st.y, st.w, st.h) then
                    GUI.PLScrollDragging = true
                    GUI.PLScrollDragLastY = my
                end
            end

            -- Search bar keyboard input
            if GUI.PLSearchFocused then
                -- A-Z
                for vk = 0x41, 0x5A do
                    local down = iskeypressed(vk)
                    local was = GUI.PLWasKeys[vk] or false
                    if down and not was then
                        GUI.PLSearchText = GUI.PLSearchText .. string.char(vk + 32) -- lowercase
                        GUI.PLScrollOffset = 0
                        BuildPlayerList()
                    end
                    GUI.PLWasKeys[vk] = down
                end
                -- 0-9
                for vk = 0x30, 0x39 do
                    local down = iskeypressed(vk)
                    local was = GUI.PLWasKeys[vk] or false
                    if down and not was then
                        GUI.PLSearchText = GUI.PLSearchText .. string.char(vk)
                        GUI.PLScrollOffset = 0
                        BuildPlayerList()
                    end
                    GUI.PLWasKeys[vk] = down
                end
                -- Underscore (shift+minus or just accept it)
                local shiftDown = iskeypressed(0xBD)
                local wasShift = GUI.PLWasKeys[0xBD] or false
                if shiftDown and not wasShift then
                    GUI.PLSearchText = GUI.PLSearchText .. "_"
                    GUI.PLScrollOffset = 0
                    BuildPlayerList()
                end
                GUI.PLWasKeys[0xBD] = shiftDown
                -- Backspace
                local bsDown = iskeypressed(0x08)
                local wasBs = GUI.PLWasKeys[0x08] or false
                if bsDown and not wasBs then
                    if #GUI.PLSearchText > 0 then
                        GUI.PLSearchText = string.sub(GUI.PLSearchText, 1, -2)
                        GUI.PLScrollOffset = 0
                        BuildPlayerList()
                    end
                end
                GUI.PLWasKeys[0x08] = bsDown
                -- Escape = unfocus
                local escDown = iskeypressed(0x1B)
                local wasEsc = GUI.PLWasKeys[0x1B] or false
                if escDown and not wasEsc then
                    GUI.PLSearchFocused = false
                    BuildPlayerList()
                end
                GUI.PLWasKeys[0x1B] = escDown
                -- Enter = unfocus
                local enterDown = iskeypressed(0x0D)
                local wasEnter = GUI.PLWasKeys[0x0D] or false
                if enterDown and not wasEnter then
                    GUI.PLSearchFocused = false
                    BuildPlayerList()
                end
                GUI.PLWasKeys[0x0D] = enterDown
            end

            -- Auto-refresh (every ~2s, only if enabled)
            if GUI.PLAutoUpdate and not GUI.PlayerListDragging then
                GUI._plRefreshTimer = (GUI._plRefreshTimer or 0) + 1
                if GUI._plRefreshTimer >= 120 then
                    GUI._plRefreshTimer = 0
                    GUI.PLCachedPlayers = ReadPlayerData()
                    BuildPlayerList()
                end
            end

            GUI._plWasMouseDown = mouseDown
        end

        -- Enchants panel drag + clicks (independent of main GUI)
        if GUI.EnchantsOpen and #GUI.EnchantsElements > 0 then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local justP = mouseDown and not (GUI._enchWasMouseDown or false)
            local headerH = 34
            local onHeader = IsInside(mx, my, GUI.EnchantsX, GUI.EnchantsY, GUI.EnchantsW, headerH)

            if GUI.EnchantsDragging then
                if mouseDown then
                    local nx = mx - GUI.EnchantsDragOX
                    local ny = my - GUI.EnchantsDragOY
                    local ddx = nx - GUI.EnchantsX
                    local ddy = ny - GUI.EnchantsY
                    if ddx ~= 0 or ddy ~= 0 then
                        GUI.EnchantsX = GUI.EnchantsX + ddx
                        GUI.EnchantsY = GUI.EnchantsY + ddy
                        for _, el in ipairs(GUI.EnchantsElements) do
                            pcall(function()
                                if el.Position then
                                    el.Position = Vector2.new(el.Position.X + ddx, el.Position.Y + ddy)
                                end
                            end)
                            pcall(function()
                                if el.From then
                                    el.From = Vector2.new(el.From.X + ddx, el.From.Y + ddy)
                                    el.To = Vector2.new(el.To.X + ddx, el.To.Y + ddy)
                                end
                            end)
                            -- Triangle elements use PointA/B/C instead of Position
                            pcall(function()
                                if el.PointA then
                                    el.PointA = Vector2.new(el.PointA.X + ddx, el.PointA.Y + ddy)
                                    el.PointB = Vector2.new(el.PointB.X + ddx, el.PointB.Y + ddy)
                                    el.PointC = Vector2.new(el.PointC.X + ddx, el.PointC.Y + ddy)
                                end
                            end)
                        end
                        for _, c in ipairs(GUI.EnchantsClickables) do
                            c.x = c.x + ddx
                            c.y = c.y + ddy
                        end
                        -- Also shift card hitboxes used by the hover indicator
                        for _, r in ipairs(GUI.EnchantsCardRects) do
                            r.x = r.x + ddx
                            r.y = r.y + ddy
                        end
                        if GUI._enchScrollTrack then
                            GUI._enchScrollTrack.x = GUI._enchScrollTrack.x + ddx
                            GUI._enchScrollTrack.y = GUI._enchScrollTrack.y + ddy
                        end
                    end
                else
                    GUI.EnchantsDragging = false
                end
            elseif mouseDown and onHeader and not GUI.Dragging and not GUI.PlayerListDragging
                and not GUI.CounterDragging and not GUI.HealthBarDragging then
                -- Don't start a drag if the press landed on a header button
                local hitClickable = false
                for _, c in ipairs(GUI.EnchantsClickables) do
                    if IsInside(mx, my, c.x, c.y, c.w, c.h) then hitClickable = true; break end
                end
                if not hitClickable then
                    GUI.EnchantsDragging = true
                    GUI.EnchantsDragOX = mx - GUI.EnchantsX
                    GUI.EnchantsDragOY = my - GUI.EnchantsY
                end
            end

            -- Clicks (only handled here when main GUI is hidden; visible-GUI path
            -- routes clicks through the main loop's clickable scan below)
            if not GUI.Visible and justP and not GUI.EnchantsDragging then
                for _, c in ipairs(GUI.EnchantsClickables) do
                    if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                        c.onClick()
                        break
                    end
                end
            end

            -- Scrollbar drag
            if GUI.EnchantsScrollDragging then
                if mouseDown then
                    local dy = my - GUI.EnchantsScrollDragLastY
                    if dy ~= 0 and GUI._enchScrollTrack then
                        local st = GUI._enchScrollTrack
                        local scrollPerPx = st.maxScroll / math.max(1, st.h - st.thumbH)
                        local newOffset = GUI.EnchantsScrollOffset + dy * scrollPerPx
                        newOffset = math.max(0, math.min(st.maxScroll, newOffset))
                        local rounded = math.floor(newOffset + 0.5)
                        if rounded ~= GUI.EnchantsScrollOffset then
                            GUI.EnchantsScrollOffset = rounded
                            BuildEnchantsPanel()
                        end
                        GUI.EnchantsScrollDragLastY = my
                    end
                else
                    GUI.EnchantsScrollDragging = false
                end
            elseif mouseDown and not GUI.EnchantsDragging and GUI._enchScrollTrack then
                local st = GUI._enchScrollTrack
                if IsInside(mx, my, st.x, st.y, st.w, st.h) then
                    GUI.EnchantsScrollDragging = true
                    GUI.EnchantsScrollDragLastY = my
                end
            end

            -- Hover indicator: highlight whichever card the mouse is over.
            -- Lazily create one persistent Square so we can just toggle its
            -- visibility/position each frame without spawning Drawing objects.
            if not GUI._enchHoverEl then
                GUI._enchHoverEl = Drawing.new("Square")
                GUI._enchHoverEl.Filled = false
                GUI._enchHoverEl.Thickness = 2
                GUI._enchHoverEl.Corner = 5
                GUI._enchHoverEl.ZIndex = 79
                GUI._enchHoverEl.Visible = false
            end
            local hoverRect = nil
            if not GUI.EnchantsModal then
                for _, r in ipairs(GUI.EnchantsCardRects) do
                    if IsInside(mx, my, r.x, r.y, r.w, r.h) then
                        hoverRect = r
                        break
                    end
                end
            end
            if hoverRect then
                GUI._enchHoverEl.Position = Vector2.new(hoverRect.x - 1, hoverRect.y - 1)
                GUI._enchHoverEl.Size = Vector2.new(hoverRect.w + 2, hoverRect.h + 2)
                GUI._enchHoverEl.Color = hoverRect.rcol or Colors.AccentRed
                GUI._enchHoverEl.Visible = true
            else
                GUI._enchHoverEl.Visible = false
            end

            GUI._enchWasMouseDown = mouseDown
        else
            -- Panel closed: make sure the hover indicator is hidden
            if GUI._enchHoverEl then GUI._enchHoverEl.Visible = false end
        end

        -- RS Diff panel drag + scroll + click (independent of main GUI).
        -- Same structure as Enchants but simpler — no modal, no card
        -- hitboxes, just header drag, button clicks, and a scrollbar.
        if GUI.RSDiffOpen and #GUI.RSDiffElements > 0 then
            local mx, my = Mouse.X, Mouse.Y
            local mouseDown = ismouse1pressed()
            local justP = mouseDown and not (GUI._rsWasMouseDown or false)
            local headerH = 34
            local onHeader = IsInside(mx, my, GUI.RSDiffX, GUI.RSDiffY, GUI.RSDiffW, headerH)

            if GUI.RSDiffDragging then
                if mouseDown then
                    local nx = mx - GUI.RSDiffDragOX
                    local ny = my - GUI.RSDiffDragOY
                    local ddx = nx - GUI.RSDiffX
                    local ddy = ny - GUI.RSDiffY
                    if ddx ~= 0 or ddy ~= 0 then
                        GUI.RSDiffX = GUI.RSDiffX + ddx
                        GUI.RSDiffY = GUI.RSDiffY + ddy
                        for _, el in ipairs(GUI.RSDiffElements) do
                            pcall(function()
                                if el.Position then
                                    el.Position = Vector2.new(el.Position.X + ddx, el.Position.Y + ddy)
                                end
                            end)
                            pcall(function()
                                if el.From then
                                    el.From = Vector2.new(el.From.X + ddx, el.From.Y + ddy)
                                    el.To = Vector2.new(el.To.X + ddx, el.To.Y + ddy)
                                end
                            end)
                        end
                        for _, c in ipairs(GUI.RSDiffClickables) do
                            c.x = c.x + ddx
                            c.y = c.y + ddy
                        end
                        if GUI._rsScrollTrack then
                            GUI._rsScrollTrack.x = GUI._rsScrollTrack.x + ddx
                            GUI._rsScrollTrack.y = GUI._rsScrollTrack.y + ddy
                        end
                    end
                else
                    GUI.RSDiffDragging = false
                end
            elseif mouseDown and onHeader and not GUI.Dragging
                and not GUI.PlayerListDragging and not GUI.CounterDragging
                and not GUI.HealthBarDragging and not GUI.EnchantsDragging then
                -- Don't start a drag if the press landed on a button
                local hitClickable = false
                for _, c in ipairs(GUI.RSDiffClickables) do
                    if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                        hitClickable = true; break
                    end
                end
                if not hitClickable then
                    GUI.RSDiffDragging = true
                    GUI.RSDiffDragOX = mx - GUI.RSDiffX
                    GUI.RSDiffDragOY = my - GUI.RSDiffY
                end
            end

            -- Clicks when main GUI is hidden (visible-GUI path routes
            -- through the main justPressed scan above).
            if not GUI.Visible and justP and not GUI.RSDiffDragging then
                for _, c in ipairs(GUI.RSDiffClickables) do
                    if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                        c.onClick()
                        break
                    end
                end
            end

            -- Scrollbar drag
            if GUI.RSDiffScrollDragging then
                if mouseDown then
                    local dy = my - GUI.RSDiffScrollDragLastY
                    if dy ~= 0 and GUI._rsScrollTrack then
                        local st = GUI._rsScrollTrack
                        local scrollPerPx = st.maxScroll / math.max(1, st.h - st.thumbH)
                        local newOffset = GUI.RSDiffScrollOffset + dy * scrollPerPx
                        newOffset = math.max(0, math.min(st.maxScroll, newOffset))
                        local rounded = math.floor(newOffset + 0.5)
                        if rounded ~= GUI.RSDiffScrollOffset then
                            GUI.RSDiffScrollOffset = rounded
                            BuildRSDiffPanel()
                        end
                        GUI.RSDiffScrollDragLastY = my
                    end
                else
                    GUI.RSDiffScrollDragging = false
                end
            elseif mouseDown and not GUI.RSDiffDragging and GUI._rsScrollTrack then
                local st = GUI._rsScrollTrack
                if IsInside(mx, my, st.x, st.y, st.w, st.h) then
                    GUI.RSDiffScrollDragging = true
                    GUI.RSDiffScrollDragLastY = my
                end
            end

            GUI._rsWasMouseDown = mouseDown
        end

        -- Adaptive polling. When nothing interactive is on-screen (main
        -- GUI hidden, no panels open, nothing being dragged, not
        -- listening for a keybind) we still need to poll the toggle key
        -- and End key — but a 30Hz tick is more than fast enough for
        -- key-rising-edge detection (33ms < typical key-press
        -- duration), and it halves background CPU when the menu is off.
        local interactive = GUI.Visible
            or GUI.PlayerListOpen or GUI.EnchantsOpen or GUI.RSDiffOpen
            or GUI.CounterVisible or GUI.HealthBarVisible
            or GUI.ListeningForKey or GUI.ListeningForPLKey or GUI.ListeningForPEKey or GUI.ListeningForCloseKey
            or GUI.Dragging or GUI.CounterDragging or GUI.HealthBarDragging
            or GUI.PlayerListDragging or GUI.EnchantsDragging or GUI.RSDiffDragging
            or next(GUI.MonitorBars) ~= nil
        task.wait(interactive and 0.016 or 0.033)
    end
end

