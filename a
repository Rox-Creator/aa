local function resupplyRegisterObj(obj)
    if obj.Name ~= "Resupply Cart v2" and obj.Name ~= "Resupply Cart" then return end
    local id = tostring(obj.Address)
    if RESUPPLY.Objects[id] then return end
    local interaction = nil
    pcall(function() interaction = obj:FindFirstChild("Interaction") end)
    if not interaction then return end
    local col = nil
    pcall(function() col = interaction.Color end)
    if not colorMatch(col, 52, 60, 106) then return end
    local version = obj.Name == "Resupply Cart v2" and "v2" or "v1"
    local maxGas = version == "v2" and 80000 or 40000

    -- Blade Box is a separate child of the cart (v2 has it; v1 may
    -- not). We read its own Interaction part the same way the gas
    -- interaction is read.
    local bladePart = nil
    pcall(function()
        local bb = obj:FindFirstChild("Blade Box")
        if bb then bladePart = bb:FindFirstChild("Interaction") end
    end)
    local maxBlade = version == "v2" and 80 or 40

    local function mkText(zoff)
        local t = Drawing.new("Text")
        t.Color = RESUPPLY.ESPColor
        t.Size = RESUPPLY.TextSize
        -- Match the Player ESP font (SystemBold) so all "world-overlay"
        -- text reads as belonging to the same set of indicators.
        t.Font = TITAN_FONTS[PLAYER_ESP.FontIndex].font
        t.Center = true
        t.Outline = true
        t.Visible = false
        t.ZIndex = 50 + zoff
        return t
    end

    RESUPPLY.Objects[id] = {
        obj       = obj,
        part      = interaction,
        bladePart = bladePart,
        version   = version,
        maxGas    = maxGas,
        maxBlade  = maxBlade,
        gasText   = mkText(0),
        bladeText = mkText(1),
        distText  = mkText(2),
    }
end

local function resupplyScan()
    for _, obj in pairs(Workspace:GetChildren()) do
        resupplyRegisterObj(obj)
    end
end

-- Resolves a resupply-style amount as a string from a given part.
-- `src` is a per-source cache stored on the data entry under
-- `cacheKey` (e.g. "gasSource" / "bladeSource") so repeat reads skip
-- the probe chain. `cacheChildKey` stores a matched child reference
-- when we resolved via a numeric-Value child.
local function readPartAmount(data, part, cacheKey, cacheChildKey)
    if not part then return "" end
    local src = data[cacheKey]
    local amount = ""
    if src == "Data" then
        pcall(function() amount = tostring(part.Data) end)
    elseif src == "Value" then
        pcall(function() amount = tostring(part.Value) end)
    elseif src == "child" then
        local c = data[cacheChildKey]
        if c and c.Parent then
            pcall(function() amount = tostring(c.Value) end)
        end
    elseif src == "Amount" then
        pcall(function() amount = tostring(part.Amount) end)
    elseif src == "AttrData" then
        pcall(function() amount = tostring(part:GetAttribute("Data")) end)
    elseif src == "AttrAmount" then
        pcall(function() amount = tostring(part:GetAttribute("Amount")) end)
    elseif src == "Name" then
        pcall(function() if tonumber(part.Name) then amount = part.Name end end)
    end
    if amount ~= "" and amount ~= "nil" then return amount end

    data[cacheKey] = nil
    data[cacheChildKey] = nil
    pcall(function() amount = tostring(part.Data) end)
    if amount ~= "" and amount ~= "nil" then data[cacheKey] = "Data"; return amount end
    pcall(function() amount = tostring(part.Value) end)
    if amount ~= "" and amount ~= "nil" then data[cacheKey] = "Value"; return amount end
    local matched = nil
    pcall(function()
        for _, child in pairs(part:GetChildren()) do
            local v = nil
            pcall(function() v = child.Value end)
            if v and tonumber(tostring(v)) then
                amount = tostring(v); matched = child; break
            end
        end
    end)
    if amount ~= "" and amount ~= "nil" then
        data[cacheKey] = "child"; data[cacheChildKey] = matched; return amount
    end
    pcall(function() amount = tostring(part.Amount) end)
    if amount ~= "" and amount ~= "nil" then data[cacheKey] = "Amount"; return amount end
    pcall(function() amount = tostring(part:GetAttribute("Data")) end)
    if amount ~= "" and amount ~= "nil" then data[cacheKey] = "AttrData"; return amount end
    pcall(function() amount = tostring(part:GetAttribute("Amount")) end)
    if amount ~= "" and amount ~= "nil" then data[cacheKey] = "AttrAmount"; return amount end
    pcall(function() if tonumber(part.Name) then amount = part.Name end end)
    if amount ~= "" and amount ~= "nil" then data[cacheKey] = "Name"; return amount end
    return ""
end

local function readResupplyAmount(data)
    return readPartAmount(data, data.part, "gasSource", "gasChild")
end

local function readBladeAmount(data)
    return readPartAmount(data, data.bladePart, "bladeSource", "bladeChild")
end

-- Reads the part's MaxAmount attribute (the game exposes it on the
-- Interaction part — e.g. blade box reports MaxAmount=500). Falls back
-- to other common max-attr names, returns nil if none are present.
-- Cached per-data so we don't re-probe every frame.
local function readPartMaxAmount(data, part, cacheKey)
    if not part then return nil end
    if data[cacheKey] then return data[cacheKey] end
    local m = nil
    pcall(function() m = tonumber(part:GetAttribute("MaxAmount")) end)
    if not m then pcall(function() m = tonumber(part:GetAttribute("MaxData")) end) end
    if not m then pcall(function() m = tonumber(part:GetAttribute("Max")) end) end
    if not m then pcall(function() m = tonumber(part:GetAttribute("Capacity")) end) end
    if m then data[cacheKey] = m end
    return m
end

local function resupplyHideAll(data)
    data.gasText.Visible   = false
    data.bladeText.Visible = false
    data.distText.Visible  = false
end

local function resupplyUpdate()
    if not RESUPPLY.Enabled then
        for _, data in pairs(RESUPPLY.Objects) do
            resupplyHideAll(data)
        end
        return
    end

    local playerPos = getPlayerPos()
    if not playerPos then return end

    for id, data in pairs(RESUPPLY.Objects) do
        local obj = data.obj
        local part = data.part
        if not obj or not obj.Parent or not part or not part.Parent then
            resupplyHideAll(data)
        else
            -- Use the cart Model's actual position for distance — the
            -- Interaction sub-part can sit far from the visible cart and
            -- gives nonsense readings (e.g. "8000 studs away"). Prefer
            -- PrimaryPart → Model.Position → Interaction part as last
            -- resort.
            local pos = nil
            pcall(function()
                local pp = obj.PrimaryPart
                if pp then pos = pp.Position end
            end)
            if not pos then pcall(function() pos = obj.Position end) end
            if not pos then pcall(function() pos = part.Position end) end
            if not pos then
                resupplyHideAll(data)
            else
                local dx = playerPos.X - pos.X
                local dy = playerPos.Y - pos.Y
                local dz = playerPos.Z - pos.Z
                local dist = math.sqrt(dx*dx + dy*dy + dz*dz)

                if dist > RESUPPLY.MaxDistance then
                    resupplyHideAll(data)
                else
                    local screenPos, onScreen = WorldToScreen(pos)
                    if onScreen and screenPos then
                        local gasAmt   = readResupplyAmount(data)
                        local gasNum   = tonumber(gasAmt)
                        -- Filter out interaction parts that just expose a
                        -- 0-100 "progress" value rather than a real fuel
                        -- count — same heuristic the old engine used.
                        if gasNum and gasNum >= 0 and gasNum <= 100 then
                            resupplyHideAll(data)
                        else
                            local bladeAmt = data.bladePart and readBladeAmount(data) or ""
                            local gasStr   = (gasAmt   ~= "" and gasAmt   ~= "nil") and gasAmt   or "0"
                            local bladeStr = (bladeAmt ~= "" and bladeAmt ~= "nil") and bladeAmt or "0"
                            -- Live MaxAmount lookup from the part (e.g. blade
                            -- box reports MaxAmount=500). Fall back to the
                            -- version-based default if the attribute is absent.
                            local gasMax   = readPartMaxAmount(data, data.part, "gasMaxCache")        or data.maxGas
                            local bladeMax = readPartMaxAmount(data, data.bladePart, "bladeMaxCache") or data.maxBlade
                            -- Matcha's built-in HUD reports distance as ~half
                            -- the raw stud count (1 stud ≈ 0.5m in AOT:R's
                            -- scale). Match that so our overlay agrees with
                            -- the player ESP next to it instead of doubling.
                            local fd = math.floor(dist * 0.6)

                            -- Stack three lines centred above the cart,
                            -- matching the Player ESP's vertical rhythm.
                            -- Distance sits on top, then gas, then blades.
                            local distY  = screenPos.Y - 40
                            local gasY   = screenPos.Y - 22
                            local bladeY = screenPos.Y - 4

                            data.distText.Position  = Vector2.new(screenPos.X, distY)
                            data.distText.Text      = fd .. "m"
                            data.distText.Visible   = true

                            data.gasText.Position   = Vector2.new(screenPos.X, gasY)
                            data.gasText.Text       = "Gas ( "    .. gasStr   .. " / " .. gasMax   .. " )"
                            data.gasText.Visible    = true

                            data.bladeText.Position = Vector2.new(screenPos.X, bladeY)
                            data.bladeText.Text     = "Blades ( " .. bladeStr .. " / " .. bladeMax .. " )"
                            data.bladeText.Visible  = true
                        end
                    else
                        resupplyHideAll(data)
                    end
                end
            end
        end
    end
end

local function resupplyCleanup()
    for id, data in pairs(RESUPPLY.Objects) do
        local obj = data.obj
        if not obj or not obj.Parent then
            pcall(function() data.gasText:Remove() end)
            pcall(function() data.bladeText:Remove() end)
            pcall(function() data.distText:Remove() end)
            RESUPPLY.Objects[id] = nil
        end
    end
end

-- Counter sources: walks each registered cart, sums gas + blade
-- amounts. Filters out the 0-100 "progress" reading the same way
-- the ESP filter does, so a half-empty cart's progress value
-- doesn't contaminate the gas total.
local function updateResupplyCounter()
    local totalGas, totalBlade = 0, 0
    for _, data in pairs(RESUPPLY.Objects) do
        local part = data.part
        if part and part.Parent then
            local num = tonumber(readResupplyAmount(data))
            if num and not (num >= 0 and num <= 100) then
                totalGas = totalGas + num
            end
        end
        if data.bladePart and data.bladePart.Parent then
            local bnum = tonumber(readBladeAmount(data))
            if bnum then totalBlade = totalBlade + bnum end
        end
    end
    GUI.GasTotal   = totalGas
    GUI.BladeTotal = totalBlade
end

